// КОНФИГ
// ═══════════════════════════════════════

var WB_STOCKS_API_BASE_   = 'https://seller-analytics-api.wildberries.ru';
var WB_STOCKS_API_PATH_   = '/api/v1/warehouse_remains';
var WB_STOCKS_TOKEN_KEYS_ = ['WB_TOKEN_ANALYTICS', 'WB_TOKEN_STATISTICS'];

var STOCKS_RAW_SHEET_         = 'RAW_WB_STOCKS';
var STOCKS_RAW_SOURCE_API_    = 'WB_API_STOCKS_T5';
var STOCKS_LOADID_API_PREFIX_ = 'STK_API_';
var IMPORT_LOG_STOCKS_SHEET_  = 'IMPORT_LOG_STOCKS';
var WB_STOCKS_TZ_             = 'Europe/Moscow';

// Группировки create (как в подтверждённом probe T5).
var WB_STOCKS_GROUPS_ = 'groupByBrand=false&groupBySubject=false&groupBySa=true' +
  '&groupByNm=true&groupByBarcode=true&groupBySize=true';

// Task polling.
var WB_STOCKS_TASK_MAX_WAIT_MS_ = 90000;   // максимум ожидания готовности отчёта
var WB_STOCKS_TASK_POLL_PAUSE_  = 5000;    // пауза между опросами статуса
var WB_STOCKS_TASK_CREATE_PAUSE_ = 3000;   // пауза после create до первого статуса

// Спец-категории внутри warehouses[] (не физические склады).
var WB_STOCKS_WH_TOTAL_      = 'Всего находится на складах';
var WB_STOCKS_WH_TO_CLIENT_  = 'В пути до получателей';
var WB_STOCKS_WH_FROM_CLIENT_ = 'В пути возвраты на склад WB';

var IMPORT_LOG_STOCKS_HEADERS_ = [
  'load_id', 'loaded_at', 'snapshot_date', 'snapshot_time',
  'rows_imported', 'skipped_dupes',
  'physical_rows', 'in_transit_rows',
  'unique_nmId', 'unmatched_nmId', 'total_physical_qty',
  'status', 'error_message'
];

// Фолбэк-заголовки RAW_WB_STOCKS (точная копия SHEETS_SCHEMA, 48 колонок) —
// используются ТОЛЬКО если SHEETS_SCHEMA недоступна при создании листа.
var STOCKS_FALLBACK_HEADERS_ = [
