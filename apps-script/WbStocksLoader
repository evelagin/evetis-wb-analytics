  'source_api', 'request_date', 'row_hash', 'raw_row_number',
  'wb_nm_id', 'wb_vendor_code', 'barcode', 'title',
  'brand_name', 'subject_name', 'category_name', 'tech_size',
  'internal_sku', 'sku_match_status',
  'warehouse_id', 'warehouse_name', 'warehouse_type',
  'region_name', 'federal_district', 'is_priority_warehouse', 'warehouse_match_status',
  'quantity_total', 'quantity_available', 'quantity_reserved',
  'quantity_in_transit', 'quantity_not_available', 'quantity_defect', 'quantity_raw',
  'stock_status', 'is_fbo_stock', 'is_available_for_sale',
  'last_change_date', 'stock_source_status',
  'wb_supply_id', 'supply_status', 'expected_qty',
  'accepted_qty', 'acceptance_date', 'supply_warehouse',
  'is_duplicate', 'processed_status', 'error_code', 'error_message',
  'raw_json'
];


