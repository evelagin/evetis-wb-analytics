// АРХИВИРОВАНИЕ
// ═══════════════════════════════════════════════════════════════

function archiveWbStorageMonth(year, month, clearAfterArchive) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();
  if (clearAfterArchive === undefined) clearAfterArchive = false;
  var monthStr = year + '-' + pad2_(month);
  var archiveName = 'ARCHIVE_WB_STORAGE_' + year + '_' + pad2_(month);

  var rawSheet = ss.getSheetByName('RAW_WB_STORAGE');
  if (!rawSheet || rawSheet.getLastRow() < 2) {
    ui.alert('⚠️', 'RAW_WB_STORAGE пуст.', ui.ButtonSet.OK); return;
  }
  var rawHMap = getHeaderMap_(rawSheet);
  var rawData = readSheetData_(rawSheet);
  var dateCol = findCol_(rawHMap, ['date']);
  var costCol = findCol_(rawHMap, ['storage_cost']);
  var nmCol = findCol_(rawHMap, ['nmID']);
  if (dateCol === -1) { ui.alert('❌', 'Нет колонки date.', ui.ButtonSet.OK); return; }

  var monthPrefix = monthStr + '-';
  var monthRows = [], totalCost = 0, nmIdSet = {};
  var rawHeaders = rawSheet.getRange(1,1,1,rawSheet.getLastColumn()).getValues()[0];
  var colCount = rawHeaders.length;

  for (var i = 0; i < rawData.length; i++) {
    var dk = normalizeStorageDate_(rawData[i][dateCol]);
    if (!dk || dk.indexOf(monthPrefix) !== 0) continue;
    monthRows.push(rawData[i]);
    if (costCol !== -1) totalCost += Number(rawData[i][costCol]) || 0;
    if (nmCol !== -1) { var nm = String(rawData[i][nmCol] || '').trim(); if (nm && nm !== '0') nmIdSet[nm] = true; }
  }
  if (monthRows.length === 0) { ui.alert('⚠️', 'Нет данных за ' + monthStr + '.', ui.ButtonSet.OK); return; }

  var archSheet = ss.getSheetByName(archiveName);
  if (archSheet) {
    if (archSheet.getLastRow() > 1) archSheet.getRange(2, 1, archSheet.getLastRow() - 1, archSheet.getLastColumn()).clearContent();
  } else {
    archSheet = ss.insertSheet(archiveName);
    if (colCount > archSheet.getMaxColumns()) archSheet.insertColumnsAfter(archSheet.getMaxColumns(), colCount - archSheet.getMaxColumns());
    archSheet.getRange(1,1,1,colCount).setValues([rawHeaders]);
    archSheet.getRange(1,1,1,colCount).setFontWeight('bold').setBackground('#1F2937').setFontColor('#FFFFFF');
    archSheet.setFrozenRows(1);
  }
  if (archSheet.getMaxRows() < monthRows.length + 1) archSheet.insertRowsAfter(archSheet.getMaxRows(), monthRows.length + 1 - archSheet.getMaxRows());
  archSheet.getRange(2, 1, monthRows.length, colCount).setValues(monthRows);
  SpreadsheetApp.flush();

  var clearedCount = 0;
  if (clearAfterArchive) clearedCount = clearStorageMonth_(rawSheet, dateCol, monthPrefix);

  ui.alert('📦 Архивация', '📦 ' + archiveName + '\n\n' +
    'Строк: ' + monthRows.length + '\nSKU: ' + Object.keys(nmIdSet).length +
    '\nСумма: ' + roundTwo_(totalCost) + ' ₽\n\n' +
    (clearAfterArchive ? '🗑️ Очищено: ' + clearedCount + ' строк' : '💾 RAW не очищен'),
    ui.ButtonSet.OK);
}

function archiveWbStorageMonthMenu() {
  var ui = SpreadsheetApp.getUi();
  var resp = ui.prompt('📦 Архивация', 'Месяц (YYYY-MM):', ui.ButtonSet.OK_CANCEL);
  if (resp.getSelectedButton() !== ui.Button.OK) return;
  var m = resp.getResponseText().trim();
  if (!/^\d{4}-\d{2}$/.test(m)) { ui.alert('❌', 'Формат: YYYY-MM', ui.ButtonSet.OK); return; }
  archiveWbStorageMonth(Number(m.split('-')[0]), Number(m.split('-')[1]), false);
}


