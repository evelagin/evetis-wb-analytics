/**
 * Internal: импортирует новые XLSX из папки.
 * Возвращает объект со статистикой, без UI-алертов.
 *
 * @return {Object} { status, newFiles, skippedFiles, errorFiles,
 *   totalRows, totalSum, results, folderName, fileCount, error }
 */
function importDriveStorageInternal_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var out = { status: 'ERROR', newFiles: 0, skippedFiles: 0, errorFiles: 0,
    totalRows: 0, totalSum: 0, results: [], folderName: '', fileCount: 0, error: '' };

  if (!STORAGE_REPORTS_FOLDER_ID || STORAGE_REPORTS_FOLDER_ID === 'ВСТАВИТЬ_ID_ПАПКИ_С_ОТЧЕТАМИ_ХРАНЕНИЯ') {
    out.error = 'Не задан STORAGE_REPORTS_FOLDER_ID'; return out;
  }

  var sheets = ensureStorageSheets_(ss);
  if (!sheets) { out.error = 'Не удалось создать листы'; return out; }

  var folder;
  try { folder = DriveApp.getFolderById(STORAGE_REPORTS_FOLDER_ID); }
  catch (e) { out.error = 'Папка не найдена: ' + e.message; return out; }
  out.folderName = folder.getName();

  var xlsxFiles = [];
  var it1 = folder.getFilesByType('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
  while (it1.hasNext()) { var f = it1.next(); xlsxFiles.push({ id: f.getId(), name: f.getName() }); }
  var it2 = folder.getFilesByType('application/vnd.ms-excel');
  while (it2.hasNext()) {
    var f2 = it2.next(); var dup = false;
    for (var d = 0; d < xlsxFiles.length; d++) { if (xlsxFiles[d].id === f2.getId()) { dup = true; break; } }
    if (!dup) xlsxFiles.push({ id: f2.getId(), name: f2.getName() });
  }

  out.fileCount = xlsxFiles.length;
  if (xlsxFiles.length === 0) { out.status = 'OK'; out.error = 'Папка пуста'; return out; }

  var processedIds = getProcessedFileIds_(sheets.logSheet);

  for (var fi = 0; fi < xlsxFiles.length; fi++) {
    var xf = xlsxFiles[fi];
    if (processedIds[xf.id] === 'OK') { out.skippedFiles++; continue; }

    var result = importSingleStorageFile_(ss, sheets.rawSheet, xf.id, xf.name);
    writeImportLogEntry_(sheets.logSheet, result);

    if (result.status === 'OK') {
      out.newFiles++;
      out.totalRows += result.rows_imported;
      out.totalSum += result.storage_sum;
    } else { out.errorFiles++; }
    out.results.push(result);
  }

  out.status = out.errorFiles > 0 ? 'PARTIAL' : 'OK';
  return out;
}


