/**
 * Импорт одного xlsx-файла (без изменений от v2).
 */
function importSingleStorageFile_(ss, rawSheet, fileId, fileName) {
  var result = {
    load_id: 'STOR_DRV_' + Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyyMMdd_HHmmss'),
    loaded_at: Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyy-MM-dd HH:mm:ss'),
    source_type: 'DRIVE', period_from: '', period_to: '',
    file_id: fileId, file_name: fileName, task_id: '',
    rows_imported: 0, unique_skus: 0, storage_sum: 0,
    finance_storage_sum: 0, delta: 0, status: 'ERROR', error_message: ''
  };
  var tempId = null;
  try {
    tempId = convertStorageXlsxToGsheet_(fileId, fileName);
    if (!tempId) { result.error_message = 'Конвертация xlsx не удалась'; return result; }
    var tempSS = SpreadsheetApp.openById(tempId);
    var srcSheet = tempSS.getSheetByName(STORAGE_FOLDER_SRC_SHEET_);
    if (!srcSheet) {
      var allSheets = tempSS.getSheets();
      for (var si = 0; si < allSheets.length; si++) {
        var sn = allSheets[si].getName().toLowerCase();
        if (sn.indexOf('детальн') >= 0 || sn.indexOf('detail') >= 0) { srcSheet = allSheets[si]; break; }
      }
      if (!srcSheet) { result.error_message = 'Лист не найден'; cleanupStorageTempSheet_(tempId); return result; }
    }
    var srcLastRow = srcSheet.getLastRow();
    var srcLastCol = srcSheet.getLastColumn();
    if (srcLastRow < STORAGE_FOLDER_HEADER_ROW_ + 1) {
      result.error_message = 'Нет данных'; cleanupStorageTempSheet_(tempId); return result;
    }
    var srcValues = srcSheet.getRange(1, 1, srcLastRow, srcLastCol).getValues();
    var headerRowIdx = STORAGE_FOLDER_HEADER_ROW_ - 1;
    var colMap = buildStorageColMapping_(srcValues[headerRowIdx]);
    var missing = [];
    ['date','nmID','storage_cost'].forEach(function(c){ if(colMap[c]===undefined) missing.push(c); });
    if (missing.length > 0) { result.error_message = 'Нет колонок: ' + missing.join(', '); cleanupStorageTempSheet_(tempId); return result; }
    var rawHMap = getHeaderMap_(rawSheet);
    normalizeHMap_(rawHMap);
    var rawColCount = rawSheet.getRange(1,1,1,rawSheet.getLastColumn()).getValues()[0].length;
    var norm = buildNormalizedRows_(srcValues, headerRowIdx + 1, colMap, rawHMap, rawColCount, result.load_id, result.loaded_at, fileId);
    cleanupStorageTempSheet_(tempId); tempId = null;
    if (norm.rows.length === 0) { result.error_message = 'Нет строк с валидной датой'; return result; }
    result.period_from = norm.dateMin; result.period_to = norm.dateMax;
    clearStorageBySourceReportId_(rawSheet, fileId);
    writeRowsToRawStorage_(rawSheet, norm.rows, rawColCount);
    var finStorage = getFinanceStorageFee_(ss, result.period_from, result.period_to);
    result.rows_imported = norm.rows.length;
    result.unique_skus = Object.keys(norm.nmIdSet).length;
    result.storage_sum = roundTwo_(norm.totalCost);
    result.finance_storage_sum = roundTwo_(finStorage);
    result.delta = roundTwo_(norm.totalCost - finStorage);
    result.status = 'OK';
    return result;
  } catch (e) {
    result.error_message = e.message;
    if (tempId) cleanupStorageTempSheet_(tempId);
    return result;
  }
}


