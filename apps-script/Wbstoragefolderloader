function ensureStorageSheets_(ss) {
  var raw = ss.getSheetByName('RAW_WB_STORAGE');
  if(!raw){createRawWbStorageSheet();raw=ss.getSheetByName('RAW_WB_STORAGE');if(!raw)return null;}
  var log = ss.getSheetByName(IMPORT_LOG_STORAGE_SHEET_NAME_);
  if(!log){createImportLogStorageSheet();log=ss.getSheetByName(IMPORT_LOG_STORAGE_SHEET_NAME_);if(!log)return null;}
  return {rawSheet:raw,logSheet:log};
}

/**
 * Добавляет camelCase-алиасы для известных колонок,
 * чтобы rawHMap['nmID'] работал даже если заголовок в листе = 'nmid'.
 *
 * getHeaderMap_() возвращает lowercase ключи (nmid),
 * а код использует camelCase (nmID). Эта функция мостит разницу.
 */
function normalizeHMap_(hMap) {
  var aliases = [
    ['nmid', 'nmID'],
    ['nmid', 'nm_id'],
    ['nmID', 'nmid']
  ];
  for (var i = 0; i < aliases.length; i++) {
    var from = aliases[i][0], to = aliases[i][1];
    if (hMap[from] !== undefined && hMap[to] === undefined) {
      hMap[to] = hMap[from];
    }
  }
  return hMap;
}

function writeRowsToRawStorage_(rawSheet, rows, rawColCount) {
  if(rows.length===0) return;
  var ir = rawSheet.getLastRow()+1; if(ir<2)ir=2;
  if(rawSheet.getMaxColumns()<rawColCount) rawSheet.insertColumnsAfter(rawSheet.getMaxColumns(),rawColCount-rawSheet.getMaxColumns());
  if(rawSheet.getMaxRows()<ir+rows.length-1) rawSheet.insertRowsAfter(rawSheet.getMaxRows(),ir+rows.length-rawSheet.getMaxRows());
  rawSheet.getRange(ir,1,rows.length,rawColCount).setValues(rows);
  SpreadsheetApp.flush();
}

function buildNormalizedRows_(srcValues, dataStartRow, colMap, rawHMap, rawColCount, loadId, loadedAt, sourceReportId) {
  var rows=[],totalCost=0,nmIdSet={},dateMin=null,dateMax=null;
  for(var ri=dataStartRow;ri<srcValues.length;ri++){
    var srcRow=srcValues[ri];
    var dateVal=colMap.date!==undefined?srcRow[colMap.date]:null;
    var dk=normalizeStorageDate_(dateVal); if(!dk)continue;
    var nmRaw=colMap.nmID!==undefined?srcRow[colMap.nmID]:'';
    var nmId=String(nmRaw||'').trim().replace(/\.0$/,'');
    var cost=colMap.storage_cost!==undefined?(Number(srcRow[colMap.storage_cost])||0):0;
    totalCost+=cost;
    if(nmId&&nmId!=='0')nmIdSet[nmId]=true;
    if(!dateMin||dk<dateMin)dateMin=dk;
    if(!dateMax||dk>dateMax)dateMax=dk;
    var newRow=new Array(rawColCount);for(var c=0;c<rawColCount;c++)newRow[c]='';
    if(rawHMap['load_id']!==undefined)newRow[rawHMap['load_id']]=loadId;
    if(rawHMap['loaded_at']!==undefined)newRow[rawHMap['loaded_at']]=loadedAt;
    if(rawHMap['source_report']!==undefined)newRow[rawHMap['source_report']]='WB_paid_storage';
    if(rawHMap['date']!==undefined)newRow[rawHMap['date']]=dk;
    if(rawHMap['nmID']!==undefined)newRow[rawHMap['nmID']]=nmId;
    if(rawHMap['storage_cost']!==undefined)newRow[rawHMap['storage_cost']]=cost;
    if(rawHMap['vendor_code']!==undefined&&colMap.vendor_code!==undefined)newRow[rawHMap['vendor_code']]=String(srcRow[colMap.vendor_code]||'').trim();
    if(rawHMap['barcode']!==undefined&&colMap.barcode!==undefined)newRow[rawHMap['barcode']]=String(srcRow[colMap.barcode]||'').trim();
    if(rawHMap['warehouse_name']!==undefined&&colMap.warehouse_name!==undefined)newRow[rawHMap['warehouse_name']]=String(srcRow[colMap.warehouse_name]||'').trim();
    if(rawHMap['quantity']!==undefined&&colMap.quantity!==undefined)newRow[rawHMap['quantity']]=Number(srcRow[colMap.quantity])||0;
    if(rawHMap['volume']!==undefined&&colMap.volume_l!==undefined)newRow[rawHMap['volume']]=Number(srcRow[colMap.volume_l])||0;
    if(rawHMap['warehouse_id']!==undefined&&colMap.warehouse_id!==undefined)newRow[rawHMap['warehouse_id']]=String(srcRow[colMap.warehouse_id]||'').trim();
    if(rawHMap['supply_id']!==undefined&&colMap.supply_id!==undefined)newRow[rawHMap['supply_id']]=String(srcRow[colMap.supply_id]||'').trim();
    if(rawHMap['calculation_type']!==undefined&&colMap.calculation_type!==undefined)newRow[rawHMap['calculation_type']]=String(srcRow[colMap.calculation_type]||'').trim();
    if(rawHMap['subject_name']!==undefined&&colMap.subject_name!==undefined)newRow[rawHMap['subject_name']]=String(srcRow[colMap.subject_name]||'').trim();
    if(rawHMap['brand_name']!==undefined&&colMap.brand_name!==undefined)newRow[rawHMap['brand_name']]=String(srcRow[colMap.brand_name]||'').trim();
    if(rawHMap['category']!==undefined&&colMap.category!==undefined)newRow[rawHMap['category']]=String(srcRow[colMap.category]||'').trim();
    if(rawHMap['source_report_id']!==undefined)newRow[rawHMap['source_report_id']]=sourceReportId;
    if(rawHMap['is_duplicate']!==undefined)newRow[rawHMap['is_duplicate']]='FALSE';
    if(rawHMap['processed_status']!==undefined)newRow[rawHMap['processed_status']]='OK';
    if(rawHMap['error_message']!==undefined)newRow[rawHMap['error_message']]='';
    rows.push(newRow);
  }
  return {rows:rows,totalCost:totalCost,nmIdSet:nmIdSet,dateMin:dateMin,dateMax:dateMax};
}


