/**
 * Маппинг WB API → RAW_WB_STORAGE (по аудиту 29.05.2026).
 */
function normalizeApiRows_(reportData, rawHMap, rawColCount, loadId, loadedAt, sourceReportId) {
  var rows = [], totalCost = 0, nmIdSet = {}, dateMin = null, dateMax = null;
  for (var i = 0; i < reportData.length; i++) {
    var item = reportData[i];
    var dk = normalizeStorageDate_(item.date || item.Date || item.originalDate || '');
    if (!dk) continue;
    var nmId = String(item.nmId || item.nmID || '').trim().replace(/\.0$/, '');
    var cost = Number(item.warehousePrice || item.storageCost || item.storage_cost || 0) || 0;
    totalCost += cost;
    if (nmId && nmId !== '0') nmIdSet[nmId] = true;
    if (!dateMin || dk < dateMin) dateMin = dk;
    if (!dateMax || dk > dateMax) dateMax = dk;
    var newRow = new Array(rawColCount); for (var c = 0; c < rawColCount; c++) newRow[c] = '';
    if(rawHMap['load_id']!==undefined)newRow[rawHMap['load_id']]=loadId;
    if(rawHMap['loaded_at']!==undefined)newRow[rawHMap['loaded_at']]=loadedAt;
    if(rawHMap['source_report']!==undefined)newRow[rawHMap['source_report']]='WB_paid_storage';
    if(rawHMap['date']!==undefined)newRow[rawHMap['date']]=dk;
    if(rawHMap['nmID']!==undefined)newRow[rawHMap['nmID']]=nmId;
    if(rawHMap['storage_cost']!==undefined)newRow[rawHMap['storage_cost']]=cost;
    if(rawHMap['vendor_code']!==undefined)newRow[rawHMap['vendor_code']]=String(item.vendorCode||item.vendor_code||'').trim();
    if(rawHMap['barcode']!==undefined)newRow[rawHMap['barcode']]=String(item.barcode||'').trim();
    if(rawHMap['warehouse_name']!==undefined)newRow[rawHMap['warehouse_name']]=String(item.warehouse||item.warehouseName||'').trim();
    if(rawHMap['quantity']!==undefined)newRow[rawHMap['quantity']]=Number(item.barcodesCount||item.quantity||0)||0;
    if(rawHMap['volume']!==undefined)newRow[rawHMap['volume']]=Number(item.volume||0)||0;
    if(rawHMap['warehouse_id']!==undefined)newRow[rawHMap['warehouse_id']]=String(item.officeId||item.warehouseId||'').trim();
    if(rawHMap['supply_id']!==undefined)newRow[rawHMap['supply_id']]=String(item.giId||item.supplyId||'').trim();
    if(rawHMap['calculation_type']!==undefined)newRow[rawHMap['calculation_type']]=String(item.calcType||item.calculationType||'').trim();
    if(rawHMap['subject_name']!==undefined)newRow[rawHMap['subject_name']]=String(item.subject||item.subjectName||'').trim();
    if(rawHMap['brand_name']!==undefined)newRow[rawHMap['brand_name']]=String(item.brand||item.brandName||'').trim();
    if(rawHMap['category']!==undefined)newRow[rawHMap['category']]=String(item.category||'').trim();
    if(rawHMap['source_report_id']!==undefined)newRow[rawHMap['source_report_id']]=sourceReportId;
    if(rawHMap['is_duplicate']!==undefined)newRow[rawHMap['is_duplicate']]='FALSE';
    if(rawHMap['processed_status']!==undefined)newRow[rawHMap['processed_status']]='OK';
    if(rawHMap['error_message']!==undefined)newRow[rawHMap['error_message']]='';
    rows.push(newRow);
  }
  return { rows: rows, totalCost: totalCost, nmIdSet: nmIdSet, dateMin: dateMin, dateMax: dateMax };
}


/**
 * Internal: импорт через WB API.
 * Возвращает result-объект, без UI-алертов.
 *
 * @param {string} dateFrom
 * @param {string} dateTo
 * @return {Object} result с полями IMPORT_LOG_STORAGE + error
 */
function importWbStorageFromApiInternal_(dateFrom, dateTo) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  var result = {
    load_id: 'STOR_API_' + Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyyMMdd_HHmmss'),
    loaded_at: Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyy-MM-dd HH:mm:ss'),
    source_type: 'API', period_from: dateFrom, period_to: dateTo,
    file_id: '', file_name: 'WB_API', task_id: '',
    rows_imported: 0, unique_skus: 0, storage_sum: 0,
    finance_storage_sum: 0, delta: 0, status: 'ERROR', error_message: ''
  };

  if (!dateFrom || !dateTo) { result.error_message = 'Не указаны dateFrom/dateTo'; return result; }

  var dFrom = new Date(dateFrom + 'T00:00:00+03:00');
  var dTo = new Date(dateTo + 'T00:00:00+03:00');
  var days = Math.ceil((dTo - dFrom) / (86400000)) + 1;
  if (days > WB_STORAGE_API_MAX_DAYS_) {
    result.error_message = 'Период ' + days + ' дней > макс. ' + WB_STORAGE_API_MAX_DAYS_; return result;
  }

  var token = getScriptProperty_(WB_STORAGE_TOKEN_KEY_);
  if (!token) { result.error_message = 'Нет токена: ' + WB_STORAGE_TOKEN_KEY_; return result; }

  var sheets = ensureStorageSheets_(ss);
  if (!sheets) { result.error_message = 'Не удалось создать листы'; return result; }

  try {
    // 1. Создать задачу
    console.log('  API: создаю задачу ' + dateFrom + ' — ' + dateTo);
    var createResp = UrlFetchApp.fetch(
      WB_STORAGE_API_BASE_ + '/api/v1/paid_storage?dateFrom=' + dateFrom + '&dateTo=' + dateTo,
      { method: 'get', headers: { 'Authorization': token }, muteHttpExceptions: true }
    );
    if (createResp.getResponseCode() !== 200) {
      result.error_message = 'HTTP ' + createResp.getResponseCode() + ': ' + createResp.getContentText().substring(0, 200);
      writeImportLogEntry_(sheets.logSheet, result); return result;
    }
    var createData = JSON.parse(createResp.getContentText());
    var taskId = '';
    if (createData.data && createData.data.taskId) taskId = String(createData.data.taskId);
    else if (createData.taskId) taskId = String(createData.taskId);
    if (!taskId) { result.error_message = 'Нет taskId'; writeImportLogEntry_(sheets.logSheet, result); return result; }
    result.task_id = taskId;
    console.log('  taskId: ' + taskId);

    // 2. Опрос статуса
    var ready = false;
    for (var p = 0; p < WB_STORAGE_API_MAX_POLLS_; p++) {
      Utilities.sleep(WB_STORAGE_API_POLL_INTERVAL_);
      var sr = UrlFetchApp.fetch(
        WB_STORAGE_API_BASE_ + '/api/v1/paid_storage/tasks/' + taskId + '/status',
        { method: 'get', headers: { 'Authorization': token }, muteHttpExceptions: true }
      );
      var sd; try { sd = JSON.parse(sr.getContentText()); } catch (e) { sd = {}; }
      var ts = (sd.data && sd.data.status) || sd.status || '';
      console.log('  Опрос ' + (p + 1) + '/' + WB_STORAGE_API_MAX_POLLS_ + ': ' + ts);
      if (ts === 'done') { ready = true; break; }
      if (ts === 'purged' || ts === 'canceled') {
        result.error_message = 'Задача ' + ts; writeImportLogEntry_(sheets.logSheet, result); return result;
      }
    }
    if (!ready) {
      result.error_message = 'Таймаут'; writeImportLogEntry_(sheets.logSheet, result); return result;
    }

    // 3. Скачать
    console.log('  Скачиваю...');
    var dlResp = UrlFetchApp.fetch(
      WB_STORAGE_API_BASE_ + '/api/v1/paid_storage/tasks/' + taskId + '/download',
      { method: 'get', headers: { 'Authorization': token }, muteHttpExceptions: true }
    );
    if (dlResp.getResponseCode() !== 200) {
      result.error_message = 'Download HTTP ' + dlResp.getResponseCode();
      writeImportLogEntry_(sheets.logSheet, result); return result;
    }
    var reportData = JSON.parse(dlResp.getContentText());
    console.log('  Записей: ' + reportData.length);

    if (!reportData || reportData.length === 0) {
      result.rows_imported = 0; result.status = 'OK'; result.error_message = 'Пустой отчёт';
      writeImportLogEntry_(sheets.logSheet, result); return result;
    }

    // 4. Нормализация
    var rawHMap = getHeaderMap_(sheets.rawSheet);
    normalizeHMap_(rawHMap);
    var rawColCount = sheets.rawSheet.getRange(1,1,1,sheets.rawSheet.getLastColumn()).getValues()[0].length;
    var norm = normalizeApiRows_(reportData, rawHMap, rawColCount,
      result.load_id, result.loaded_at, 'API_' + taskId);

    if (norm.rows.length === 0) {
      result.error_message = 'Нет строк после нормализации';
      writeImportLogEntry_(sheets.logSheet, result); return result;
    }

    // 5. Очистка + запись
    clearStorageBySourceReportId_(sheets.rawSheet, 'API_' + taskId);
    clearStorageApiPeriod_(sheets.rawSheet, dateFrom, dateTo);
    writeRowsToRawStorage_(sheets.rawSheet, norm.rows, rawColCount);

    // 6. Результат
    result.rows_imported = norm.rows.length;
    result.unique_skus = Object.keys(norm.nmIdSet).length;
    result.storage_sum = roundTwo_(norm.totalCost);

    if (result.rows_imported > 0 && result.storage_sum === 0) {
      result.status = 'WARNING_ZERO_STORAGE_SUM';
      result.error_message = 'rows=' + result.rows_imported + ' но sum=0';
    } else {
      result.status = 'OK';
    }

    writeImportLogEntry_(sheets.logSheet, result);
    return result;

  } catch (e) {
    result.error_message = e.message;
    console.log('❌ API: ' + e.message);
    writeImportLogEntry_(sheets.logSheet, result);
    return result;
  }
}


