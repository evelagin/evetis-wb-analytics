/**
 * Возвращает дедуплицированную карту хранения по SKU и дате.
 *
 * Ключ: "YYYY-MM-DD|nmID"
 * Значение: storage_cost (₽)
 *
 * Правила дедупликации:
 *   1. API > DRIVE (source_report_id начинается с 'API_')
 *   2. При нескольких API за одну дату/SKU — самый свежий load_id
 *   3. При нескольких DRIVE за одну дату/SKU — самый свежий load_id
 *   4. Никогда не суммировать разные source_report_id за одну дату/SKU
 *
 * @param {string} [dateFrom] — "YYYY-MM-DD" (опционально)
 * @param {string} [dateTo] — "YYYY-MM-DD" (опционально)
 * @return {Object} { map: {key→cost}, dateMin, dateMax, totalCost, skuCount, rowCount }
 */
function getCleanStorageDailyMap_(dateFrom, dateTo) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var rawSheet = ss.getSheetByName('RAW_WB_STORAGE');
  if (!rawSheet || rawSheet.getLastRow() < 2) {
    console.log('  cleanMap: RAW_WB_STORAGE пуст или не найден (lastRow=' + (rawSheet ? rawSheet.getLastRow() : 'null') + ')');
    return { map: {}, dateMin: null, dateMax: null, totalCost: 0, skuCount: 0, rowCount: 0 };
  }

  var hMap = getHeaderMap_(rawSheet);
  normalizeHMap_(hMap);
  var rawData = readSheetData_(rawSheet);
  var dateCol = findCol_(hMap, ['date']);
  var costCol = findCol_(hMap, ['storage_cost']);
  var nmCol = findCol_(hMap, ['nmID']);
  var loadIdCol = findCol_(hMap, ['load_id']);
  var srcRepCol = findCol_(hMap, ['source_report_id']);

  // Диагностика: показать что видим
  var headerKeys = Object.keys(hMap);
  console.log('  cleanMap: lastRow=' + rawSheet.getLastRow() + ', rawData.length=' + rawData.length +
    ', headers=[' + headerKeys.join(',') + ']');
  console.log('  cleanMap: dateCol=' + dateCol + ', costCol=' + costCol + ', nmCol=' + nmCol +
    ', loadIdCol=' + loadIdCol + ', srcRepCol=' + srcRepCol);
  console.log('  cleanMap: фильтр dateFrom=' + (dateFrom||'нет') + ', dateTo=' + (dateTo||'нет'));

  if (dateCol === -1 || costCol === -1 || nmCol === -1) {
    console.log('  cleanMap: ❌ ОБРЫВ — не найдены колонки!');
    return { map: {}, dateMin: null, dateMax: null, totalCost: 0, skuCount: 0, rowCount: 0 };
  }

  // Диагностика: первые 3 строки
  for (var dbg = 0; dbg < Math.min(3, rawData.length); dbg++) {
    var dbgDate = rawData[dbg][dateCol];
    var dbgNm = rawData[dbg][nmCol];
    var dbgCost = rawData[dbg][costCol];
    var dbgDk = normalizeStorageDate_(dbgDate);
    console.log('  cleanMap: row' + dbg + ' date=' + dbgDate + '(→' + dbgDk + ') nmID=' + dbgNm + ' cost=' + dbgCost);
  }

  // ── Двухпроходная агрегация ──
  // Проход 1: SUM по date|nmID|sourceReportId (один SKU может быть на нескольких складах)
  var byDateNmSrc = {}; // "date|nmId|srcRep" → { cost, loadId, isApi }
  var skipNoDate = 0, skipDateFilter = 0, skipNoNm = 0, processed = 0;

  for (var i = 0; i < rawData.length; i++) {
    var dk = normalizeStorageDate_(rawData[i][dateCol]);
    if (!dk) { skipNoDate++; continue; }

    if (dateFrom && dk < dateFrom) { skipDateFilter++; continue; }
    if (dateTo && dk > dateTo) { skipDateFilter++; continue; }

    var nmId = normalizeNmId_(rawData[i][nmCol]);
    if (!nmId) { skipNoNm++; continue; }

    processed++;
    var cost = Number(rawData[i][costCol]) || 0;
    var loadId = loadIdCol !== -1 ? String(rawData[i][loadIdCol] || '') : '';
    var srcRep = srcRepCol !== -1 ? String(rawData[i][srcRepCol] || '') : '';
    var isApi = srcRep.indexOf('API_') === 0;

    var key3 = dk + '|' + nmId + '|' + srcRep;
    if (!byDateNmSrc[key3]) {
      byDateNmSrc[key3] = { cost: cost, loadId: loadId, isApi: isApi };
    } else {
      byDateNmSrc[key3].cost += cost;  // SUM: разные склады одного SKU из одного источника
      if (loadId > byDateNmSrc[key3].loadId) byDateNmSrc[key3].loadId = loadId;
    }
  }

  // Проход 2: для каждого date|nmID выбираем лучший источник (API > DRIVE, свежий > старый)
  var candidates = {};
  var key3List = Object.keys(byDateNmSrc);
  for (var k3i = 0; k3i < key3List.length; k3i++) {
    var parts3 = key3List[k3i].split('|');
    var key2 = parts3[0] + '|' + parts3[1];
    var entry = byDateNmSrc[key3List[k3i]];

    if (!candidates[key2]) {
      candidates[key2] = { cost: entry.cost, loadId: entry.loadId, isApi: entry.isApi };
    } else {
      var existing = candidates[key2];
      if (entry.isApi && !existing.isApi) {
        candidates[key2] = { cost: entry.cost, loadId: entry.loadId, isApi: true };
      } else if (!entry.isApi && existing.isApi) {
        // Оставляем API
      } else if (entry.loadId > existing.loadId) {
        candidates[key2] = { cost: entry.cost, loadId: entry.loadId, isApi: entry.isApi };
      }
    }
  }

  console.log('  cleanMap: processed=' + processed + ', groups=' + key3List.length +
    ', candidates=' + Object.keys(candidates).length +
    ', skipNoDate=' + skipNoDate + ', skipDateFilter=' + skipDateFilter + ', skipNoNm=' + skipNoNm);

  // ── Строим финальную карту ──
  var map = {};
  var totalCost = 0;
  var nmIdSet = {};
  var dateMin = null, dateMax = null;

  var keys = Object.keys(candidates);
  for (var ki = 0; ki < keys.length; ki++) {
    var k = keys[ki];
    var c = candidates[k].cost;
    map[k] = c;
    totalCost += c;

    var parts = k.split('|');
    var d = parts[0];
    var nm = parts[1];
    nmIdSet[nm] = true;
    if (!dateMin || d < dateMin) dateMin = d;
    if (!dateMax || d > dateMax) dateMax = d;
  }

  return {
    map: map,
    dateMin: dateMin,
    dateMax: dateMax,
    totalCost: totalCost,
    skuCount: Object.keys(nmIdSet).length,
    rowCount: keys.length
  };
}

/**
 * Агрегация чистой карты по датам (для сверки).
 * @param {Object} cleanMap — от getCleanStorageDailyMap_()
 * @return {Object} { date → sum }
 */
function aggregateCleanMapByDate_(cleanMap) {
  var byDate = {};
  var keys = Object.keys(cleanMap.map);
  for (var i = 0; i < keys.length; i++) {
    var date = keys[i].split('|')[0];
    if (!byDate[date]) byDate[date] = 0;
    byDate[date] += cleanMap.map[keys[i]];
  }
  return byDate;
}


