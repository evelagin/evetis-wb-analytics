// МЕСЯЧНОЕ ЗАКРЫТИЕ
// ═══════════════════════════════════════════════════════════════

function closeStorageMonth(year, month) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();
  var monthStr = year + '-' + pad2_(month);

  var coverage = checkWbStorageCoverageInternal_(ss, monthStr);
  if (!coverage) { ui.alert('❌', 'Не удалось проверить покрытие.', ui.ButtonSet.OK); return; }

  var hasCriticalGaps = coverage.missing.length > 0;
  var recon = buildIntersectionReconciliation_(ss);

  var delta = 0, deltaOk = true;
  if (recon && recon.hasIntersection) {
    delta = recon.deltaIntersection;
    deltaOk = Math.abs(delta) <= STORAGE_RECONCILIATION_THRESHOLD_;
  }

  var canArchive = !hasCriticalGaps && deltaOk;

  var msg = '📊 Закрытие: ' + monthStr + '\n\n' +
    '1. ПОКРЫТИЕ:\n' +
    '   ✅ Загружено: ' + coverage.loaded.length + '\n' +
    '   ❌ Отсутствует: ' + coverage.missing.length + '\n\n' +
    '2. СВЕРКА (по пересечению):\n' +
    '   Хранение: ' + roundTwo_(coverage.totalStorage) + ' ₽\n';
  if (recon && recon.hasIntersection) {
    msg += '   Δ пересечения: ' + roundTwo_(delta) + ' ₽ ' + (deltaOk ? '✅' : '⚠️') + '\n';
  }
  msg += '\n';

  if (canArchive) {
    msg += '✅ Все проверки пройдены.\nАрхивировать?';
    if (ui.alert('📊 Закрытие', msg, ui.ButtonSet.YES_NO) === ui.Button.YES) {
      archiveWbStorageMonth(year, month, false);
    }
  } else {
    msg += '❌ Проблемы:\n';
    if (hasCriticalGaps) msg += '   — Пропущено ' + coverage.missing.length + ' дней\n';
    if (!deltaOk) msg += '   — Расхождение: ' + roundTwo_(delta) + ' ₽\n';
    msg += '\nАрхивация заблокирована.';
    ui.alert('❌ Закрытие', msg, ui.ButtonSet.OK);
  }
}

function closeStorageMonthMenu() {
  var ui = SpreadsheetApp.getUi();
  var resp = ui.prompt('📊 Закрытие', 'Месяц (YYYY-MM):', ui.ButtonSet.OK_CANCEL);
  if (resp.getSelectedButton() !== ui.Button.OK) return;
  var m = resp.getResponseText().trim();
  if (!/^\d{4}-\d{2}$/.test(m)) { ui.alert('❌', 'Формат: YYYY-MM', ui.ButtonSet.OK); return; }
  closeStorageMonth(Number(m.split('-')[0]), Number(m.split('-')[1]));
}


