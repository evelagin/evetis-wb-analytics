/**
 * 🔄 Обновить хранение WB
 *
 * Одна кнопка для ежедневной работы:
 *   1. API rolling 7 days (свежие данные)
 *   2. Drive Folder Loader (ВСЕГДА — подхватывает файлы за остальные дни)
 *   3. Сверка + покрытие
 */
function updateWbStorageData() {
  var t0 = Date.now();
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();

  console.log('═══ updateWbStorageData() СТАРТ ═══');

  // ── 1. Определить период rolling 7 days ──
  var yesterday = new Date();
  yesterday.setDate(yesterday.getDate() - 1);
  var weekAgo = new Date(yesterday);
  weekAgo.setDate(weekAgo.getDate() - 6);
  var dateFrom = Utilities.formatDate(weekAgo, 'Europe/Moscow', 'yyyy-MM-dd');
  var dateTo = Utilities.formatDate(yesterday, 'Europe/Moscow', 'yyyy-MM-dd');

  var apiResult = null;
  var driveResult = null;
  var apiOk = false;

  // ── 2. Попробовать API ──
  console.log('  Шаг 1: API rolling 7 days (' + dateFrom + ' — ' + dateTo + ')');
  apiResult = importWbStorageFromApiInternal_(dateFrom, dateTo);
  apiOk = (apiResult.status === 'OK' || apiResult.status === 'WARNING_ZERO_STORAGE_SUM');
  console.log('  API: ' + apiResult.status + ' (' + apiResult.rows_imported + ' строк, ' + apiResult.storage_sum + ' ₽)');

  // ── 3. Drive Folder Loader — ВСЕГДА запускать ──
  // API покрывает только 7 дней. Drive подхватывает файлы за остальные дни.
  // Идемпотентно: уже обработанные файлы (status=OK) пропускаются.
  console.log('  Шаг 2: Drive Folder Loader');
  driveResult = importDriveStorageInternal_();
  console.log('  Drive: ' + driveResult.status + ' (новых: ' + driveResult.newFiles +
    ', пропущено: ' + driveResult.skippedFiles + ', строк: ' + driveResult.totalRows + ')');

  // ── 4. Чистая агрегация за текущий месяц ──
  var now = new Date();
  var monthFrom = now.getFullYear() + '-' + pad2_(now.getMonth() + 1) + '-01';
  var monthTo = now.getFullYear() + '-' + pad2_(now.getMonth() + 1) + '-' + pad2_(new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate());
  var cleanMap = getCleanStorageDailyMap_(monthFrom, monthTo);

  // ── 5. Сверка по пересечению ──
  var recon = buildIntersectionReconciliation_(ss);

  // ── 6. Покрытие текущего месяца ──
  var monthStr = now.getFullYear() + '-' + pad2_(now.getMonth() + 1);
  var coverage = checkWbStorageCoverageInternal_(ss, monthStr);

  // ── 7. Последняя загрузка ──
  var logSheet = ss.getSheetByName(IMPORT_LOG_STORAGE_SHEET_NAME_);
  var lastLoadDate = '';
  if (logSheet && logSheet.getLastRow() >= 2) {
    var lastLoadedAt = logSheet.getRange(logSheet.getLastRow(), 2).getValue();
    lastLoadDate = String(lastLoadedAt || '');
  }

  // ── 8. Итоговый алерт ──
  var elapsed = sec_(t0);
  var msg = '🔄 Обновление хранения WB\n\n';

  // API
  msg += '1️⃣ API (' + dateFrom + ' — ' + dateTo + '): ';
  if (apiOk) {
    msg += '✅ ' + apiResult.status + '\n' +
      '   Строк: ' + apiResult.rows_imported + ', Сумма: ' + apiResult.storage_sum + ' ₽\n';
  } else {
    msg += '❌ ' + apiResult.status + '\n   ' + apiResult.error_message + '\n';
  }

  // Drive
  msg += '\n2️⃣ Drive Folder Loader: ';
  if (driveResult.status === 'OK' || driveResult.status === 'PARTIAL') {
    if (driveResult.newFiles > 0) {
      msg += '✅ Новых: ' + driveResult.newFiles +
        ', Строк: ' + driveResult.totalRows + ', Сумма: ' + roundTwo_(driveResult.totalSum) + ' ₽\n';
    } else {
      msg += '✅ Новых файлов нет (пропущено: ' + driveResult.skippedFiles + ')\n';
    }
  } else {
    msg += '⚠️ ' + (driveResult.error || driveResult.status) + '\n';
  }

  // Хранение за месяц
  msg += '\n── Месяц ' + monthStr + ' ──\n' +
    'Чистая сумма хранения: ' + roundTwo_(cleanMap.totalCost) + ' ₽\n' +
    'SKU: ' + cleanMap.skuCount + '\n' +
    'Уникальных записей: ' + cleanMap.rowCount + '\n';

  // Покрытие
  if (coverage) {
    msg += 'Дней загружено: ' + coverage.loaded.length + '\n';
    if (coverage.missing.length > 0) {
      msg += '⚠️ Нет данных: ' + coverage.missing.length + ' дней\n';
    }
  }

  // Сверка
  if (recon && recon.hasIntersection) {
    var deltaOk = Math.abs(recon.deltaIntersection) <= STORAGE_RECONCILIATION_THRESHOLD_;
    msg += '\n── Сверка (пересечение ' + recon.intersectionFrom + '—' + recon.intersectionTo + ') ──\n' +
      'Storage: ' + roundTwo_(recon.storageSumIntersection) + ' ₽\n' +
      'Finance: ' + roundTwo_(recon.financeSumIntersection) + ' ₽\n' +
      'Δ: ' + roundTwo_(recon.deltaIntersection) + ' ₽ ' + (deltaOk ? '✅' : '⚠️') + '\n';
    if (recon.storageDaysOutsideFinance > 0) {
      msg += '📌 ' + recon.storageDaysOutsideFinance + ' дней только в Storage (не ошибка)\n';
    }
  }

  msg += '\nПоследняя загрузка: ' + lastLoadDate + '\nВремя: ' + elapsed + ' сек';

  ui.alert('🔄 Обновление хранения WB', msg, ui.ButtonSet.OK);
}


