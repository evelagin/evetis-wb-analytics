/**
 * Сверка RAW_WB_STORAGE vs RAW_WB_FINANCE по пересечению дат.
 * Использует getCleanStorageDailyMap_() для дедупликации.
 */
function verifyStorageReconciliation() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();

  var recon = buildIntersectionReconciliation_(ss);
  if (!recon) {
    ui.alert('❌', 'Не удалось построить сверку.', ui.ButtonSet.OK); return;
  }

  var msg = '📊 Сверка хранения WB\n\n' +
    '── ПЕРИОДЫ ──\n' +
    'RAW_WB_STORAGE:  ' + recon.storageDateMin + ' — ' + recon.storageDateMax + '\n' +
    'RAW_WB_FINANCE:  ' + (recon.financeDateMin || 'нет данных') + ' — ' + (recon.financeDateMax || '') + '\n' +
    'Пересечение:     ' + (recon.intersectionFrom || 'нет') + ' — ' + (recon.intersectionTo || '') + '\n\n' +
    '── СУММЫ (дедуплицированные) ──\n' +
    'Storage (всего): ' + roundTwo_(recon.storageTotalAll) + ' ₽\n' +
    'Finance (всего): ' + roundTwo_(recon.financeTotalAll) + ' ₽\n\n';

  if (recon.hasIntersection) {
    var deltaOk = Math.abs(recon.deltaIntersection) <= STORAGE_RECONCILIATION_THRESHOLD_;
    msg += '── СВЕРКА ПО ПЕРЕСЕЧЕНИЮ ──\n' +
      'Дней: ' + recon.intersectionDays + '\n' +
      'Storage: ' + roundTwo_(recon.storageSumIntersection) + ' ₽\n' +
      'Finance: ' + roundTwo_(recon.financeSumIntersection) + ' ₽\n' +
      'Δ: ' + roundTwo_(recon.deltaIntersection) + ' ₽ ' + (deltaOk ? '✅' : '⚠️') + '\n';
    if (recon.storageDaysOutsideFinance > 0) {
      msg += '\n📌 ' + recon.storageDaysOutsideFinance + ' дней есть в Storage, но ещё нет в финансовом отчёте (не ошибка)\n';
    }
  } else {
    msg += '⚠️ Нет пересечения дат — сверка невозможна.\n';
  }

  msg += '\nSKU: ' + recon.storageSkuCount + ', записей (чистых): ' + recon.storageRowCount;
  ui.alert('📊 Сверка хранения', msg, ui.ButtonSet.OK);
}


/**
 * Сверка на чистой карте (дедуплицированной).
 *
 * @param {SpreadsheetApp.Spreadsheet} ss
 * @return {Object|null}
 */
function buildIntersectionReconciliation_(ss) {
  // ── 1. Чистая карта Storage ──
  var cleanMap = getCleanStorageDailyMap_();
  if (!cleanMap.dateMin) return null;

  var storageByDate = aggregateCleanMapByDate_(cleanMap);

  // ── 2. Finance по датам ──
  var financeByDate = {};
  var financeDateMin = null, financeDateMax = null;
  var finSheet = ss.getSheetByName('RAW_WB_FINANCE');
  if (finSheet && finSheet.getLastRow() >= 2) {
    var fHMap = getHeaderMap_(finSheet);
    var fDateCol = findCol_(fHMap, ['sale_dt', 'rr_dt', 'order_dt']);
    var fStorCol = findCol_(fHMap, ['storage_fee']);
    if (fDateCol !== -1 && fStorCol !== -1) {
      var fData = readSheetData_(finSheet);
      for (var fi = 0; fi < fData.length; fi++) {
        var fdk = normalizeDateKey_(fData[fi][fDateCol]);
        if (!fdk) continue;
        var fCost = Math.abs(Number(fData[fi][fStorCol]) || 0);
        if (fCost === 0) continue;
        if (!financeByDate[fdk]) financeByDate[fdk] = 0;
        financeByDate[fdk] += fCost;
        if (!financeDateMin || fdk < financeDateMin) financeDateMin = fdk;
        if (!financeDateMax || fdk > financeDateMax) financeDateMax = fdk;
      }
    }
  }

  // ── 3. Пересечение ──
  var storageDates = Object.keys(storageByDate).sort();
  var intersectionFrom = null, intersectionTo = null;
  if (cleanMap.dateMin && financeDateMin) {
    intersectionFrom = cleanMap.dateMin > financeDateMin ? cleanMap.dateMin : financeDateMin;
    intersectionTo = cleanMap.dateMax < financeDateMax ? cleanMap.dateMax : financeDateMax;
  }
  var hasIntersection = intersectionFrom && intersectionTo && intersectionFrom <= intersectionTo;

  // ── 4. Суммы ──
  var storageSumIntersection = 0, financeSumIntersection = 0, intersectionDays = 0;
  var storageSumOutsideFinance = 0, storageDaysOutsideFinance = 0;
  var financeTotalAll = 0;

  for (var si = 0; si < storageDates.length; si++) {
    var sd = storageDates[si];
    if (hasIntersection && sd >= intersectionFrom && sd <= intersectionTo) {
      storageSumIntersection += storageByDate[sd];
      if (financeByDate[sd]) intersectionDays++;
    }
    if (!financeByDate[sd]) {
      storageSumOutsideFinance += storageByDate[sd];
      storageDaysOutsideFinance++;
    }
  }

  var financeDates = Object.keys(financeByDate);
  for (var fdi = 0; fdi < financeDates.length; fdi++) {
    financeTotalAll += financeByDate[financeDates[fdi]];
    if (hasIntersection && financeDates[fdi] >= intersectionFrom && financeDates[fdi] <= intersectionTo) {
      financeSumIntersection += financeByDate[financeDates[fdi]];
    }
  }

  return {
    storageDateMin: cleanMap.dateMin, storageDateMax: cleanMap.dateMax,
    storageTotalAll: cleanMap.totalCost,
    financeDateMin: financeDateMin, financeDateMax: financeDateMax,
    financeTotalAll: financeTotalAll,
    intersectionFrom: intersectionFrom, intersectionTo: intersectionTo,
    hasIntersection: hasIntersection, intersectionDays: intersectionDays,
    storageSumIntersection: storageSumIntersection,
    financeSumIntersection: financeSumIntersection,
    deltaIntersection: hasIntersection ? roundTwo_(storageSumIntersection - financeSumIntersection) : 0,
    storageDaysOutsideFinance: storageDaysOutsideFinance,
    storageSumOutsideFinance: storageSumOutsideFinance,
    storageRowCount: cleanMap.rowCount,
    storageSkuCount: cleanMap.skuCount
  };
}


// ═══════════════════════════════════════════════════════════════
// ПОКРЫТИЕ
// ═══════════════════════════════════════════════════════════════

function checkWbStorageCoverage(month) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();
  if (!month || !/^\d{4}-\d{2}$/.test(month)) {
    ui.alert('❌', 'Формат: YYYY-MM', ui.ButtonSet.OK); return null;
  }
  var coverage = checkWbStorageCoverageInternal_(ss, month);
  if (!coverage) { ui.alert('❌', 'Ошибка проверки.', ui.ButtonSet.OK); return null; }

  if (coverage.missing.length > 0) writeStorageCoverageErrors_(ss, month, coverage.missing);

  var msg = '📅 Покрытие: ' + month + '\n\n' +
    '✅ Загружено: ' + coverage.loaded.length + '\n' +
    '❌ Отсутствует: ' + coverage.missing.length + '\n' +
    '⚠️ Нулевая сумма: ' + coverage.zeroCost.length + '\n' +
    'Сумма: ' + roundTwo_(coverage.totalStorage) + ' ₽\n';

  if (coverage.missing.length > 0) {
    msg += '\nПропущенные даты:\n';
    for (var i = 0; i < Math.min(coverage.missing.length, 15); i++) msg += '  ' + coverage.missing[i] + '\n';
    if (coverage.missing.length > 15) msg += '  ...и ещё ' + (coverage.missing.length - 15) + '\n';
  }
  ui.alert('📅 Покрытие', msg, ui.ButtonSet.OK);
  return coverage;
}

function checkWbStorageCoverageCurrentMonth() {
  var now = new Date();
  checkWbStorageCoverage(now.getFullYear() + '-' + pad2_(now.getMonth() + 1));
}

function checkWbStorageCoverageInternal_(ss, monthStr) {
  var parts = monthStr.split('-');
  var year = Number(parts[0]), mon = Number(parts[1]);
  var daysInMonth = new Date(year, mon, 0).getDate();
  var today = Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyy-MM-dd');

  // Используем чистую карту
  var dateFrom = monthStr + '-01';
  var dateTo = monthStr + '-' + pad2_(daysInMonth);
  var cleanMap = getCleanStorageDailyMap_(dateFrom, dateTo);
  var storageByDate = aggregateCleanMapByDate_(cleanMap);

  var loaded = [], missing = [], zeroCost = [], totalStorage = 0;

  for (var d = 1; d <= daysInMonth; d++) {
    var dk = year + '-' + pad2_(mon) + '-' + pad2_(d);
    if (dk > today) continue;
    var cost = storageByDate[dk] || 0;
    if (!storageByDate.hasOwnProperty(dk)) { missing.push(dk); }
    else if (cost === 0) { zeroCost.push(dk); }
    else { loaded.push(dk); totalStorage += cost; }
  }

  return { loaded: loaded, missing: missing, zeroCost: zeroCost,
    totalDays: daysInMonth, totalStorage: totalStorage };
}

function writeStorageCoverageErrors_(ss, month, missingDates) {
  var errSheet = ss.getSheetByName('ERRORS_CONTROL');
  if (!errSheet) return;
  var errHeaders = getHeaderMap_(errSheet);
  var lastCol = errSheet.getLastColumn(); if (lastCol < 1) return;
  var batch = [], ts = new Date();
  for (var i = 0; i < missingDates.length; i++) {
    var row = []; for (var c = 0; c < lastCol; c++) row.push('');
    setIfExists_(row, errHeaders, 'error_id', 'STORAGE_COVERAGE_' + ts.getTime() + '_' + i);
    setIfExists_(row, errHeaders, 'detected_at', ts);
    setIfExists_(row, errHeaders, 'source_sheet', 'RAW_WB_STORAGE');
    setIfExists_(row, errHeaders, 'error_type', 'STORAGE_DATE_MISSING');
    setIfExists_(row, errHeaders, 'severity', 'Проверить');
    setIfExists_(row, errHeaders, 'error_message', 'Нет данных хранения за ' + missingDates[i]);
    setIfExists_(row, errHeaders, 'message', 'Нет данных хранения за ' + missingDates[i]);
    setIfExists_(row, errHeaders, 'recommended_action', 'Загрузите через API или XLSX');
    setIfExists_(row, errHeaders, 'status', 'Новая');
    setIfExists_(row, errHeaders, 'resolved', false);
    batch.push(row);
  }
  if (batch.length > 0) errSheet.getRange(errSheet.getLastRow() + 1, 1, batch.length, lastCol).setValues(batch);
}


