function getProcessedFileIds_(logSheet) {
  var result = {};
  var lr = logSheet.getLastRow();
  if (lr<2) return result;
  var data = logSheet.getRange(2,1,lr-1,IMPORT_LOG_STORAGE_HEADERS_.length).getValues();
  for (var r=0;r<data.length;r++) {
    var fid = String(data[r][5]||'').trim();
    var st = String(data[r][13]||'').trim();
    if (fid) result[fid] = st;
  }
  return result;
}

function getProcessedTaskIds_(logSheet) {
  var result = {};
  var lr = logSheet.getLastRow();
  if (lr<2) return result;
  var data = logSheet.getRange(2,1,lr-1,IMPORT_LOG_STORAGE_HEADERS_.length).getValues();
  for (var r=0;r<data.length;r++) {
    if (String(data[r][2]||'').trim()!=='API') continue;
