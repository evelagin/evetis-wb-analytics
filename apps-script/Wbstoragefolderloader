function createImportLogStorageSheet() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheetName = IMPORT_LOG_STORAGE_SHEET_NAME_;
  var sheet = ss.getSheetByName(sheetName);
  if (sheet) {
    var eh = sheet.getRange(1,1,1,sheet.getLastColumn()).getValues()[0];
    if (String(eh[0]||'').trim()===IMPORT_LOG_STORAGE_HEADERS_[0]) {
      SpreadsheetApp.getUi().alert('✅ '+sheetName,'Лист уже существует.',SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
  } else { sheet = ss.insertSheet(sheetName); }
  var h = IMPORT_LOG_STORAGE_HEADERS_;
  if (sheet.getMaxColumns()<h.length) sheet.insertColumnsAfter(sheet.getMaxColumns(),h.length-sheet.getMaxColumns());
  sheet.getRange(1,1,1,h.length).setValues([h]);
  sheet.getRange(1,1,1,h.length).setFontWeight('bold').setBackground('#1F2937').setFontColor('#FFFFFF').setFontSize(10).setFontFamily('Arial');
  var w=[120,150,100,100,100,200,250,120,80,80,120,120,80,60,300];
  for(var i=0;i<w.length;i++) sheet.setColumnWidth(i+1,w[i]);
  sheet.setFrozenRows(1); SpreadsheetApp.flush();
  SpreadsheetApp.getUi().alert('✅ '+sheetName+' создан','Лог готов ('+h.length+' колонок).',SpreadsheetApp.getUi().ButtonSet.OK);
}


