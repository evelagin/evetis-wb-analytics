/**
 * Ищет первое совпадение среди вариантов названий колонок.
 * Возвращает индекс (0-based) или -1.
 */
function findCol_(headerMap, variants) {
  for (var i = 0; i < variants.length; i++) {
    var v = variants[i].toLowerCase();
    if (headerMap[v] !== undefined) {
      return headerMap[v];
    }
  }
  return -1;
}


/**
 * Определяет wb_nm_id для строки RAW-данных.
 * Сначала пробует прямую колонку nmId,
 * потом через vendor_code, потом через barcode.
 */
function resolveNmId_(row, nmCol, vendorCol, barcodeCol, vendorToNm, barcodeToNm) {
  if (nmCol >= 0) {
    var direct = normalizeNmId_(row[nmCol]);
    if (direct) return direct;
  }
  if (vendorCol >= 0) {
    var vc = String(row[vendorCol] || '').trim().toUpperCase();
    if (vc && vendorToNm[vc]) return vendorToNm[vc];
  }
  if (barcodeCol >= 0) {
    var bc = String(row[barcodeCol] || '').trim();
    if (bc && barcodeToNm[bc]) return barcodeToNm[bc];
  }
  return '';
}


/**
 * Парсит дату из ячейки.
 * Поддерживает: Date, YYYY-MM-DD, DD.MM.YYYY, MM/DD/YYYY, с временем.
 * Возвращает строку "YYYY-MM-DD" или ''.
 */
function parseDate_(val) {
  if (!val) return '';

  if (val instanceof Date) {
    if (isNaN(val.getTime())) return '';
    return formatDate_(val);
  }

  var s = String(val).trim();
  if (!s) return '';

  s = s.split('T')[0].split(' ')[0];

  var isoMatch = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (isoMatch) {
    return isoMatch[1] + '-' + pad2_(isoMatch[2]) + '-' + pad2_(isoMatch[3]);
  }

  var ruMatch = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (ruMatch) {
    return ruMatch[3] + '-' + pad2_(ruMatch[2]) + '-' + pad2_(ruMatch[1]);
  }

  var usMatch = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (usMatch) {
    return usMatch[3] + '-' + pad2_(usMatch[1]) + '-' + pad2_(usMatch[2]);
  }

  var d = new Date(s);
  if (!isNaN(d.getTime())) {
    return formatDate_(d);
  }

  return '';
}


/** Форматирует Date → "YYYY-MM-DD". */
function formatDate_(d) {
  return d.getFullYear() + '-' + pad2_(d.getMonth() + 1) + '-' + pad2_(d.getDate());
}


/** Ведущий ноль. */
function pad2_(n) {
  var s = String(n);
  return s.length < 2 ? '0' + s : s;
}


/** Округление до 2 знаков. */
function roundTwo_(val) {
  return Math.round((val || 0) * 100) / 100;
}


/** Секунды с момента tStart (Date.now() timestamp). */
function sec_(tStart) {
  return ((Date.now() - tStart) / 1000).toFixed(2);
}


/**
 * Создаёт массив-строку ошибки для буфера (НЕ пишет в лист).
 * Возвращает объект с данными ошибки.
 */
function makeErrorRow_(sourceSheet, sourceRow, errorType, severity, internalSku, wbNmId, message, action) {
  return {
    sourceSheet: sourceSheet,
    sourceRow: sourceRow,
    errorType: errorType,
    severity: severity,
    internalSku: internalSku,
    wbNmId: wbNmId,
    message: message,
    action: action
  };
}


/**
 * Записывает все ошибки из буфера в ERRORS_CONTROL одной пачкой.
 * Никаких appendRow() в цикле.
 */
function flushErrors_(ss, errorsBuffer) {
  if (!errorsBuffer || errorsBuffer.length === 0) return;

  var errSheet = ss.getSheetByName('ERRORS_CONTROL');
  if (!errSheet) {
    console.log('⚠️ Лист ERRORS_CONTROL не найден, ' + errorsBuffer.length + ' ошибок не записаны.');
    return;
  }

  var errHeaders = getHeaderMap_(errSheet);
  var lastCol = errSheet.getLastColumn();
  if (lastCol < 1) {
    console.log('⚠️ ERRORS_CONTROL пустой (нет заголовков), ошибки не записаны.');
    return;
  }

  var batchRows = [];
  var ts = new Date();

  for (var i = 0; i < errorsBuffer.length; i++) {
    var e = errorsBuffer[i];
    var newRow = [];
    for (var c = 0; c < lastCol; c++) {
      newRow.push('');
    }

    var errorId = CLEAN_WB_SOURCE_ + '_' + ts.getTime() + '_' + i;

    setIfExists_(newRow, errHeaders, 'error_id', errorId);
    setIfExists_(newRow, errHeaders, 'detected_at', ts);
    setIfExists_(newRow, errHeaders, 'source_sheet', e.sourceSheet);
    setIfExists_(newRow, errHeaders, 'source_row', e.sourceRow || '');
    setIfExists_(newRow, errHeaders, 'error_type', e.errorType);
    setIfExists_(newRow, errHeaders, 'severity', e.severity);
    setIfExists_(newRow, errHeaders, 'internal_sku', e.internalSku);
    setIfExists_(newRow, errHeaders, 'wb_nm_id', e.wbNmId);
    setIfExists_(newRow, errHeaders, 'error_message', e.message);
    setIfExists_(newRow, errHeaders, 'message', e.message);
    setIfExists_(newRow, errHeaders, 'recommended_action', e.action);
    setIfExists_(newRow, errHeaders, 'comment', e.action);
    setIfExists_(newRow, errHeaders, 'status', 'Новая');
    setIfExists_(newRow, errHeaders, 'resolved', false);

    batchRows.push(newRow);
  }

  // Запись пачкой
  var startRow = errSheet.getLastRow() + 1;
  errSheet.getRange(startRow, 1, batchRows.length, lastCol).setValues(batchRows);
}


/**
 * Записывает результат в UPDATE_LOG.
 * Не падает, если колонок нет — пишет в те, которые есть.
 */
function writeUpdateLog_(ss, rowsWritten, errCount, emptySheets, t0) {
  var logSheet = ss.getSheetByName('UPDATE_LOG');
  if (!logSheet) {
    console.log('⚠️ Лист UPDATE_LOG не найден.');
    return;
  }

  var logHeaders = getHeaderMap_(logSheet);
  var lastCol = logSheet.getLastColumn();
  if (lastCol < 1) {
    logSheet.appendRow([new Date(), 'RAW_TO_CLEAN', 'Готово',
      'Строк: ' + rowsWritten + ', ошибок: ' + errCount]);
    return;
  }

  var elapsed = sec_(t0);
  var status = errCount > 0 ? 'С ошибками' : 'Готово';
  var comment = 'Строк: ' + rowsWritten + ', ошибок: ' + errCount +
    ', время: ' + elapsed + ' сек';
  if (emptySheets.length > 0) {
    comment += '. Пустые: ' + emptySheets.join(', ');
  }

  var newRow = [];
  for (var c = 0; c < lastCol; c++) {
    newRow.push('');
  }

  setIfExists_(newRow, logHeaders, 'timestamp', new Date());
  setIfExists_(newRow, logHeaders, 'date', new Date());
  setIfExists_(newRow, logHeaders, 'datetime', new Date());
  setIfExists_(newRow, logHeaders, 'updated_at', new Date());

  setIfExists_(newRow, logHeaders, 'block', 'RAW_TO_CLEAN');
  setIfExists_(newRow, logHeaders, 'module', 'RAW_TO_CLEAN');
  setIfExists_(newRow, logHeaders, 'source', 'CLEAN_WB_DAILY');
  setIfExists_(newRow, logHeaders, 'action', 'buildCleanWbDaily');

  setIfExists_(newRow, logHeaders, 'status', status);
  setIfExists_(newRow, logHeaders, 'result', status);

  setIfExists_(newRow, logHeaders, 'rows_written', rowsWritten);
  setIfExists_(newRow, logHeaders, 'rows', rowsWritten);
  setIfExists_(newRow, logHeaders, 'rows_count', rowsWritten);

  setIfExists_(newRow, logHeaders, 'errors', errCount);
  setIfExists_(newRow, logHeaders, 'errors_count', errCount);

  setIfExists_(newRow, logHeaders, 'comment', comment);
  setIfExists_(newRow, logHeaders, 'message', comment);
  setIfExists_(newRow, logHeaders, 'details', comment);

  // Одна запись через appendRow — допустимо, это один вызов
  logSheet.appendRow(newRow);
}


