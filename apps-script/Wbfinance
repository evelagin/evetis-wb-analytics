function ensureFinanceColsInClean() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('CLEAN_WB_DAILY');
  if (!sheet) { console.log('❌ CLEAN_WB_DAILY не найден.'); return false; }

  var lastCol = sheet.getLastColumn();
  if (lastCol < 1) { console.log('❌ CLEAN_WB_DAILY пустой.'); return false; }

  var headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  var headerLower = headers.map(function(h) { return String(h).trim().toLowerCase(); });

  var missing = [];
  for (var i = 0; i < FINANCE_CLEAN_COLS_.length; i++) {
    if (headerLower.indexOf(FINANCE_CLEAN_COLS_[i]) === -1) {
      missing.push(FINANCE_CLEAN_COLS_[i]);
    }
  }

  if (missing.length === 0) {
    console.log('✅ Все колонки расходов уже есть в CLEAN_WB_DAILY.');
    return true;
  }

  var insertAfterIdx = headerLower.indexOf('net_revenue');
  if (insertAfterIdx === -1) {
    insertAfterIdx = headerLower.indexOf('source_status');
    if (insertAfterIdx === -1) insertAfterIdx = lastCol;
    else insertAfterIdx = insertAfterIdx - 1;
  }

  var insertCol = insertAfterIdx + 2;
  for (var mi = 0; mi < missing.length; mi++) {
    sheet.insertColumnAfter(insertCol - 1 + mi);
    sheet.getRange(1, insertCol + mi).setValue(missing[mi]);
  }

  var newHeaderRange = sheet.getRange(1, insertCol, 1, missing.length);
  newHeaderRange.setFontWeight('bold').setBackground('#1F2937').setFontColor('#FFFFFF');
  SpreadsheetApp.flush();
  console.log('✅ Добавлены колонки: ' + missing.join(', '));
  return true;
}


