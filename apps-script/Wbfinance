/**
 * getCleanMonthCabinetTotals_() — суммирует ВСЕ строки CLEAN_WB_DAILY
 * за указанный месяц, включая строки с пустым nm_id (кабинетные расходы).
 *
 * Возвращает объект: { day → {orders, sales, ..., wbAfter, cogs}, total → {...} }
 * Ключ day = число 1..31, total = итого за месяц.
 *
 * @param {Array[]} cleanData — все строки CLEAN (без заголовка)
 * @param {string} monthKey — "YYYY-MM"
 * @param {Object} colIdx — {date, nm, orders, sales, returns, netSales, grossRev, netRev,
 *                           forPay, log, stor, deduct, acc, pen, loyalty, tech, after, ads, stock}
 * @param {Object} cogsMap — {nmId → себестоимость за шт}
 * @returns {Object}
 */
function getCleanMonthCabinetTotals_(cleanData, monthKey, colIdx, cogsMap) {
  var result = {};
  var stats = { totalRows: 0, cabinetRows: 0, skuRows: 0,
    storAll: 0, deductAll: 0, storSku: 0, deductSku: 0 };

  for (var i = 0; i < cleanData.length; i++) {
    var row = cleanData[i];
    var ds = normalizeDateKey_(row[colIdx.date]);
    if (!ds) continue;
    var p = ds.split('-');
    var mk = p[0] + '-' + p[1];
    if (mk !== monthKey) continue;
    var dd = Number(p[2]);

    stats.totalRows++;
    var nm = normalizeNmIdFinance_(colIdx.nm >= 0 ? row[colIdx.nm] : '');
    var isCabinet = !nm;
    if (isCabinet) stats.cabinetRows++; else stats.skuRows++;

    var rowStor = colIdx.stor >= 0 ? (Number(row[colIdx.stor]) || 0) : 0;
    var rowDeduct = colIdx.deduct >= 0 ? (Number(row[colIdx.deduct]) || 0) : 0;
    stats.storAll += rowStor;
    stats.deductAll += rowDeduct;
    if (!isCabinet) { stats.storSku += rowStor; stats.deductSku += rowDeduct; }

    if (!result[dd]) {
      result[dd] = { orders:0, sales:0, returns:0, netSales:0, grossRev:0, netRev:0,
        forPay:0, log:0, stor:0, deduct:0, acc:0, pen:0,
        loyalty:0, tech:0, after:0, ads:0, stock:0, cogs:0 };
    }
    var d = result[dd];
    d.orders += colIdx.orders >= 0 ? (Number(row[colIdx.orders]) || 0) : 0;
    d.sales += colIdx.sales >= 0 ? (Number(row[colIdx.sales]) || 0) : 0;
    d.returns += colIdx.returns >= 0 ? (Number(row[colIdx.returns]) || 0) : 0;
    d.netSales += colIdx.netSales >= 0 ? (Number(row[colIdx.netSales]) || 0) : 0;
    d.grossRev += colIdx.grossRev >= 0 ? (Number(row[colIdx.grossRev]) || 0) : 0;
    d.netRev += colIdx.netRev >= 0 ? (Number(row[colIdx.netRev]) || 0) : 0;
    d.forPay += colIdx.forPay >= 0 ? (Number(row[colIdx.forPay]) || 0) : 0;
    d.log += colIdx.log >= 0 ? (Number(row[colIdx.log]) || 0) : 0;
    d.stor += rowStor;
    d.deduct += rowDeduct;
    d.acc += colIdx.acc >= 0 ? (Number(row[colIdx.acc]) || 0) : 0;
    d.pen += colIdx.pen >= 0 ? (Number(row[colIdx.pen]) || 0) : 0;
    d.loyalty += colIdx.loyalty >= 0 ? (Number(row[colIdx.loyalty]) || 0) : 0;
    d.tech += colIdx.tech >= 0 ? (Number(row[colIdx.tech]) || 0) : 0;
    d.after += colIdx.after >= 0 ? (Number(row[colIdx.after]) || 0) : 0;
    d.ads += colIdx.ads >= 0 ? (Number(row[colIdx.ads]) || 0) : 0;
    d.stock += colIdx.stock >= 0 ? (Number(row[colIdx.stock]) || 0) : 0;

    // Себестоимость = net_sales_qty * cogs_per_unit
    var rowNetSales = colIdx.netSales >= 0 ? (Number(row[colIdx.netSales]) || 0) : 0;
    d.cogs += rowNetSales * (nm ? (cogsMap[nm] || 0) : 0);
  }

  return { days: result, stats: stats };
}


/**
 * buildCabinetTotalBlock_() — строит блок данных ЮНИТ для "ИТОГО ПО КАБИНЕТУ"
 * напрямую из кабинетных итогов, а не из суммы товарных блоков.
 *
 * @param {Object} cabinetDays — { day → {orders, sales, ..., cogs} }
 * @param {number} daysInMonth
 * @returns {Array} блок данных (массив из UNIT_ROWS_COUNT_ объектов)
 */
function buildCabinetTotalBlock_(cabinetDays, daysInMonth) {
  var data = [];
  for (var i = 0; i < UNIT_ROWS_COUNT_; i++) data.push({});

  for (var d = 1; d <= daysInMonth; d++) {
    var dd = cabinetDays[d] || { orders:0, sales:0, returns:0, netSales:0, grossRev:0, netRev:0,
      forPay:0, log:0, stor:0, deduct:0, acc:0, pen:0, loyalty:0, tech:0, after:0, ads:0, stock:0, cogs:0 };

    var avgP = dd.netSales > 0 ? Math.round(dd.grossRev / dd.netSales) : 0;
    var drr = dd.grossRev > 0 ? dd.ads / dd.grossRev : 0;
    var cogs1 = dd.netSales > 0 ? Math.round(dd.cogs / dd.netSales) : 0;
    var profit = dd.after - dd.cogs;
    var margin = dd.after > 0 ? profit / dd.after : 0;

    var status = '';
    if (dd.grossRev === 0 && dd.ads > 0) status = 'Реклама без продаж';
    else if (profit < 0 && dd.grossRev > 0) status = 'Убыток';
    else if (drr > 0.25 && dd.grossRev > 0) status = 'Высокий ДРР';

    data[R_.ORDERS][d] = dd.orders;
    data[R_.SALES][d] = dd.sales;
    data[R_.RETURNS][d] = dd.returns;
    data[R_.NET_SALES][d] = dd.netSales;
    data[R_.AVG_PRICE][d] = avgP;
    data[R_.NET_REV][d] = roundTwo_(dd.grossRev);
    data[R_.WB_FOR_PAY][d] = roundTwo_(dd.forPay);
    data[R_.WB_LOG][d] = roundTwo_(dd.log);
    data[R_.WB_STOR][d] = roundTwo_(dd.stor);
    data[R_.WB_DEDUCT][d] = roundTwo_(dd.deduct);
    data[R_.WB_COMP][d] = roundTwo_(dd.loyalty + dd.tech);
    data[R_.WB_AFTER][d] = roundTwo_(dd.after);
    data[R_.ADS][d] = dd.ads;
    data[R_.DRR][d] = drr;
    data[R_.COGS_UNIT][d] = cogs1;
    data[R_.COGS_TOTAL][d] = roundTwo_(dd.cogs);
    data[R_.PROFIT][d] = roundTwo_(profit);
    data[R_.MARGIN][d] = margin;
    data[R_.STOCK][d] = dd.stock;
    data[R_.STATUS][d] = status;
    data[R_.COMMENT][d] = '';
  }

  // Итого
  var sumIdx = [R_.ORDERS, R_.SALES, R_.RETURNS, R_.NET_SALES, R_.NET_REV,
    R_.WB_FOR_PAY, R_.WB_LOG, R_.WB_STOR, R_.WB_DEDUCT, R_.WB_COMP, R_.WB_AFTER,
    R_.ADS, R_.COGS_TOTAL, R_.PROFIT];
  for (var si = 0; si < sumIdx.length; si++) {
    var idx = sumIdx[si], s = 0;
    for (var d = 1; d <= daysInMonth; d++) s += (data[idx][d] || 0);
    data[idx].total = roundTwo_(s);
  }
  var lastSt = 0;
  for (var d = 1; d <= daysInMonth; d++) if (data[R_.STOCK][d]) lastSt = data[R_.STOCK][d];
  data[R_.STOCK].total = lastSt;

  var tNR = data[R_.NET_REV].total || 0, tNS = data[R_.NET_SALES].total || 0;
  var tAds = data[R_.ADS].total || 0, tCT = data[R_.COGS_TOTAL].total || 0;
  var tAfter = data[R_.WB_AFTER].total || 0, tP = data[R_.PROFIT].total || 0;
  data[R_.AVG_PRICE].total = tNS > 0 ? Math.round(tNR / tNS) : 0;
  data[R_.DRR].total = tNR > 0 ? tAds / tNR : 0;
  data[R_.COGS_UNIT].total = tNS > 0 ? Math.round(tCT / tNS) : 0;
  data[R_.MARGIN].total = tAfter > 0 ? tP / tAfter : 0;

  var st = '';
  if (tNR === 0 && tAds > 0) st = 'Реклама без продаж';
  else if (tP < 0 && tNR > 0) st = 'Убыток';
  else if (tNR > 0 && tAds / tNR > 0.25) st = 'Высокий ДРР';
  data[R_.STATUS].total = st;
  data[R_.COMMENT].total = '';

  return data;
}


/**
 * Сборка данных блока с платёжной моделью WB.
 *
 * Формула прибыли (P&L):
 *   После расходов WB = wb_for_pay - логистика - хранение - удержания
 *                       - приемка - штрафы + компенсация лояльности + тех.компенсации
 *   Прибыль = После расходов WB - себестоимость продаж
 *
 * ВАЖНО: WB Продвижение и транзит доставка уже входят в удержания.
 *        Рекламу из RAW_WB_ADS НЕ вычитаем из прибыли — она уже в удержаниях.
 *        ДРР считаем для аналитики, но не для P&L.
 */
function buildBlockDataWithFinance_(monthSkuData, nmIds, daysInMonth, cogsMap, isTotal) {
  var data = [];
  for (var i = 0; i < UNIT_ROWS_COUNT_; i++) data.push({});

  for (var d = 1; d <= daysInMonth; d++) {
    var dO = 0, dS = 0, dR = 0, dNS = 0, dNR = 0, dGR = 0, dAds = 0, dSt = 0, dCogsT = 0;
    var dForPay = 0, dLog = 0, dStor = 0, dDeduct = 0, dAcc = 0, dPen = 0;
    var dLoyalty = 0, dTech = 0, dAfter = 0;

    for (var ni = 0; ni < nmIds.length; ni++) {
      var dd = (monthSkuData[nmIds[ni]] || {})[d];
      if (!dd) continue;
      dO += dd.orders; dS += dd.sales; dR += dd.returns; dNS += dd.netSales;
      dNR += dd.netRev; dGR += (dd.grossRev || dd.netRev || 0);
      dAds += dd.ads; dSt += dd.stock;
      dCogsT += dd.netSales * (cogsMap[nmIds[ni]] || 0);
      dForPay += (dd.wbForPay || 0);
      dLog += (dd.wbLog || 0);
      dStor += (dd.wbStor || 0);
      dDeduct += (dd.wbDeduct || 0);
      dAcc += (dd.wbAcc || 0);
      dPen += (dd.wbPen || 0);
      dLoyalty += (dd.wbLoyalty || 0);
      dTech += (dd.wbTech || 0);
      dAfter += (dd.wbAfter || 0);
    }

    var avgP = dNS > 0 ? Math.round(dGR / dNS) : 0;
    var drr = dGR > 0 ? dAds / dGR : 0;
    var cogs1 = isTotal ? (dNS > 0 ? Math.round(dCogsT / dNS) : 0) : (nmIds.length === 1 ? (cogsMap[nmIds[0]] || 0) : 0);

    // Прибыль = После расходов WB - Себестоимость продаж
    var profit = dAfter - dCogsT;
    // Маржинальность = Прибыль / После расходов WB
    var margin = dAfter > 0 ? profit / dAfter : 0;

    var status = '';
    if (dGR === 0 && dAds > 0) status = 'Реклама без продаж';
    else if (profit < 0 && dGR > 0) status = 'Убыток';
    else if (drr > 0.25 && dGR > 0) status = 'Высокий ДРР';
    else if (dSt === 0 && (dO > 0 || dS > 0)) status = 'Нет остатка';

    // v6: правильное заполнение строк ЮНИТ
    data[R_.ORDERS][d] = dO;
    data[R_.SALES][d] = dS;
    data[R_.RETURNS][d] = dR;
    data[R_.NET_SALES][d] = dNS;
    data[R_.AVG_PRICE][d] = avgP;
    data[R_.NET_REV][d] = roundTwo_(dGR);           // Сумма реализации WB (gross)
    data[R_.WB_FOR_PAY][d] = roundTwo_(dForPay);    // К перечислению WB за товар
    data[R_.WB_LOG][d] = roundTwo_(dLog);            // Логистика WB
    data[R_.WB_STOR][d] = roundTwo_(dStor);          // Хранение WB
    data[R_.WB_DEDUCT][d] = roundTwo_(dDeduct);      // Удержания WB
    data[R_.WB_COMP][d] = roundTwo_(dLoyalty + dTech); // Компенсации WB
    data[R_.WB_AFTER][d] = roundTwo_(dAfter);        // После расходов WB
    data[R_.ADS][d] = dAds;
    data[R_.DRR][d] = drr;
    data[R_.COGS_UNIT][d] = cogs1;
    data[R_.COGS_TOTAL][d] = roundTwo_(dCogsT);
    data[R_.PROFIT][d] = roundTwo_(profit);
    data[R_.MARGIN][d] = margin;
    data[R_.STOCK][d] = dSt;
    data[R_.STATUS][d] = status;
    data[R_.COMMENT][d] = '';
  }

  // Итого
  var sumIdx = [R_.ORDERS, R_.SALES, R_.RETURNS, R_.NET_SALES, R_.NET_REV,
    R_.WB_FOR_PAY, R_.WB_LOG, R_.WB_STOR, R_.WB_DEDUCT, R_.WB_COMP, R_.WB_AFTER,
    R_.ADS, R_.COGS_TOTAL, R_.PROFIT];
  for (var si = 0; si < sumIdx.length; si++) {
    var idx = sumIdx[si], s = 0;
    for (var d = 1; d <= daysInMonth; d++) s += (data[idx][d] || 0);
    data[idx].total = roundTwo_(s);
  }
  var lastSt = 0;
  for (var d = 1; d <= daysInMonth; d++) if (data[R_.STOCK][d]) lastSt = data[R_.STOCK][d];
  data[R_.STOCK].total = lastSt;

  var tNR = data[R_.NET_REV].total || 0, tNS = data[R_.NET_SALES].total || 0;
  var tAds = data[R_.ADS].total || 0, tCT = data[R_.COGS_TOTAL].total || 0;
  var tAfter = data[R_.WB_AFTER].total || 0, tP = data[R_.PROFIT].total || 0;
  data[R_.AVG_PRICE].total = tNS > 0 ? Math.round(tNR / tNS) : 0;
  data[R_.DRR].total = tNR > 0 ? tAds / tNR : 0;
  data[R_.COGS_UNIT].total = tNS > 0 ? Math.round(tCT / tNS) : 0;
  // Маржинальность = Прибыль / После расходов WB
  data[R_.MARGIN].total = tAfter > 0 ? tP / tAfter : 0;

  var st = '';
  if (tNR === 0 && tAds > 0) st = 'Реклама без продаж';
  else if (tP < 0 && tNR > 0) st = 'Убыток';
  else if (tNR > 0 && tAds / tNR > 0.25) st = 'Высокий ДРР';
  data[R_.STATUS].total = st;
  data[R_.COMMENT].total = '';

  return data;
}


