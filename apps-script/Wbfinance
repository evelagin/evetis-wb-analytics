/**
 * Единая нормализация даты → строка "YYYY-MM-DD".
 * Используется и в CLEAN, и в RAW_WB_FINANCE для совпадения ключей.
 *
 * Поддерживает:
 *   - Date object из Google Sheets
 *   - "2026-05-24", "2026-05-24T10:00:00"
 *   - "24.05.2026", "24.05.26"
 *   - "05/24/2026"
 *   - строки с временем
 */
function normalizeDateKey_(value) {
  if (!value) return '';

  // Date object
  if (value instanceof Date) {
    if (isNaN(value.getTime())) return '';
    return value.getFullYear() + '-' + pad2_(value.getMonth() + 1) + '-' + pad2_(value.getDate());
  }

  var s = String(value).trim();
  if (!s) return '';

  // Убираем время (после T или пробела)
  s = s.split('T')[0].split(' ')[0];

  // ISO: YYYY-MM-DD
  var isoMatch = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (isoMatch) {
    return isoMatch[1] + '-' + pad2_(isoMatch[2]) + '-' + pad2_(isoMatch[3]);
  }

  // RU: DD.MM.YYYY
  var ruMatch = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (ruMatch) {
    return ruMatch[3] + '-' + pad2_(ruMatch[2]) + '-' + pad2_(ruMatch[1]);
  }

  // RU short: DD.MM.YY
  var ruShort = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{2})$/);
  if (ruShort) {
    var yr = Number(ruShort[3]);
    var fullYear = yr >= 70 ? 1900 + yr : 2000 + yr;
    return fullYear + '-' + pad2_(ruShort[2]) + '-' + pad2_(ruShort[1]);
  }

  // US: MM/DD/YYYY
  var usMatch = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (usMatch) {
    return usMatch[3] + '-' + pad2_(usMatch[1]) + '-' + pad2_(usMatch[2]);
  }

  // Fallback: попробовать new Date()
  var d = new Date(s);
  if (!isNaN(d.getTime())) {
    return d.getFullYear() + '-' + pad2_(d.getMonth() + 1) + '-' + pad2_(d.getDate());
  }

  return '';
}


