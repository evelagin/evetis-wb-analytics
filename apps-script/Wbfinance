  var opTypeSummary = {};

  // ── Цикл по строкам ──
  for (var i = 0; i < fData.length; i++) {
    var row = fData[i];

    var dateStr = normalizeDateKey_(row[fDateCol]);
    if (!dateStr) { stats.errors++; continue; }

    var nmId = normalizeNmIdFinance_(fNmCol >= 0 ? row[fNmCol] : null);
    if (!nmId) nmId = resolveNmId_(row, fNmCol, fVendorCol, fBarcodeCol, vendorToNm, barcodeToNm);
