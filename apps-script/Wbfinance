    var key = dateStr + '|' + nmId;

    var docType = fDocTypeCol >= 0 ? String(row[fDocTypeCol] || '').trim() : '';
    var opType  = fOpTypeCol >= 0 ? String(row[fOpTypeCol] || '').trim() : '';
    var qty       = fQtyCol >= 0 ? (Number(row[fQtyCol]) || 0) : 0;
    var retailAmt = fRetailCol >= 0 ? (Number(row[fRetailCol]) || 0) : 0;
    var forPay    = fForPayCol >= 0 ? (Number(row[fForPayCol]) || 0) : 0;
    var logAmt    = fLogCol >= 0 ? (Number(row[fLogCol]) || 0) : 0;
    var storAmt   = fStorCol >= 0 ? (Number(row[fStorCol]) || 0) : 0;
    var deductAmt = fDeductCol >= 0 ? (Number(row[fDeductCol]) || 0) : 0;
    var accAmt    = fAccCol >= 0 ? (Number(row[fAccCol]) || 0) : 0;
    var rebillAmt = fRebillCol >= 0 ? (Number(row[fRebillCol]) || 0) : 0;
    var penAmt    = fPenCol >= 0 ? (Number(row[fPenCol]) || 0) : 0;
    var acqAmt    = fAcqCol >= 0 ? (Number(row[fAcqCol]) || 0) : 0;

    // ── Диагностическая сводка ──
    var opKey = (docType || '(пусто)') + ' | ' + (opType || '(пусто)');
    if (!opTypeSummary[opKey]) {
      opTypeSummary[opKey] = { count: 0, qty: 0, retail: 0, forPay: 0,
        log: 0, stor: 0, deduct: 0, acc: 0, pen: 0, acq: 0 };
    }
    var os = opTypeSummary[opKey];
    os.count++;
    os.qty += qty;
    os.retail += retailAmt;
    os.forPay += forPay;
    os.log += logAmt;
    os.stor += storAmt;
    os.deduct += deductAmt;
    os.acc += accAmt;
    os.pen += penAmt;
    os.acq += acqAmt;

    // ── Классификация строки ──
    var dtLow = docType.toLowerCase();
    var opLow = opType.toLowerCase();

    // Продажа товара: СТРОГО doc_type="Продажа" И supplier_oper_name="Продажа" И qty > 0
    var isSaleOfGoods = (dtLow === 'продажа' && opLow === 'продажа' && qty > 0);

    // Возврат товара: doc_type="Возврат" ИЛИ supplier_oper_name="Возврат"
    // НО НЕ "Возмещение за выдачу и возврат товаров на ПВЗ"
    var isReturnOfGoods = false;
    if (dtLow === 'возврат' && opLow.indexOf('возмещение') === -1) {
      isReturnOfGoods = true;
    }

    if (isSaleOfGoods) {
      fSalesMap[key] = (fSalesMap[key] || 0) + qty;
      fGrossRevMap[key] = (fGrossRevMap[key] || 0) + Math.abs(retailAmt);
      stats.salesRows++;
    } else if (isReturnOfGoods) {
      fReturnsMap[key] = (fReturnsMap[key] || 0) + (Math.abs(qty) || 1);
      fRetAmtMap[key] = (fRetAmtMap[key] || 0) + Math.abs(retailAmt);
      stats.returnRows++;
    } else {
      stats.otherRows++;
    }

    // ── Агрегация финансовых сумм ПО КАЖДОЙ СТРОКЕ (не только для расходов) ──
    // Все суммы берём как есть, со знаком — знак важен для корректных итогов

    // К перечислению продавцу
    if (forPay !== 0) fForPayMap[key] = (fForPayMap[key] || 0) + forPay;

    // Логистика (обычно отрицательная в отчёте, берём abs)
    if (logAmt !== 0) fLogisticsMap[key] = (fLogisticsMap[key] || 0) + Math.abs(logAmt);

    // Хранение
    if (storAmt !== 0) fStorageMap[key] = (fStorageMap[key] || 0) + Math.abs(storAmt);

    // Удержания
    if (deductAmt !== 0) fDeductionMap[key] = (fDeductionMap[key] || 0) + Math.abs(deductAmt);

    // Приемка
    if (accAmt !== 0) fAcceptanceMap[key] = (fAcceptanceMap[key] || 0) + Math.abs(accAmt);

    // Штрафы
    if (penAmt !== 0) fPenaltyMap[key] = (fPenaltyMap[key] || 0) + Math.abs(penAmt);

    // Эквайринг / компенсация платёжных услуг
    if (acqAmt !== 0) fAcquiringMap[key] = (fAcquiringMap[key] || 0) + Math.abs(acqAmt);

    // Rebill-логистика: отдельно от обычной логистики
    if (rebillAmt !== 0) fRebillMap[key] = (fRebillMap[key] || 0) + Math.abs(rebillAmt);

    // Расшифровка удержаний и компенсаций по supplier_oper_name
    if (opLow.indexOf('продвижен') >= 0 || opLow.indexOf('реклам') >= 0) {
      var promoAmt = Math.abs(deductAmt || 0);
      if (promoAmt > 0) fPromotionMap[key] = (fPromotionMap[key] || 0) + promoAmt;
    }
    if (opLow.indexOf('транзит') >= 0) {
      var transitAmt = Math.abs(logAmt || deductAmt || 0);
      if (transitAmt > 0) fTransitMap[key] = (fTransitMap[key] || 0) + transitAmt;
    }
    if (opLow.indexOf('компенсация скидки') >= 0 || opLow.indexOf('лояльност') >= 0) {
      // Компенсация скидки — это ПРИХОД продавцу.
      // v7: В RAW после патча: compensation_amount содержит сумму лояльности.
      // Фолбэк: additional_payment, forPay, retailAmt.
      var compAmtL = fCompCol >= 0 ? (Number(row[fCompCol]) || 0) : 0;
      var addPayAmtL = fAddPayCol >= 0 ? (Number(row[fAddPayCol]) || 0) : 0;
      var loyaltyAmt = compAmtL || addPayAmtL || forPay || retailAmt || 0;
      if (loyaltyAmt !== 0) fLoyaltyMap[key] = (fLoyaltyMap[key] || 0) + Math.abs(loyaltyAmt);
    }
    if (opLow.indexOf('возмещение издержек') >= 0 || opLow.indexOf('техническ') >= 0 ||
        opLow.indexOf('возмещение за выдачу') >= 0) {
      // v7: В RAW после патча: additional_payment содержит ЧИСТЫЙ эффект строки
      // (возмещение + вознаграждение WB + НДС с вознаграждения).
      // Это уже net-сумма, знак правильный. Берём как есть (положительный = приход).
      var addPayAmtT = fAddPayCol >= 0 ? (Number(row[fAddPayCol]) || 0) : 0;
      var compAmtT = fCompCol >= 0 ? (Number(row[fCompCol]) || 0) : 0;
      var techAmt = addPayAmtT || compAmtT || forPay || 0;
      // Не берём abs — net может быть и положительным и отрицательным
      if (techAmt !== 0) fTechCompMap[key] = (fTechCompMap[key] || 0) + techAmt;
    }
  }

  stats.aggregatedKeys = Object.keys(fForPayMap).length;

  // ── Вывод диагностической сводки ──
  console.log('══ СВОДКА ПО ТИПАМ ОПЕРАЦИЙ RAW_WB_FINANCE ══');
  var opKeys = Object.keys(opTypeSummary).sort(function(a, b) {
    return opTypeSummary[b].count - opTypeSummary[a].count;
  });
  for (var oki = 0; oki < opKeys.length; oki++) {
    var o = opTypeSummary[opKeys[oki]];
    console.log('  ' + opKeys[oki] + ': ' + o.count + ' строк, qty=' + o.qty +
      ', retail=' + roundTwo_(o.retail) + ', forPay=' + roundTwo_(o.forPay) +
      ', log=' + roundTwo_(o.log) + ', stor=' + roundTwo_(o.stor) +
      ', deduct=' + roundTwo_(o.deduct) + ', pen=' + roundTwo_(o.pen) +
      ', acq=' + roundTwo_(o.acq));
  }

  // ── Глобальные итоги ──
  var totalRetail = 0, totalForPay = 0, totalLog = 0, totalStor = 0;
  var totalDeduct = 0, totalAcc = 0, totalPen = 0, totalAcq = 0;
  var totalLoyalty = 0, totalTech = 0, totalPromo = 0, totalTransit = 0;
  var allFinKeys = {};
  var finMaps = [fForPayMap, fLogisticsMap, fStorageMap, fDeductionMap, fSalesMap, fReturnsMap];
  for (var fm = 0; fm < finMaps.length; fm++) {
    var fmk = Object.keys(finMaps[fm]);
    for (var fmi = 0; fmi < fmk.length; fmi++) allFinKeys[fmk[fmi]] = true;
  }
  var afk = Object.keys(allFinKeys);
  for (var ai = 0; ai < afk.length; ai++) {
    var ak = afk[ai];
    totalForPay += (fForPayMap[ak] || 0);
    totalLog += (fLogisticsMap[ak] || 0);
    totalStor += (fStorageMap[ak] || 0);
    totalDeduct += (fDeductionMap[ak] || 0);
    totalAcc += (fAcceptanceMap[ak] || 0);
    totalPen += (fPenaltyMap[ak] || 0);
    totalAcq += (fAcquiringMap[ak] || 0);
    totalLoyalty += (fLoyaltyMap[ak] || 0);
    totalTech += (fTechCompMap[ak] || 0);
    totalPromo += (fPromotionMap[ak] || 0);
    totalTransit += (fTransitMap[ak] || 0);
    totalRetail += (fGrossRevMap[ak] || 0);
  }

  console.log('══ ИТОГИ RAW_WB_FINANCE ══');
  console.log('  Сумма реализации WB:        ' + roundTwo_(totalRetail));
  console.log('  К перечислению продавцу:     ' + roundTwo_(totalForPay));
  console.log('  Логистика WB:                ' + roundTwo_(totalLog));
  console.log('  Хранение:                    ' + roundTwo_(totalStor));
  console.log('  Удержания:                   ' + roundTwo_(totalDeduct));
  console.log('    в т.ч. WB Продвижение:     ' + roundTwo_(totalPromo));
  console.log('    в т.ч. Транзит доставка:   ' + roundTwo_(totalTransit));
  console.log('  Приемка:                     ' + roundTwo_(totalAcc));
  console.log('  Штрафы:                      ' + roundTwo_(totalPen));
  console.log('  Эквайринг:                   ' + roundTwo_(totalAcq));
  console.log('  Компенсация лояльности:      ' + roundTwo_(totalLoyalty));
  console.log('  Технические компенсации:     ' + roundTwo_(totalTech));

  var afterExpenses = totalForPay - totalLog - totalStor - totalDeduct
    - totalAcc - totalPen + totalLoyalty + totalTech;
  console.log('  ──────────────────────────────');
  console.log('  После расходов WB:           ' + roundTwo_(afterExpenses));

  console.log('📊 Продаж: ' + stats.salesRows + ', возвратов: ' + stats.returnRows +
    ', прочих: ' + stats.otherRows + ', ошибок: ' + stats.errors);
  console.log('✅ readAndAggregateFinance_() v3.0: ' + stats.rawRows + ' строк, ' + sec_(t0) + ' сек');

  return {
    salesMap: fSalesMap, returnsMap: fReturnsMap,
    grossRevMap: fGrossRevMap, retAmtMap: fRetAmtMap,
    forPayMap: fForPayMap, logisticsMap: fLogisticsMap,
    storageMap: fStorageMap, deductionMap: fDeductionMap,
    acceptanceMap: fAcceptanceMap, penaltyMap: fPenaltyMap,
    loyaltyMap: fLoyaltyMap, techCompMap: fTechCompMap,
    promotionMap: fPromotionMap, transitMap: fTransitMap, acquiringMap: fAcquiringMap, rebillMap: fRebillMap,
    stats: stats, errorsBuffer: errorsBuffer
  };
}


// ═══════════════════════════════════════
// ГЛАВНАЯ: buildCleanWbDailyWithFinance()
// ═══════════════════════════════════════

function buildCleanWbDailyWithFinance() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var t0 = Date.now();
  var errorsBuffer = [];
  var emptySheets = [];

  console.log('═══ buildCleanWbDailyWithFinance() v1.1 СТАРТ ═══');

  // ── Обеспечиваем структуру ──
  ensureFinanceColsInClean();

  clearErrorsBySource(CLEAN_WB_SOURCE_);
  clearErrorsBySource(FINANCE_SOURCE_);

  // ══════════════════════════════════════
  // 1. SKU_MASTER
  // ══════════════════════════════════════

  var tStep = Date.now();
  var masterSheet = ss.getSheetByName('SKU_MASTER');
  if (!masterSheet) {
    errorsBuffer.push(makeErrorRow_('SKU_MASTER', 0, 'Не найден лист', 'Критично', '', '',
      'SKU_MASTER не найден.', 'Создать лист'));
    flushErrors_(ss, errorsBuffer);
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'Лист SKU_MASTER не найден.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var mHeaders = getHeaderMap_(masterSheet);
  var mNmCol = findCol_(mHeaders, ['wb_nm_id', 'nm_id', 'nmid', 'nmid_wb', 'nm_id_wb']);
  if (mNmCol === -1) {
    errorsBuffer.push(makeErrorRow_('SKU_MASTER', 1, 'Не найдена колонка', 'Критично', '', '',
      'wb_nm_id не найден.', 'Добавить колонку'));
    flushErrors_(ss, errorsBuffer);
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'В SKU_MASTER нет wb_nm_id.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var mNameCol = findCol_(mHeaders, ['product_name_short', 'product_name', 'name', 'product']);
  var mSkuCol = findCol_(mHeaders, ['internal_sku']);
  var mVendorCol = findCol_(mHeaders, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
  var mBarcodeCol = findCol_(mHeaders, ['barcode', 'barcodes']);

  var masterData = readSheetData_(masterSheet);
  var skuLookup = {}, vendorToNm = {}, barcodeToNm = {};

  for (var i = 0; i < masterData.length; i++) {
    var row = masterData[i];
    var nmId = normalizeNmIdFinance_(row[mNmCol]);
    if (!nmId) continue;
    var info = {
      product_name: mNameCol >= 0 ? String(row[mNameCol] || '') : '',
      internal_sku: mSkuCol >= 0 ? String(row[mSkuCol] || '') : '',
      vendor_code: mVendorCol >= 0 ? String(row[mVendorCol] || '') : '',
      barcode: mBarcodeCol >= 0 ? String(row[mBarcodeCol] || '') : ''
    };
    skuLookup[nmId] = info;
    if (info.vendor_code) vendorToNm[info.vendor_code.trim().toUpperCase()] = nmId;
    if (info.barcode) barcodeToNm[String(info.barcode).trim()] = nmId;
  }
  console.log('✅ SKU_MASTER: ' + Object.keys(skuLookup).length + ' товаров, ' + sec_(tStep) + ' сек');

  // ══════════════════════════════════════
  // 2. RAW_WB_ORDERS
  // ══════════════════════════════════════

  tStep = Date.now();
  var ordersMap = {};
  var ordersSheet = ss.getSheetByName('RAW_WB_ORDERS');
  if (!ordersSheet || ordersSheet.getLastRow() < 2) {
    emptySheets.push('RAW_WB_ORDERS');
  } else {
    var oH = getHeaderMap_(ordersSheet);
    var oDateCol = findCol_(oH, ['order_dt', 'date', 'order_date', 'lastchangedate']);
    var oNmCol = findCol_(oH, ['wb_nm_id', 'nmid', 'nm_id']);
    var oVendorCol = findCol_(oH, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
    var oBarcodeCol = findCol_(oH, ['barcode', 'barcodes']);
    var oQtyCol = findCol_(oH, ['quantity', 'qty', 'orders_qty']);
    if (oDateCol >= 0) {
      var oData = readSheetData_(ordersSheet);
      for (var oi = 0; oi < oData.length; oi++) {
        var oRow = oData[oi];
        var oDate = normalizeDateKey_(oRow[oDateCol]);
        if (!oDate) continue;
        var oNmId = resolveNmId_(oRow, oNmCol, oVendorCol, oBarcodeCol, vendorToNm, barcodeToNm);
        if (!oNmId) continue;
        oNmId = normalizeNmIdFinance_(oNmId);
        if (!oNmId) continue;
        var key = oDate + '|' + oNmId;
        var qty = oQtyCol >= 0 ? Math.abs(Number(oRow[oQtyCol]) || 0) : 1;
        ordersMap[key] = (ordersMap[key] || 0) + qty;
      }
      console.log('✅ RAW_WB_ORDERS: ' + oData.length + ' строк, ' + Object.keys(ordersMap).length + ' ключей');
    } else {
      emptySheets.push('RAW_WB_ORDERS (нет даты)');
    }
  }

  // ══════════════════════════════════════
  // 3. RAW_WB_SALES_RETURNS
  // ══════════════════════════════════════

  tStep = Date.now();
  var salesMap = {}, returnsMap = {}, grossRevMap = {}, retAmtMap = {};
  var srSheet = ss.getSheetByName('RAW_WB_SALES_RETURNS');
  if (!srSheet || srSheet.getLastRow() < 2) {
    emptySheets.push('RAW_WB_SALES_RETURNS');
  } else {
    var srH = getHeaderMap_(srSheet);
    var srDateCol = findCol_(srH, ['sale_dt', 'date', 'sale_date', 'last_change_date', 'lastchangedate', 'rr_dt']);
    var srNmCol = findCol_(srH, ['wb_nm_id', 'nmid', 'nm_id']);
    var srVendorCol = findCol_(srH, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
    var srBarcodeCol = findCol_(srH, ['barcode', 'barcodes']);
    var srQtyCol = findCol_(srH, ['quantity', 'qty']);
    var srAmountCol = findCol_(srH, ['finished_price', 'finishedprice', 'pricewithdisc', 'price_with_disc',
      'retail_amount', 'for_pay', 'forpay', 'ppvz_for_pay', 'amount']);
    var srTypeCol = findCol_(srH, ['operation_type', 'supplier_oper_name', 'type']);
    if (srDateCol >= 0) {
      var srData = readSheetData_(srSheet);
      for (var si = 0; si < srData.length; si++) {
        var srRow = srData[si];
        var srDate = normalizeDateKey_(srRow[srDateCol]);
        if (!srDate) continue;
        var srNmId = resolveNmId_(srRow, srNmCol, srVendorCol, srBarcodeCol, vendorToNm, barcodeToNm);
        if (!srNmId) continue;
        srNmId = normalizeNmIdFinance_(srNmId);
        if (!srNmId) continue;
        var sKey = srDate + '|' + srNmId;
        var rawQty = srQtyCol >= 0 ? Number(srRow[srQtyCol]) : 0;
        var rawAmt = srAmountCol >= 0 ? Number(srRow[srAmountCol]) : 0;
        var isReturn = false;
        if (srTypeCol >= 0) {
          var tv = String(srRow[srTypeCol] || '').toLowerCase();
          if (tv.indexOf('возврат') >= 0 || tv.indexOf('return') >= 0) isReturn = true;
        }
        if (!isReturn && (rawQty < 0 || rawAmt < 0)) isReturn = true;
        var absQty = Math.abs(rawQty) || 1;
        var absAmt = Math.abs(rawAmt) || 0;
        if (isReturn) {
          returnsMap[sKey] = (returnsMap[sKey] || 0) + absQty;
          retAmtMap[sKey] = (retAmtMap[sKey] || 0) + absAmt;
        } else {
          salesMap[sKey] = (salesMap[sKey] || 0) + absQty;
          grossRevMap[sKey] = (grossRevMap[sKey] || 0) + absAmt;
        }
      }
      console.log('✅ RAW_WB_SALES_RETURNS: ' + srData.length + ' строк');
    } else {
      emptySheets.push('RAW_WB_SALES_RETURNS (нет даты)');
    }
  }

  // ══════════════════════════════════════
  // 4. RAW_WB_ADS
  // ══════════════════════════════════════

  tStep = Date.now();
  var adsMap = {};
  var adsSheet = ss.getSheetByName('RAW_WB_ADS');
  if (!adsSheet || adsSheet.getLastRow() < 2) {
    emptySheets.push('RAW_WB_ADS');
  } else {
    var aH = getHeaderMap_(adsSheet);
    var aDateCol = findCol_(aH, ['stat_date', 'date', 'advert_date', 'day']);
    var aNmCol = findCol_(aH, ['wb_nm_id', 'nmid', 'nm_id']);
    var aVendorCol = findCol_(aH, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
    var aBarcodeCol = findCol_(aH, ['barcode', 'barcodes']);
    var aSpendCol = findCol_(aH, ['spend', 'sum', 'advert_spend', 'cost', 'expense', 'expenses']);
    if (aDateCol >= 0 && aSpendCol >= 0) {
      var aData = readSheetData_(adsSheet);
      for (var ai = 0; ai < aData.length; ai++) {
        var aRow = aData[ai];
        var aDate = normalizeDateKey_(aRow[aDateCol]);
        if (!aDate) continue;
        var aNmId = resolveNmId_(aRow, aNmCol, aVendorCol, aBarcodeCol, vendorToNm, barcodeToNm);
        if (!aNmId) continue;
        aNmId = normalizeNmIdFinance_(aNmId);
        if (!aNmId) continue;
        var aKey = aDate + '|' + aNmId;
        adsMap[aKey] = (adsMap[aKey] || 0) + Math.abs(Number(aRow[aSpendCol]) || 0);
      }
      console.log('✅ RAW_WB_ADS: ' + aData.length + ' строк, ' + Object.keys(adsMap).length + ' ключей');
    } else {
      emptySheets.push('RAW_WB_ADS (нет колонок)');
    }
  }

  // ══════════════════════════════════════
  // 5. RAW_WB_STOCKS
  // ══════════════════════════════════════

  tStep = Date.now();
  var stocksMap = {};
  var stockSheet = ss.getSheetByName('RAW_WB_STOCKS');
  if (!stockSheet || stockSheet.getLastRow() < 2) {
    emptySheets.push('RAW_WB_STOCKS');
  } else {
    var stH = getHeaderMap_(stockSheet);
    var stDateCol = findCol_(stH, ['snapshot_date', 'date', 'stock_date', 'lastchangedate']);
    var stNmCol = findCol_(stH, ['wb_nm_id', 'nmid', 'nm_id']);
    var stVendorCol = findCol_(stH, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
    var stBarcodeCol = findCol_(stH, ['barcode', 'barcodes']);
    var stQtyCol = findCol_(stH, ['quantity_total', 'quantity', 'quantityfull', 'stock_qty', 'qty', 'stocks']);
    if (stQtyCol >= 0) {
      var stData = readSheetData_(stockSheet);
      var today = normalizeDateKey_(new Date());
      for (var sti = 0; sti < stData.length; sti++) {
        var stRow = stData[sti];
        var stDate = stDateCol >= 0 ? normalizeDateKey_(stRow[stDateCol]) : '';
        if (!stDate) stDate = today;
        var stNmId = resolveNmId_(stRow, stNmCol, stVendorCol, stBarcodeCol, vendorToNm, barcodeToNm);
        if (!stNmId) continue;
        stNmId = normalizeNmIdFinance_(stNmId);
        if (!stNmId) continue;
        var stKey = stDate + '|' + stNmId;
        stocksMap[stKey] = (stocksMap[stKey] || 0) + (Number(stRow[stQtyCol]) || 0);
      }
      console.log('✅ RAW_WB_STOCKS: ' + stData.length + ' строк, ' + Object.keys(stocksMap).length + ' ключей');
    } else {
      emptySheets.push('RAW_WB_STOCKS (нет колонки)');
    }
  }

  // ══════════════════════════════════════
  // 6. RAW_WB_FINANCE
  // ══════════════════════════════════════

  var finResult = readAndAggregateFinance_(ss, skuLookup, vendorToNm, barcodeToNm);
  var finStats = finResult.stats;
  for (var fe = 0; fe < finResult.errorsBuffer.length; fe++) {
    errorsBuffer.push(finResult.errorsBuffer[fe]);
  }

  // ══════════════════════════════════════
  // 6b. ВЫБОР ИСТОЧНИКА ПРОДАЖ/ВОЗВРАТОВ/ВЫРУЧКИ
  // Приоритет: RAW_WB_FINANCE (финансовый отчёт WB = источник истины)
  // Фолбэк:   RAW_WB_SALES_RETURNS (только если в RAW_WB_FINANCE нет продаж)
  // ══════════════════════════════════════

  var salesSource = '';
  var hasSalesFromFin = Object.keys(finResult.salesMap || {}).length > 0;
  var hasSalesFromRaw = Object.keys(salesMap).length > 0;

  if (hasSalesFromFin) {
    salesMap = finResult.salesMap;
    returnsMap = finResult.returnsMap;
    grossRevMap = finResult.grossRevMap;
    retAmtMap = finResult.retAmtMap;
    salesSource = 'RAW_WB_FINANCE';
    console.log('📊 Источник продаж/возвратов: RAW_WB_FINANCE');
    console.log('  Продаж из источника: ' + finStats.salesRows);
    console.log('  Возвратов из источника: ' + finStats.returnRows);
  } else if (hasSalesFromRaw) {
    salesSource = 'RAW_WB_SALES_RETURNS (фолбэк)';
    console.log('📊 Источник: RAW_WB_SALES_RETURNS (фолбэк)');
  } else {
    salesSource = 'НЕТ ДАННЫХ';
    console.log('⚠️ Нет данных о продажах');
  }

  // ══════════════════════════════════════
  // 7. СБОРКА ИТОГОВОГО МАССИВА
  // ══════════════════════════════════════

  tStep = Date.now();

  var allKeys = {};
  var maps = [ordersMap, salesMap, returnsMap, grossRevMap, retAmtMap, adsMap, stocksMap,
              finResult.forPayMap || {}, finResult.logisticsMap || {},
              finResult.storageMap || {}, finResult.deductionMap || {}];
  for (var mi = 0; mi < maps.length; mi++) {
    var mk2 = Object.keys(maps[mi]);
    for (var mk3 = 0; mk3 < mk2.length; mk3++) allKeys[mk2[mk3]] = true;
  }

  var keyList = Object.keys(allKeys);
  keyList.sort();

  var CLEAN_HEADERS_FULL_ = [
    'date', 'wb_nm_id', 'product_name', 'internal_sku',
    'orders_qty', 'sales_qty', 'returns_qty', 'net_sales_qty',
    'gross_revenue', 'returns_amount', 'net_revenue',
    'wb_for_pay', 'wb_logistics', 'wb_storage',
    'wb_deductions', 'wb_acceptance', 'wb_penalties', 'wb_acquiring',
    'wb_loyalty_comp', 'wb_tech_comp', 'wb_after_expenses',
    'wb_rebill_logistics',
    'ads_spend', 'stock_qty', 'source_status', 'updated_at'
  ];

  var now = new Date();
  var resultRows = [];
  var uniqueDates = {}, uniqueNm = {};

  for (var ki = 0; ki < keyList.length; ki++) {
    var k = keyList[ki];
    var parts = k.split('|');
    var kDate = parts[0];
    var kNmId = parts[1];

    uniqueDates[kDate] = true;
    uniqueNm[kNmId] = true;

    var nfo = skuLookup[kNmId] || {};
    var salesQty = salesMap[k] || 0;
    var returnsQty = returnsMap[k] || 0;
    var grossRev = grossRevMap[k] || 0;
    var retAmt = retAmtMap[k] || 0;
    var sourceStatus = skuLookup[kNmId] ? 'OK' : 'Нет SKU_MASTER';

    var wbForPay    = finResult.forPayMap[k] || 0;
    var wbLog       = finResult.logisticsMap[k] || 0;
    var wbStor      = finResult.storageMap[k] || 0;
    var wbDeduct    = finResult.deductionMap[k] || 0;
    var wbAcc       = finResult.acceptanceMap[k] || 0;
    var wbPen       = finResult.penaltyMap[k] || 0;
    var wbAcq       = finResult.acquiringMap[k] || 0;
    var wbRebill  = finResult.rebillMap[k] || 0;
    var wbLoyalty   = finResult.loyaltyMap[k] || 0;
    var wbTech      = finResult.techCompMap[k] || 0;

    // Формула: после расходов WB
    var wbAfter = wbForPay - wbLog - wbStor - wbDeduct - wbAcc - wbPen + wbLoyalty + wbTech;

    resultRows.push([
      kDate,
      kNmId,
      nfo.product_name || '',
      nfo.internal_sku || '',
      ordersMap[k] || 0,
      salesQty,
      returnsQty,
      salesQty - returnsQty,
      roundTwo_(grossRev),
      roundTwo_(retAmt),
      roundTwo_(grossRev - retAmt),
      roundTwo_(wbForPay),
      roundTwo_(wbLog),
      roundTwo_(wbStor),
      roundTwo_(wbDeduct),
      roundTwo_(wbAcc),
      roundTwo_(wbPen),
      roundTwo_(wbAcq),
      roundTwo_(wbLoyalty),
      roundTwo_(wbTech),
      roundTwo_(wbAfter),
      roundTwo_(wbRebill),
      roundTwo_(adsMap[k] || 0),
      stocksMap[k] || 0,
      sourceStatus,
      now
    ]);
  }

  var datesCount = Object.keys(uniqueDates).length;
  var nmCount = Object.keys(uniqueNm).length;
  console.log('✅ Сборка: ' + resultRows.length + ' строк, ' + datesCount + ' дат, ' + nmCount + ' SKU');

  // Диагностика: первая строка с ненулевыми расходами
  for (var di2 = 0; di2 < resultRows.length; di2++) {
    if (resultRows[di2][11] > 0 || resultRows[di2][12] > 0 || resultRows[di2][13] > 0) {
      console.log('💰 Пример строки с расходами: date=' + resultRows[di2][0] +
        ', nm=' + resultRows[di2][1] +
        ', comm=' + resultRows[di2][11] + ', log=' + resultRows[di2][12] +
        ', stor=' + resultRows[di2][13] + ', acq=' + resultRows[di2][15]);
      break;
    }
  }

  // ══════════════════════════════════════
  // 8. ЗАПИСЬ CLEAN_WB_DAILY
  // ══════════════════════════════════════

  tStep = Date.now();
  var cleanSheet = ss.getSheetByName('CLEAN_WB_DAILY');
  if (!cleanSheet) {
    errorsBuffer.push(makeErrorRow_('CLEAN_WB_DAILY', 0, 'Не найден лист', 'Критично', '', '',
      'CLEAN_WB_DAILY не найден.', 'Создать лист'));
    flushErrors_(ss, errorsBuffer);
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'CLEAN_WB_DAILY не найден.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  // Гарантируем нужное число колонок
  var maxCols = cleanSheet.getMaxColumns();
  if (maxCols < CLEAN_HEADERS_FULL_.length) {
    cleanSheet.insertColumnsAfter(maxCols, CLEAN_HEADERS_FULL_.length - maxCols);
  }
  // Перезаписываем заголовки
  cleanSheet.getRange(1, 1, 1, CLEAN_HEADERS_FULL_.length).setValues([CLEAN_HEADERS_FULL_]);
  // Удаляем лишние колонки
  var nowMaxCols = cleanSheet.getMaxColumns();
  if (nowMaxCols > CLEAN_HEADERS_FULL_.length) {
    cleanSheet.deleteColumns(CLEAN_HEADERS_FULL_.length + 1, nowMaxCols - CLEAN_HEADERS_FULL_.length);
  }

  // Очистка данных
  var cleanLastRow = cleanSheet.getLastRow();
  if (cleanLastRow >= 2) {
    cleanSheet.getRange(2, 1, cleanLastRow - 1, CLEAN_HEADERS_FULL_.length).clearContent();
  }

  // Запись
  if (resultRows.length > 0) {
    cleanSheet.getRange(2, 1, resultRows.length, CLEAN_HEADERS_FULL_.length).setValues(resultRows);
  }
  SpreadsheetApp.flush();
  console.log('✅ Запись CLEAN_WB_DAILY: ' + resultRows.length + ' строк, ' + sec_(tStep) + ' сек');

  // ── Контрольные суммы CLEAN_WB_DAILY ──
  var ctrlSales = 0, ctrlReturns = 0, ctrlNetSales = 0;
  var ctrlGrossRev = 0, ctrlRetAmt = 0, ctrlNetRev = 0;
  var ctrlForPay = 0, ctrlLog = 0, ctrlStor = 0, ctrlDeduct = 0;
  var ctrlAcc = 0, ctrlPen = 0, ctrlLoyalty = 0, ctrlTech = 0, ctrlAfter = 0;
  // Индексы: 5=sales, 6=returns, 7=net_sales, 8=gross, 9=retAmt, 10=netRev
  // 11=forPay, 12=log, 13=stor, 14=deduct, 15=acc, 16=pen, 17=acq, 18=loyalty, 19=tech, 20=after
  for (var ci = 0; ci < resultRows.length; ci++) {
    ctrlSales += (Number(resultRows[ci][5]) || 0);
    ctrlReturns += (Number(resultRows[ci][6]) || 0);
    ctrlNetSales += (Number(resultRows[ci][7]) || 0);
    ctrlGrossRev += (Number(resultRows[ci][8]) || 0);
    ctrlRetAmt += (Number(resultRows[ci][9]) || 0);
    ctrlNetRev += (Number(resultRows[ci][10]) || 0);
    ctrlForPay += (Number(resultRows[ci][11]) || 0);
    ctrlLog += (Number(resultRows[ci][12]) || 0);
    ctrlStor += (Number(resultRows[ci][13]) || 0);
    ctrlDeduct += (Number(resultRows[ci][14]) || 0);
    ctrlAcc += (Number(resultRows[ci][15]) || 0);
    ctrlPen += (Number(resultRows[ci][16]) || 0);
    ctrlLoyalty += (Number(resultRows[ci][18]) || 0);
    ctrlTech += (Number(resultRows[ci][19]) || 0);
    ctrlAfter += (Number(resultRows[ci][20]) || 0);
  }
  console.log('══ Контрольные суммы CLEAN_WB_DAILY ══');
  console.log('  sales_qty:       ' + ctrlSales);
  console.log('  returns_qty:     ' + ctrlReturns);
  console.log('  net_sales_qty:   ' + ctrlNetSales);
  console.log('  gross_revenue (реализация WB): ' + roundTwo_(ctrlGrossRev));
  console.log('  returns_amount:  ' + roundTwo_(ctrlRetAmt));
  console.log('  net_revenue:     ' + roundTwo_(ctrlNetRev));
  console.log('  wb_for_pay:      ' + roundTwo_(ctrlForPay));
  console.log('  wb_logistics:    ' + roundTwo_(ctrlLog));
  console.log('  wb_storage:      ' + roundTwo_(ctrlStor));
  console.log('  wb_deductions:   ' + roundTwo_(ctrlDeduct));
  console.log('  wb_acceptance:   ' + roundTwo_(ctrlAcc));
  console.log('  wb_penalties:    ' + roundTwo_(ctrlPen));
  console.log('  wb_loyalty_comp: ' + roundTwo_(ctrlLoyalty));
  console.log('  wb_tech_comp:    ' + roundTwo_(ctrlTech));
  console.log('  wb_after_expenses: ' + roundTwo_(ctrlAfter));

  var expectedSales = finStats.salesRows || 0;
  if (salesSource === 'RAW_WB_FINANCE' && expectedSales > 0 && ctrlSales < expectedSales * 0.5) {
    var warnMsg = '⚠️ КРИТИЧНО: sales_qty в CLEAN (' + ctrlSales +
      ') значительно меньше ожидаемых из RAW_WB_FINANCE (' + expectedSales + ')';
    console.log(warnMsg);
    errorsBuffer.push(makeErrorRow_('CLEAN_WB_DAILY', 0, 'Расхождение продаж', 'Критично', '', '',
      warnMsg, 'Проверить маппинг nm_id и дат'));
  }

  // ── Ошибки и лог ──
  var errorsTotal = errorsBuffer.length;
  flushErrors_(ss, errorsBuffer);
  writeUpdateLog_(ss, resultRows.length, errorsTotal, emptySheets, t0);

  // ── Финал ──
  var elapsed = sec_(t0);
  console.log('═══ buildCleanWbDailyWithFinance() ЗАВЕРШЕНО: ' + resultRows.length + ' строк, ' + elapsed + ' сек ═══');

  SpreadsheetApp.getUi().alert('📊 CLEAN_WB_DAILY собран',
    'Строк: ' + resultRows.length + ' | Дат: ' + datesCount + ' | SKU: ' + nmCount + '\n\n' +
    '📦 Источник: ' + salesSource + '\n' +
    '  Продаж: ' + ctrlSales + ' | Возвратов: ' + ctrlReturns + '\n\n' +
    '💰 Реализация WB: ' + roundTwo_(ctrlGrossRev) + ' ₽\n' +
    '  К перечислению: ' + roundTwo_(ctrlForPay) + ' ₽\n' +
    '  Логистика: ' + roundTwo_(ctrlLog) + ' ₽\n' +
    '  Хранение: ' + roundTwo_(ctrlStor) + ' ₽\n' +
    '  Удержания: ' + roundTwo_(ctrlDeduct) + ' ₽\n' +
    '  После расходов WB: ' + roundTwo_(ctrlAfter) + ' ₽\n\n' +
    'Ошибок: ' + errorsTotal + ' | Время: ' + elapsed + ' сек',
    SpreadsheetApp.getUi().ButtonSet.OK);
}


