  var fCompCol    = findCol_(fH, ['compensation_amount', 'компенсация', 'возмещение']);
  var fRebillCol = findCol_(fH, ['rebill_logistics', 'rebill_logistic_cost', 'rebillLogisticCost', 'rebilllogisticcost']);

