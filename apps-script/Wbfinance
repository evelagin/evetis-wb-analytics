 * Если есть прямые колонки — берёт из них.
 * Если нет прямых колонок, но есть operation_type + amount — использует фолбэк.
 * Оба режима могут работать одновременно (суммируются).
 */
/**
 * Аудит всех колонок RAW_WB_FINANCE.
 * Выводит заголовки с индексами и суммы по числовым колонкам.
 * Отдельно считает суммы для строк "Продажа | Продажа" и "Логистика".
 */
function auditRawWbFinanceColumns() {
  console.log('═══ auditRawWbFinanceColumns() СТАРТ ═══');
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var finSheet = ss.getSheetByName('RAW_WB_FINANCE');
  if (!finSheet || finSheet.getLastRow() < 2) {
    console.log('❌ RAW_WB_FINANCE пуст или не найден');
    SpreadsheetApp.getUi().alert('❌', 'RAW_WB_FINANCE пуст.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var lastCol = finSheet.getLastColumn();
  var headers = finSheet.getRange(1, 1, 1, lastCol).getValues()[0];
  var data = finSheet.getRange(2, 1, finSheet.getLastRow() - 1, lastCol).getValues();

  console.log('📋 Всего колонок: ' + lastCol + ', строк данных: ' + data.length);
  console.log('');

  // Найдём docType и opType колонки для фильтрации
  var docTypeIdx = -1, opTypeIdx = -1;
  for (var h = 0; h < headers.length; h++) {
    var hn = String(headers[h] || '').trim().toLowerCase();
    if (hn === 'doc_type_name') docTypeIdx = h;
    if (hn === 'supplier_oper_name' || hn === 'operation_type_normalized') {
      if (opTypeIdx === -1) opTypeIdx = h;
    }
  }

  console.log('══ ВСЕ ЗАГОЛОВКИ ══');
  for (var h = 0; h < headers.length; h++) {
    console.log('  [' + h + '] (col ' + (h + 1) + '): "' + headers[h] + '"');
  }

  // Считаем суммы по всем числовым колонкам
  console.log('');
  console.log('══ СУММЫ ПО ЧИСЛОВЫМ КОЛОНКАМ (все строки) ══');

  var colSums = {};
  var saleSums = {};   // только "Продажа | Продажа"
  var logSums = {};    // только "Логистика"
  var loyaltySums = {}; // только "Компенсация скидки"

  for (var ri = 0; ri < data.length; ri++) {
    var row = data[ri];
    var dt = docTypeIdx >= 0 ? String(row[docTypeIdx] || '').trim() : '';
    var op = opTypeIdx >= 0 ? String(row[opTypeIdx] || '').trim() : '';
    var isSaleRow = (dt === 'Продажа' && op === 'Продажа');
    var isLogRow = (op.indexOf('Логистика') >= 0 || op.indexOf('логистика') >= 0);
    var isLoyaltyRow = (op.indexOf('Компенсация скидки') >= 0 || op.indexOf('лояльност') >= 0);

    for (var ci = 0; ci < row.length; ci++) {
      var val = Number(row[ci]);
      if (isNaN(val) || val === 0) continue;
      if (!colSums[ci]) colSums[ci] = 0;
      colSums[ci] += val;
      if (isSaleRow) {
        if (!saleSums[ci]) saleSums[ci] = 0;
        saleSums[ci] += val;
      }
      if (isLogRow) {
        if (!logSums[ci]) logSums[ci] = 0;
        logSums[ci] += val;
      }
      if (isLoyaltyRow) {
        if (!loyaltySums[ci]) loyaltySums[ci] = 0;
        loyaltySums[ci] += val;
      }
    }
  }

  var numCols = Object.keys(colSums).sort(function(a, b) { return Number(a) - Number(b); });
  for (var nci = 0; nci < numCols.length; nci++) {
    var ci = Number(numCols[nci]);
    console.log('  [' + ci + '] "' + headers[ci] + '": ВСЕГО=' + roundTwo_(colSums[ci]) +
      (saleSums[ci] ? ', Продажа|Продажа=' + roundTwo_(saleSums[ci]) : '') +
      (logSums[ci] ? ', Логистика=' + roundTwo_(logSums[ci]) : '') +
      (loyaltySums[ci] ? ', Лояльность=' + roundTwo_(loyaltySums[ci]) : ''));
  }

  // Подсказка: ищем 168174.71 и 20697.22
  console.log('');
  console.log('══ ПОИСК ЭТАЛОННЫХ СУММ ══');
  for (var nci2 = 0; nci2 < numCols.length; nci2++) {
    var ci2 = Number(numCols[nci2]);
    var sv = saleSums[ci2] || 0;
    if (Math.abs(sv - 168174.71) < 1) {
      console.log('  🎯 К перечислению продавцу: [' + ci2 + '] "' + headers[ci2] + '" = ' + roundTwo_(sv));
    }
    if (Math.abs(sv - 158190.03) < 1) {
      console.log('  🎯 Реализация WB: [' + ci2 + '] "' + headers[ci2] + '" = ' + roundTwo_(sv));
    }
    var lv = logSums[ci2] || 0;
    if (Math.abs(Math.abs(lv) - 20697.22) < 1) {
      console.log('  🎯 Логистика WB: [' + ci2 + '] "' + headers[ci2] + '" = ' + roundTwo_(lv));
    }
    var lyv = loyaltySums[ci2] || 0;
    if (Math.abs(lyv - 277.31) < 1 || Math.abs(Math.abs(lyv) - 277.31) < 1) {
      console.log('  🎯 Лояльность: [' + ci2 + '] "' + headers[ci2] + '" = ' + roundTwo_(lyv));
    }
  }

  console.log('');
  console.log('═══ auditRawWbFinanceColumns() ЗАВЕРШЕНО ═══');
  SpreadsheetApp.getUi().alert('✅ Аудит колонок завершён',
    'Результаты — в Журнале выполнения (console.log).\n\n' +
    'Колонок: ' + lastCol + '\nСтрок данных: ' + data.length + '\n' +
    'Числовых колонок с данными: ' + numCols.length,
    SpreadsheetApp.getUi().ButtonSet.OK);
}


