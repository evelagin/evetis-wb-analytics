  var fNmCol      = findCol_(fH, ['wb_nm_id', 'nm_id', 'nmid', 'артикул wb']);
  var fVendorCol  = findCol_(fH, ['wb_vendor_code', 'vendor_code', 'vendorcode', 'supplierarticle']);
  var fBarcodeCol = findCol_(fH, ['barcode', 'barcodes']);
  var fDocTypeCol = findCol_(fH, ['doc_type_name', 'тип документа']);
  var fOpTypeCol  = findCol_(fH, ['supplier_oper_name', 'operation_type_normalized', 'operation_type']);
  var fQtyCol     = findCol_(fH, ['quantity', 'кол-во', 'количество']);
  var fRetailCol  = findCol_(fH, ['retail_amount', 'retail_price',
    'вайлдберриз реализовал товар (пр)', 'вайлдберриз реализовал товар']);
  var fForPayCol  = findCol_(fH, ['ppvz_for_pay', 'for_pay',
    'к перечислению продавцу за реализованный товар', 'к перечислению продавцу',
    'к перечислению']);
  var fLogCol     = findCol_(fH, ['delivery_rub', 'logistics_amount',
    'услуги по доставке товара покупателю', 'услуги по доставке товара',
    'логистика']);
  var fStorCol    = findCol_(fH, ['storage_fee', 'хранение']);
  var fDeductCol  = findCol_(fH, ['deduction', 'удержания']);
  var fAccCol     = findCol_(fH, ['acceptance_fee', 'acceptance',
    'операции на приемке', 'приемка']);
  var fPenCol     = findCol_(fH, ['penalty', 'общая сумма штрафов', 'штраф', 'штрафы']);
  var fAcqCol     = findCol_(fH, ['acquiring_fee',
    'компенсация платёжных услуг', 'компенсация платежных услуг',
    'комиссия за интеграцию платёжных сервисов', 'комиссия за интеграцию платежных сервисов',
