/**
 * Заполняет RAW_WB_FINANCE тестовыми расходами.
 *
 * v1.2 — Берёт даты и выручку из CLEAN_WB_DAILY, а НЕ из календаря.
 * Только строки, где есть продажи (sales_qty > 0 или net_revenue > 0).
 * Расходы ложатся точно на те же date + wb_nm_id, что и продажи.
 *
 * Расходы:
 *   - Комиссия WB: 15% от net_revenue
 *   - Логистика WB: 35 ₽ × net_sales_qty
 *   - Хранение WB: 2 ₽ за SKU/день
 *   - Приемка WB: 0 — строка не создаётся
 *   - Эквайринг: 1.5% от net_revenue
 *   - Штрафы: 0 — строка не создаётся
 */
function fillTestFinanceRawData() {
  console.log('═══ fillTestFinanceRawData() v1.2 СТАРТ ═══');
  var t0 = Date.now();
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  // ── 1. Проверяем RAW_WB_FINANCE ──
  var finSheet = ss.getSheetByName('RAW_WB_FINANCE');
  if (!finSheet) {
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'Лист RAW_WB_FINANCE не найден.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  // ── 2. Проверяем/добавляем колонки amount и operation_type_normalized ──
  var fH = getHeaderMap_(finSheet);
  var fLastCol = finSheet.getLastColumn();

  var hasAmount = findCol_(fH, ['amount', 'sum', 'amount_rub', 'ppvz_for_pay']) >= 0;
  var hasOpType = findCol_(fH, ['operation_type_normalized', 'supplier_oper_name', 'operation_type']) >= 0;

  var addedCols = [];
  if (!hasAmount) {
    finSheet.getRange(1, fLastCol + 1).setValue('amount');
    addedCols.push('amount');
    fLastCol++;
  }
  if (!hasOpType) {
    finSheet.getRange(1, fLastCol + 1).setValue('operation_type_normalized');
    addedCols.push('operation_type_normalized');
    fLastCol++;
  }
  if (addedCols.length > 0) {
    SpreadsheetApp.flush();
    console.log('  Добавлены колонки: ' + addedCols.join(', '));
  }

  // Перечитываем заголовки
  fH = getHeaderMap_(finSheet);
  fLastCol = finSheet.getLastColumn();
  console.log('  RAW_WB_FINANCE: lastCol=' + fLastCol);

  logFoundCols_(fH, ['rr_dt', 'sale_dt', 'order_dt', 'operation_date', 'date',
    'wb_nm_id', 'nm_id', 'wb_vendor_code', 'barcode',
    'commission', 'delivery_rub', 'storage_fee', 'acceptance_fee', 'acquiring_fee', 'penalty',
    'operation_type_normalized', 'supplier_oper_name', 'amount', 'sum', 'ppvz_for_pay']);

  // ── 3. Читаем CLEAN_WB_DAILY — источник дат и выручки ──
  var cleanSheet = ss.getSheetByName('CLEAN_WB_DAILY');
  if (!cleanSheet || cleanSheet.getLastRow() < 2) {
    SpreadsheetApp.getUi().alert('❌ Ошибка',
      'CLEAN_WB_DAILY пуст или не найден.\nСначала заполните тестовые RAW-данные и соберите CLEAN.',
      SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var cH = getHeaderMap_(cleanSheet);
  var cDateCol = findCol_(cH, ['date']);
  var cNmCol = findCol_(cH, ['wb_nm_id']);
  var cNameCol = findCol_(cH, ['product_name']);
  var cSkuCol = findCol_(cH, ['internal_sku']);
  var cSalesCol = findCol_(cH, ['sales_qty']);
  var cNetSalesCol = findCol_(cH, ['net_sales_qty']);
  var cNetRevCol = findCol_(cH, ['net_revenue']);
  var cGrossRevCol = findCol_(cH, ['gross_revenue']);

  if (cDateCol === -1 || cNmCol === -1) {
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'В CLEAN_WB_DAILY нет колонки date или wb_nm_id.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var cleanData = readSheetData_(cleanSheet);
  console.log('  CLEAN_WB_DAILY: ' + cleanData.length + ' строк прочитано');

  // ── 4. Читаем SKU_MASTER для vendor_code / barcode ──
  var skuExtra = {}; // nm_id → {vendor_code, barcode}
  var masterSheet = ss.getSheetByName('SKU_MASTER');
  if (masterSheet) {
    var mH2 = getHeaderMap_(masterSheet);
    var mNm2 = findCol_(mH2, ['wb_nm_id', 'nm_id', 'nmid']);
    var mVc2 = findCol_(mH2, ['wb_vendor_code', 'vendor_code']);
    var mBc2 = findCol_(mH2, ['barcode', 'barcodes']);
    if (mNm2 >= 0) {
      var mData2 = readSheetData_(masterSheet);
      for (var mi = 0; mi < mData2.length; mi++) {
        var mnm = normalizeNmIdFinance_(mData2[mi][mNm2]);
        if (!mnm) continue;
        skuExtra[mnm] = {
          vendor_code: mVc2 >= 0 ? String(mData2[mi][mVc2] || '') : '',
          barcode: mBc2 >= 0 ? String(mData2[mi][mBc2] || '') : ''
        };
      }
    }
  }

  // ── 5. Фильтруем строки CLEAN: только с продажами / выручкой ──
  var salesRows = [];
  for (var ci = 0; ci < cleanData.length; ci++) {
    var row = cleanData[ci];
    var salesQty = cSalesCol >= 0 ? (Number(row[cSalesCol]) || 0) : 0;
    var netRev = cNetRevCol >= 0 ? (Number(row[cNetRevCol]) || 0) : 0;
    var grossRev = cGrossRevCol >= 0 ? (Number(row[cGrossRevCol]) || 0) : 0;

    if (salesQty <= 0 && netRev <= 0 && grossRev <= 0) continue;

    var dateStr = normalizeDateKey_(row[cDateCol]);
    var nmId = normalizeNmIdFinance_(row[cNmCol]);
    if (!dateStr || !nmId) continue;

    var netSalesQty = cNetSalesCol >= 0 ? (Number(row[cNetSalesCol]) || 0) : salesQty;
    var productName = cNameCol >= 0 ? String(row[cNameCol] || '') : '';
    var internalSku = cSkuCol >= 0 ? String(row[cSkuCol] || '') : '';

    var extra = skuExtra[nmId] || {};

    salesRows.push({
      date: dateStr,
      dateObj: new Date(dateStr + 'T12:00:00'),
      nmId: nmId,
      productName: productName,
      internalSku: internalSku,
      vendorCode: extra.vendor_code || '',
      barcode: extra.barcode || '',
      netRev: netRev,
      netSalesQty: netSalesQty
    });
  }

  console.log('  Строк с продажами в CLEAN: ' + salesRows.length);

  if (salesRows.length === 0) {
    SpreadsheetApp.getUi().alert('⚠️ Нет данных',
      'В CLEAN_WB_DAILY нет строк с продажами или выручкой.\nСначала заполните тестовые RAW-данные и соберите CLEAN.',
      SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  // Логируем какие даты нашли
  var uniqueDates = {};
  for (var ui2 = 0; ui2 < salesRows.length; ui2++) uniqueDates[salesRows[ui2].date] = true;
  console.log('  Даты из CLEAN: ' + Object.keys(uniqueDates).sort().join(', '));

  // ── 6. Типы расходов ──
  var expenseTypes = [
    { name: 'Комиссия WB',  calc: function(nr, nq) { return roundTwo_(nr * 0.15); } },
    { name: 'Логистика WB',  calc: function(nr, nq) { return roundTwo_(35 * nq); } },
    { name: 'Хранение WB',   calc: function(nr, nq) { return 2; } },
    { name: 'Эквайринг',     calc: function(nr, nq) { return roundTwo_(nr * 0.015); } }
    // Приемка = 0 и Штрафы = 0 — не создаём строки
  ];

  // ── 7. Генерируем строки RAW_WB_FINANCE ──
  var finRows = [];

  for (var si = 0; si < salesRows.length; si++) {
    var sr = salesRows[si];

    for (var ei = 0; ei < expenseTypes.length; ei++) {
      var expType = expenseTypes[ei];
      var amt = expType.calc(sr.netRev, sr.netSalesQty);
      if (amt <= 0) continue;

      var finRow = makeEmptyRow_(fLastCol);

      // Дата — во все возможные колонки
      setIfExists_(finRow, fH, 'rr_dt', sr.dateObj);
      setIfExists_(finRow, fH, 'sale_dt', sr.dateObj);
      setIfExists_(finRow, fH, 'order_dt', sr.dateObj);
      setIfExists_(finRow, fH, 'operation_date', sr.dateObj);
      setIfExists_(finRow, fH, 'date', sr.dateObj);

      // Артикул
      setIfExists_(finRow, fH, 'wb_nm_id', sr.nmId);
      setIfExists_(finRow, fH, 'nm_id', sr.nmId);
      setIfExists_(finRow, fH, 'wb_vendor_code', sr.vendorCode);
      setIfExists_(finRow, fH, 'barcode', sr.barcode);

      // Тип операции
      setIfExists_(finRow, fH, 'operation_type_normalized', expType.name);
      setIfExists_(finRow, fH, 'supplier_oper_name', expType.name);
      setIfExists_(finRow, fH, 'operation_type', expType.name);

      // Сумма
      setIfExists_(finRow, fH, 'amount', amt);
      setIfExists_(finRow, fH, 'sum', amt);
      setIfExists_(finRow, fH, 'amount_rub', amt);
      setIfExists_(finRow, fH, 'ppvz_for_pay', amt);

      // Прямые колонки расходов (если есть)
      if (expType.name === 'Комиссия WB')  setIfExists_(finRow, fH, 'commission', amt);
      if (expType.name === 'Логистика WB')  setIfExists_(finRow, fH, 'delivery_rub', amt);
      if (expType.name === 'Хранение WB')   setIfExists_(finRow, fH, 'storage_fee', amt);
      if (expType.name === 'Эквайринг')      setIfExists_(finRow, fH, 'acquiring_fee', amt);

      // Мета
      setIfExists_(finRow, fH, 'load_id', 'TEST_FINANCE_001');
      setIfExists_(finRow, fH, 'processed_status', 'OK');

      finRows.push(finRow);
    }
  }

  console.log('  Сгенерировано строк: ' + finRows.length);

  // ── 8. Запись ──
  var writtenFinance = writeTestRows_(finSheet, finRows, 'RAW_WB_FINANCE');

  var elapsed = ((Date.now() - t0) / 1000).toFixed(2);
  console.log('═══ fillTestFinanceRawData() v1.2 ЗАВЕРШЕНО: ' + writtenFinance + ' строк, ' + elapsed + ' сек ═══');

  var dateList = Object.keys(uniqueDates).sort();
  SpreadsheetApp.getUi().alert('✅ Тестовые расходы WB записаны',
    'Источник дат: CLEAN_WB_DAILY\n' +
    'Строк с продажами: ' + salesRows.length + '\n' +
    'Даты: ' + dateList.join(', ') + '\n' +
    'RAW_WB_FINANCE: записано ' + writtenFinance + ' строк\n\n' +
    'Расходы (только ненулевые):\n' +
    '  Комиссия WB: 15% от net_revenue\n' +
    '  Логистика WB: 35 ₽ × net_sales_qty\n' +
    '  Хранение WB: 2 ₽ / SKU / день\n' +
    '  Эквайринг: 1.5% от net_revenue\n\n' +
    'Время: ' + elapsed + ' сек\n\n' +
    'Теперь запустите «Пересобрать CLEAN с расходами».',
    SpreadsheetApp.getUi().ButtonSet.OK);
}


