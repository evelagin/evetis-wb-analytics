/**
 * Нормализует wb_nm_id:
 *   252442517     → "252442517"
 *   252442517.0   → "252442517"
 *   "252442517 "  → "252442517"
 *   пустое/null   → ""
 *
 * ВАЖНО: эта функция может уже существовать в другом файле.
 * Если да — Apps Script возьмёт последнее определение.
 * Для надёжности используем имя normalizeNmIdFinance_().
 */
function normalizeNmIdFinance_(val) {
  if (val === null || val === undefined || val === '') return '';
  // Число → убрать десятичную часть
  if (typeof val === 'number') {
    val = Math.floor(val);
  }
  var s = String(val).trim();
  // Убрать .0, .00
  s = s.replace(/\.0+$/, '');
  // Убрать нечисловые (кроме ведущих нулей)
  if (!s || s === '0') return '';
  return s;
}


