  var ss = SpreadsheetApp.getActiveSpreadsheet();
  console.log('═══ buildMonthlyUnitReportWithFinance() СТАРТ ═══');

  var tStep = Date.now();
  var cleanSheet = ss.getSheetByName('CLEAN_WB_DAILY');
  if (!cleanSheet || cleanSheet.getLastRow() < 2) {
    SpreadsheetApp.getUi().alert('❌ Ошибка', 'CLEAN_WB_DAILY пуст или не найден.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  var cH = getHeaderMap_(cleanSheet);
  var cDateCol = findCol_(cH, ['date']);
  var cNmCol = findCol_(cH, ['wb_nm_id']);
  var cNameCol = findCol_(cH, ['product_name']);
  var cSkuCol = findCol_(cH, ['internal_sku']);
  var cOrdersCol = findCol_(cH, ['orders_qty']);
  var cSalesCol = findCol_(cH, ['sales_qty']);
  var cReturnsCol = findCol_(cH, ['returns_qty']);
  var cNetSalesCol = findCol_(cH, ['net_sales_qty']);
  var cNetRevCol = findCol_(cH, ['net_revenue']);
  var cGrossRevCol = findCol_(cH, ['gross_revenue']);
  var cAdsCol = findCol_(cH, ['ads_spend']);
  var cStockCol = findCol_(cH, ['stock_qty']);
  var cCommCol = findCol_(cH, ['wb_for_pay']);
  var cLogCol = findCol_(cH, ['wb_logistics']);
  var cStorCol = findCol_(cH, ['wb_storage']);
  var cAccCol = findCol_(cH, ['wb_acceptance']);
  var cDeductCol = findCol_(cH, ['wb_deductions']);
  var cPenCol = findCol_(cH, ['wb_penalties']);
  var cAcqCol = findCol_(cH, ['wb_acquiring']);
  var cLoyaltyCol = findCol_(cH, ['wb_loyalty_comp']);
  var cTechCol = findCol_(cH, ['wb_tech_comp']);
  var cAfterCol = findCol_(cH, ['wb_after_expenses']);

  if (cDateCol === -1 || cNmCol === -1) {
    SpreadsheetApp.getUi().alert('❌', 'Нет date или wb_nm_id в CLEAN.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  // v7: Валидация критических финансовых колонок
  var missingFinCols = [];
  var finColCheck = [
    { name: 'wb_for_pay', idx: cCommCol },
    { name: 'wb_logistics', idx: cLogCol },
    { name: 'wb_storage', idx: cStorCol },
    { name: 'wb_deductions', idx: cDeductCol },
    { name: 'wb_loyalty_comp', idx: cLoyaltyCol },
    { name: 'wb_tech_comp', idx: cTechCol },
    { name: 'wb_after_expenses', idx: cAfterCol }
  ];
  for (var fci = 0; fci < finColCheck.length; fci++) {
    if (finColCheck[fci].idx === -1) {
      missingFinCols.push(finColCheck[fci].name);
      console.log('  ⚠️ КРИТИЧНО: колонка "' + finColCheck[fci].name + '" НЕ НАЙДЕНА в CLEAN_WB_DAILY!');
    }
  }
  if (missingFinCols.length > 0) {
    // Записываем ошибку в ERRORS_CONTROL
    var errSheet = ss.getSheetByName('ERRORS_CONTROL');
    if (errSheet) {
      var errMsg = 'Не найдены финансовые колонки в CLEAN_WB_DAILY: ' + missingFinCols.join(', ');
      var errRow = [
        'UNIT_FIN_COLS_' + Date.now(), new Date(), 'CLEAN_WB_DAILY', 0,
        'Не найдена колонка', 'Критично', '', '',
        errMsg, '', '', 'нет', '', '', 'Пересоберите CLEAN с расходами'
      ];
      errSheet.appendRow(errRow);
      console.log('  ❌ Записана ошибка в ERRORS_CONTROL: ' + errMsg);
    }
    console.log('  ⚠️ ЮНИТ будет собран без расходов WB — сначала пересоберите CLEAN с расходами!');
  }

  var cleanData = readSheetData_(cleanSheet);
  console.log('✅ CLEAN_WB_DAILY: ' + cleanData.length + ' строк');
  console.log('  Колонки: forPay=' + cCommCol + ', log=' + cLogCol +
    ', stor=' + cStorCol + ', deduct=' + cDeductCol + ', acc=' + cAccCol +
    ', pen=' + cPenCol + ', loyalty=' + cLoyaltyCol + ', tech=' + cTechCol +
    ', after=' + cAfterCol);

  // SKU_MASTER
  var masterSheet = ss.getSheetByName('SKU_MASTER');
  var cogsMap = {}, skuInfoMap = {};
  if (masterSheet) {
    var mH = getHeaderMap_(masterSheet);
    var mNmCol = findCol_(mH, ['wb_nm_id', 'nm_id']);
    var mCogsCol = findCol_(mH, ['current_cogs']);
    var mNameCol = findCol_(mH, ['product_name_short', 'product_name']);
    var mSkuCol = findCol_(mH, ['internal_sku']);
    var mCatCol = findCol_(mH, ['category']);
    var mData = readSheetData_(masterSheet);
    for (var i = 0; i < mData.length; i++) {
      var nm = mNmCol >= 0 ? normalizeNmIdFinance_(mData[i][mNmCol]) : '';
      if (!nm) continue;
      cogsMap[nm] = mCogsCol >= 0 ? (Number(mData[i][mCogsCol]) || 0) : 0;
      skuInfoMap[nm] = {
        name: mNameCol >= 0 ? String(mData[i][mNameCol] || '') : '',
        sku: mSkuCol >= 0 ? String(mData[i][mSkuCol] || '') : '',
        category: mCatCol >= 0 ? String(mData[i][mCatCol] || '') : ''
      };
    }
  }

  // v8: Собираем индексы колонок для getCleanMonthCabinetTotals_
  var cabinetColIdx = {
    date: cDateCol, nm: cNmCol,
    orders: cOrdersCol, sales: cSalesCol, returns: cReturnsCol,
    netSales: cNetSalesCol, grossRev: cGrossRevCol, netRev: cNetRevCol,
    forPay: cCommCol, log: cLogCol, stor: cStorCol,
    deduct: cDeductCol, acc: cAccCol, pen: cPenCol,
    loyalty: cLoyaltyCol, tech: cTechCol, after: cAfterCol,
    ads: cAdsCol, stock: cStockCol
  };

  // Группируем по месяцам — ТОЛЬКО строки с непустым nm_id (для товарных блоков)
  var monthData = {}, allNmIds = {}, monthKeys_ = {};
  for (var ci = 0; ci < cleanData.length; ci++) {
    var row = cleanData[ci];
    var ds = normalizeDateKey_(row[cDateCol]);
    if (!ds) continue;
    var p = ds.split('-'), mk = p[0] + '-' + p[1], dd = Number(p[2]);
    monthKeys_[mk] = true;
    var nm = normalizeNmIdFinance_(row[cNmCol]);
    if (!nm) continue; // кабинетные строки — обрабатываются отдельно через getCleanMonthCabinetTotals_
    if (!monthData[mk]) monthData[mk] = {};
    if (!monthData[mk][nm]) monthData[mk][nm] = {};
    allNmIds[nm] = true;
    if (!skuInfoMap[nm]) {
      skuInfoMap[nm] = {
        name: cNameCol >= 0 ? String(row[cNameCol] || '') : '',
        sku: cSkuCol >= 0 ? String(row[cSkuCol] || '') : '',
        category: ''
      };
    }
    monthData[mk][nm][dd] = {
      orders: cOrdersCol >= 0 ? (Number(row[cOrdersCol]) || 0) : 0,
      sales: cSalesCol >= 0 ? (Number(row[cSalesCol]) || 0) : 0,
      returns: cReturnsCol >= 0 ? (Number(row[cReturnsCol]) || 0) : 0,
      netSales: cNetSalesCol >= 0 ? (Number(row[cNetSalesCol]) || 0) : 0,
      netRev: cNetRevCol >= 0 ? (Number(row[cNetRevCol]) || 0) : 0,
      grossRev: cGrossRevCol >= 0 ? (Number(row[cGrossRevCol]) || 0) : 0,
      ads: cAdsCol >= 0 ? (Number(row[cAdsCol]) || 0) : 0,
      stock: cStockCol >= 0 ? (Number(row[cStockCol]) || 0) : 0,
      wbForPay: cCommCol >= 0 ? (Number(row[cCommCol]) || 0) : 0,
      wbLog: cLogCol >= 0 ? (Number(row[cLogCol]) || 0) : 0,
      wbStor: cStorCol >= 0 ? (Number(row[cStorCol]) || 0) : 0,
      wbDeduct: cDeductCol >= 0 ? (Number(row[cDeductCol]) || 0) : 0,
      wbAcc: cAccCol >= 0 ? (Number(row[cAccCol]) || 0) : 0,
      wbPen: cPenCol >= 0 ? (Number(row[cPenCol]) || 0) : 0,
      wbLoyalty: cLoyaltyCol >= 0 ? (Number(row[cLoyaltyCol]) || 0) : 0,
      wbTech: cTechCol >= 0 ? (Number(row[cTechCol]) || 0) : 0,
      wbAfter: cAfterCol >= 0 ? (Number(row[cAfterCol]) || 0) : 0
    };
  }

  var monthKeys = Object.keys(monthKeys_).sort();
  var nmIdList = Object.keys(allNmIds).sort();
  console.log('  Месяцев: ' + monthKeys.length + ', товаров: ' + nmIdList.length);

  // Собираем листы
  var tWrite = 0, tFormat = 0;
  var verifyErrors = false;
  for (var mki = 0; mki < monthKeys.length; mki++) {
    var mk = monthKeys[mki], mP = mk.split('-'), year = Number(mP[0]), month = Number(mP[1]);
    var daysInMonth = new Date(year, month, 0).getDate();
    var sheetName = 'ЮНИТ_' + pad2_(month) + '_' + year;
    var monthNmIds = monthData[mk] ? Object.keys(monthData[mk]).sort() : [];
    var totalCols = 1 + daysInMonth + 1;

    // v8: Кабинетные итоги — суммируем ВСЕ строки CLEAN за месяц (включая nm=0)
    var cabinetResult = getCleanMonthCabinetTotals_(cleanData, mk, cabinetColIdx, cogsMap);
    var cabStats = cabinetResult.stats;

    // v8: Диагностика — подтверждаем гипотезу про кабинетные расходы
    console.log('  ── v8: Диагностика CLEAN за ' + mk + ' ──');
    console.log('    Строк CLEAN за месяц всего:        ' + cabStats.totalRows);
    console.log('    Строк с nm=0 / пустой SKU:         ' + cabStats.cabinetRows);
    console.log('    Строк с товарным SKU:               ' + cabStats.skuRows);
    console.log('    wb_storage по всем строкам:          ' + roundTwo_(cabStats.storAll));
    console.log('    wb_storage только товарные:           ' + roundTwo_(cabStats.storSku));
    console.log('    wb_deductions по всем строкам:        ' + roundTwo_(cabStats.deductAll));
    console.log('    wb_deductions только товарные:         ' + roundTwo_(cabStats.deductSku));
    if (cabStats.cabinetRows > 0 && (cabStats.storAll - cabStats.storSku) > 1) {
      console.log('    → Подтверждено: хранение ' + roundTwo_(cabStats.storAll - cabStats.storSku) +
        ' ₽ сидит в кабинетных строках (без SKU)');
    }
    if (cabStats.cabinetRows > 0 && (cabStats.deductAll - cabStats.deductSku) > 1) {
      console.log('    → Подтверждено: удержания ' + roundTwo_(cabStats.deductAll - cabStats.deductSku) +
        ' ₽ сидят в кабинетных строках (без SKU)');
    }

    tStep = Date.now();
    var allRows = [], rowFormats = [];

    var r1 = emptyRow_(totalCols);
    r1[0] = 'Юнит-экономика WB'; r1[1] = RU_MONTHS_[month] + ' ' + year;
    allRows.push(r1); rowFormats.push('title');

    var r2 = emptyRow_(totalCols);
    r2[0] = 'Обновлено'; r2[1] = Utilities.formatDate(new Date(), 'Europe/Moscow', 'dd.MM.yyyy HH:mm');
    allRows.push(r2); rowFormats.push('subtitle');
    allRows.push(emptyRow_(totalCols)); rowFormats.push('empty');

    var dateRow = emptyRow_(totalCols), dowRow = emptyRow_(totalCols);
    var weekendColIdx = [];
    dateRow[0] = 'Показатель';
    for (var d = 1; d <= daysInMonth; d++) {
      var dt2 = new Date(year, month - 1, d);
      dateRow[d] = pad2_(d) + '.' + pad2_(month);
      var dow2 = dt2.getDay();
      dowRow[d] = RU_DAYS_[dow2];
      if (dow2 === 0 || dow2 === 6) weekendColIdx.push(d);
    }
    dateRow[totalCols - 1] = 'Итого';

    var totalSepRow = emptyRow_(totalCols);
    totalSepRow[0] = '📊 ИТОГО ПО КАБИНЕТУ';
    allRows.push(totalSepRow); rowFormats.push('total_header');
    allRows.push(dateRow.slice()); rowFormats.push('dates');
    allRows.push(dowRow.slice()); rowFormats.push('dow');

    // v8: ИТОГО ПО КАБИНЕТУ — из кабинетных итогов (все строки CLEAN, включая nm=0)
    var totalBlock = buildCabinetTotalBlock_(cabinetResult.days, daysInMonth);
    pushBlockRows_(allRows, rowFormats, totalBlock, UNIT_TOTAL_LABELS_, totalCols, [R_.STATUS, R_.COMMENT]);
    allRows.push(emptyRow_(totalCols)); rowFormats.push('empty');

    for (var ni = 0; ni < monthNmIds.length; ni++) {
      var nmId2 = monthNmIds[ni];
      var info2 = skuInfoMap[nmId2] || {};
      var sepRow = emptyRow_(totalCols);
      sepRow[0] = 'АРТИКУЛ WB: ' + nmId2;
      sepRow[1] = info2.name || ''; sepRow[2] = info2.sku || '';
      if (info2.category) sepRow[3] = info2.category;
      allRows.push(sepRow); rowFormats.push('sku_header');
      allRows.push(dateRow.slice()); rowFormats.push('dates');
      allRows.push(dowRow.slice()); rowFormats.push('dow');
      var skuBlock = buildBlockDataWithFinance_(monthData[mk] || {}, [nmId2], daysInMonth, cogsMap, false);
      pushBlockRows_(allRows, rowFormats, skuBlock, UNIT_ROW_LABELS_, totalCols);
      allRows.push(emptyRow_(totalCols)); rowFormats.push('empty');
    }

    // Запись
    tStep = Date.now();
    var sheet = ss.getSheetByName(sheetName);
    if (sheet) { sheet.clear(); sheet.clearConditionalFormatRules(); }
    else { sheet = ss.insertSheet(sheetName); }
    if (sheet.getMaxRows() < allRows.length) sheet.insertRowsAfter(sheet.getMaxRows(), allRows.length - sheet.getMaxRows());
    if (sheet.getMaxColumns() < totalCols) sheet.insertColumnsAfter(sheet.getMaxColumns(), totalCols - sheet.getMaxColumns());
    try { sheet.getRange(1, 1, sheet.getMaxRows(), sheet.getMaxColumns()).clearDataValidations(); } catch (e) {}
    sheet.getRange(1, 1, allRows.length, totalCols).setValues(allRows);
    SpreadsheetApp.flush();
    tWrite += Number(sec_(tStep));

    // Форматирование
    tStep = Date.now();
    sheet.setColumnWidth(1, 230);
    for (var c = 2; c <= totalCols; c++) sheet.setColumnWidth(c, 80);
    sheet.setFrozenRows(2);
    sheet.getRange(1, 1, allRows.length, totalCols).setFontFamily('Arial').setFontSize(10);
    var fmtRanges = groupFormats_(rowFormats);
    for (var fi = 0; fi < fmtRanges.length; fi++) {
      var fmt = fmtRanges[fi];
      var range = sheet.getRange(fmt.start + 1, 1, fmt.count, totalCols);
      switch (fmt.type) {
        case 'title': range.setFontSize(14).setFontWeight('bold'); break;
        case 'subtitle': range.setFontColor('#6B7280'); break;
        case 'total_header': range.setBackground('#1E40AF').setFontColor('#FFFFFF').setFontWeight('bold').setFontSize(11); break;
        case 'sku_header': range.setBackground('#DBEAFE').setFontWeight('bold').setFontSize(10); break;
        case 'dates': range.setFontWeight('bold').setHorizontalAlignment('center').setBackground('#E5E7EB'); break;
        case 'dow': range.setHorizontalAlignment('center').setFontColor('#6B7280').setFontSize(9); break;
        case 'money':
          sheet.getRange(fmt.start + 1, 2, fmt.count, totalCols - 1).setNumberFormat('#,##0');
          sheet.getRange(fmt.start + 1, 1, fmt.count, 1).setFontWeight('bold'); break;
        case 'pct':
          sheet.getRange(fmt.start + 1, 2, fmt.count, totalCols - 1).setNumberFormat('0%');
          sheet.getRange(fmt.start + 1, 1, fmt.count, 1).setFontWeight('bold'); break;
        case 'qty':
          sheet.getRange(fmt.start + 1, 2, fmt.count, totalCols - 1).setNumberFormat('#,##0');
          sheet.getRange(fmt.start + 1, 1, fmt.count, 1).setFontWeight('bold'); break;
        case 'text':
          sheet.getRange(fmt.start + 1, 1, fmt.count, 1).setFontWeight('bold'); break;
      }
    }
    for (var wi = 0; wi < weekendColIdx.length; wi++) {
      sheet.getRange(4, weekendColIdx[wi] + 1, allRows.length - 3, 1).setBackground('#F9FAFB');
    }
    tFormat += Number(sec_(tStep));

    tStep = Date.now();
    applyUnitCondRules_(sheet, rowFormats, allRows.length, totalCols);

    // ── v8: Контрольные логи ЮНИТ ──
    console.log('  📋 Контроль ' + sheetName + ':');
    console.log('    Сумма реализации WB:     ' + roundTwo_(totalBlock[R_.NET_REV].total || 0));
    console.log('    К перечислению WB:       ' + roundTwo_(totalBlock[R_.WB_FOR_PAY].total || 0));
    console.log('    Логистика WB:            ' + roundTwo_(totalBlock[R_.WB_LOG].total || 0));
    console.log('    Хранение WB:             ' + roundTwo_(totalBlock[R_.WB_STOR].total || 0));
    console.log('    Удержания WB:            ' + roundTwo_(totalBlock[R_.WB_DEDUCT].total || 0));
    console.log('    Компенсации WB:          ' + roundTwo_(totalBlock[R_.WB_COMP].total || 0));
    console.log('    После расходов WB:       ' + roundTwo_(totalBlock[R_.WB_AFTER].total || 0));
    console.log('    Себестоимость продаж:     ' + roundTwo_(totalBlock[R_.COGS_TOTAL].total || 0));
    console.log('    Прибыль:                 ' + roundTwo_(totalBlock[R_.PROFIT].total || 0));

    // ── v8: Жесткая сверка CLEAN vs ЮНИТ (расхождение > 1 ₽ = ошибка) ──
    var unitStor = roundTwo_(totalBlock[R_.WB_STOR].total || 0);
    var unitDeduct = roundTwo_(totalBlock[R_.WB_DEDUCT].total || 0);
    var unitAfter = roundTwo_(totalBlock[R_.WB_AFTER].total || 0);
    var cleanStor = roundTwo_(cabStats.storAll);
    var cleanDeduct = roundTwo_(cabStats.deductAll);
    // cleanAfter — считаем из cabinetResult.days
    var cleanAfter = 0;
    var cabDayKeys = Object.keys(cabinetResult.days);
    for (var cdk = 0; cdk < cabDayKeys.length; cdk++) {
      cleanAfter += (cabinetResult.days[cabDayKeys[cdk]].after || 0);
    }
    cleanAfter = roundTwo_(cleanAfter);

    console.log('  ── v8: Жесткая сверка CLEAN → ЮНИТ (' + sheetName + ') ──');
    var diffStor = Math.abs(cleanStor - unitStor);
    var diffDeduct = Math.abs(cleanDeduct - unitDeduct);
    var diffAfter = Math.abs(cleanAfter - unitAfter);
    console.log('    CLEAN wb_storage = ' + cleanStor + ' → ЮНИТ = ' + unitStor +
      (diffStor > 1 ? ' ❌ РАСХОЖДЕНИЕ ' + roundTwo_(diffStor) + ' ₽!' : ' ✅'));
    console.log('    CLEAN wb_deductions = ' + cleanDeduct + ' → ЮНИТ = ' + unitDeduct +
      (diffDeduct > 1 ? ' ❌ РАСХОЖДЕНИЕ ' + roundTwo_(diffDeduct) + ' ₽!' : ' ✅'));
    console.log('    CLEAN wb_after_expenses = ' + cleanAfter + ' → ЮНИТ = ' + unitAfter +
      (diffAfter > 1 ? ' ❌ РАСХОЖДЕНИЕ ' + roundTwo_(diffAfter) + ' ₽!' : ' ✅'));

    if (diffStor > 1 || diffDeduct > 1 || diffAfter > 1) {
      verifyErrors = true;
      console.log('  ❌ СВЕРКА ПРОВАЛЕНА для ' + sheetName + '!');
      var errSheet3 = ss.getSheetByName('ERRORS_CONTROL');
      if (errSheet3) {
        errSheet3.appendRow([
          'UNIT_VERIFY_' + Date.now(), new Date(), sheetName, 0,
          'Расхождение данных', 'Критично', '', '',
          'Сверка CLEAN→ЮНИТ: stor=' + cleanStor + '/' + unitStor +
          ', deduct=' + cleanDeduct + '/' + unitDeduct +
          ', after=' + cleanAfter + '/' + unitAfter,
          '', '', 'нет', '', '', 'Проверить buildMonthlyUnitReportWithFinance()'
        ]);
      }
    }
  }

  var elapsed = sec_(t0);
  console.log('═══ buildMonthlyUnitReportWithFinance() ЗАВЕРШЕНО: ' + elapsed + ' сек ═══');

  if (verifyErrors) {
    SpreadsheetApp.getUi().alert('⚠️ Юнит-экономика собрана с ОШИБКАМИ',
      'Листов: ' + monthKeys.length + '\nТоваров: ' + nmIdList.length +
      '\n\n❌ Сверка CLEAN → ЮНИТ провалена!\nПодробности — в Журнале выполнения и ERRORS_CONTROL.\n\n' +
      'Время: ' + elapsed + ' сек',
      SpreadsheetApp.getUi().ButtonSet.OK);
  } else {
    SpreadsheetApp.getUi().alert('📈 Юнит-экономика собрана (с расходами WB)',
      'Листов: ' + monthKeys.length + '\nТоваров: ' + nmIdList.length +
      '\n\n✅ Сверка CLEAN → ЮНИТ пройдена\n\n' +
      'Время: ' + elapsed + ' сек',
      SpreadsheetApp.getUi().ButtonSet.OK);
  }
}


