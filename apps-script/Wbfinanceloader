/**
 * Нормализует JSON-строки ответа WB API → строки RAW_WB_FINANCE.
 * Заполняет служебные поля, row_hash, raw_json.
 *
 * @return {Object} {rows, hashes:[...] }
 */
function normalizeFinanceApiRows_(apiData, hMap, rawLastCol, loadId, loadedAt, dateFrom, dateTo, taskId, skuIndex) {
  var rows = [];
  var apiKeys = Object.keys(FINANCE_API_FIELD_MAP_);

  for (var i = 0; i < apiData.length; i++) {
    var item = apiData[i];
    var newRow = new Array(rawLastCol);
    for (var c = 0; c < rawLastCol; c++) newRow[c] = '';

    // Маппинг полей API → RAW
    for (var k = 0; k < apiKeys.length; k++) {
      var apiField = apiKeys[k];
      var rawCol = FINANCE_API_FIELD_MAP_[apiField];
      var idx = hMap[rawCol];
      if (idx === undefined) continue;
      var v = item[apiField];
      if (v === undefined || v === null) continue;
      newRow[idx] = v;
    }

    // operation_type_normalized = supplier_oper_name (как в XLSX-маппинге)
    if (hMap['operation_type_normalized'] !== undefined && item.supplier_oper_name !== undefined) {
      newRow[hMap['operation_type_normalized']] = item.supplier_oper_name;
    }

    // Служебные поля
    if (hMap['load_id'] !== undefined) newRow[hMap['load_id']] = loadId;
    if (hMap['loaded_at'] !== undefined) newRow[hMap['loaded_at']] = loadedAt;
    if (hMap['source_api'] !== undefined) newRow[hMap['source_api']] = FINANCE_RAW_SOURCE_API_;
    if (hMap['request_date_from'] !== undefined) newRow[hMap['request_date_from']] = dateFrom;
    if (hMap['request_date_to'] !== undefined) newRow[hMap['request_date_to']] = dateTo;
    if (hMap['report_period_from'] !== undefined) newRow[hMap['report_period_from']] = dateFrom;
    if (hMap['report_period_to'] !== undefined) newRow[hMap['report_period_to']] = dateTo;
    if (hMap['processed_status'] !== undefined) newRow[hMap['processed_status']] = 'raw';
    if (hMap['raw_row_number'] !== undefined) newRow[hMap['raw_row_number']] = i + 1;

    // period_month
    if (hMap['period_month'] !== undefined) {
      var dkPm = normalizeDateKey_(newRow[hMap['sale_dt']] || newRow[hMap['rr_dt']] || '');
      newRow[hMap['period_month']] = dkPm ? dkPm.substring(0, 7) : '';
    }

    // Связка с SKU_MASTER (если индекс передан)
    if (skuIndex) {
      var nmId = hMap['wb_nm_id'] !== undefined ? normalizeNmIdFinance_(newRow[hMap['wb_nm_id']]) : '';
      var matched = false;
      if (nmId && skuIndex.byNm[nmId]) {
        matched = true;
        if (hMap['internal_sku'] !== undefined) newRow[hMap['internal_sku']] = skuIndex.byNm[nmId].sku || '';
      }
      if (!matched && hMap['barcode'] !== undefined) {
        var bc = String(newRow[hMap['barcode']] || '').trim();
        if (bc && skuIndex.byBarcode[bc]) {
          matched = true;
          var rNm = skuIndex.byBarcode[bc];
          if (hMap['internal_sku'] !== undefined && skuIndex.byNm[rNm]) newRow[hMap['internal_sku']] = skuIndex.byNm[rNm].sku || '';
        }
      }
      if (hMap['sku_match_status'] !== undefined) newRow[hMap['sku_match_status']] = matched ? 'matched' : 'not_found';
    }

    // raw_json
    if (hMap['raw_json'] !== undefined) {
      try { newRow[hMap['raw_json']] = JSON.stringify(item); }
      catch (e) { newRow[hMap['raw_json']] = ''; }
    }

    // row_hash
    var rh = computeFinanceRowHash_(newRow, hMap);
    if (hMap['row_hash'] !== undefined) newRow[hMap['row_hash']] = rh;
    newRow.__hash = rh; // временно для дедупа

    rows.push(newRow);
  }

  return rows;
}

/**
 * Тянет отчёт реализации из WB API за период (с пагинацией по rrdid).
 * @return {Object} {ok, data, error, pages}
 */
function fetchFinanceApiData_(token, dateFrom, dateTo) {
  var all = [];
  var rrdid = 0;
  var pages = 0;

  while (pages < WB_FINANCE_API_MAX_PAGES_) {
    pages++;
    var url = WB_FINANCE_API_BASE_ + WB_FINANCE_API_PATH_ +
      '?dateFrom=' + encodeURIComponent(dateFrom) +
      '&dateTo=' + encodeURIComponent(dateTo) +
      '&limit=' + WB_FINANCE_API_LIMIT_ +
      '&rrdid=' + rrdid;

    var resp = UrlFetchApp.fetch(url, {
      method: 'get',
      headers: { 'Authorization': token },
      muteHttpExceptions: true
    });

    var code = resp.getResponseCode();
    if (code === 429) {
      // Rate limit — подождать и повторить эту же страницу
      console.log('  API 429 (rate limit), пауза ' + (WB_FINANCE_API_PAGE_PAUSE_ / 1000) + ' сек...');
      Utilities.sleep(WB_FINANCE_API_PAGE_PAUSE_);
      pages--; // не считаем за страницу
      continue;
    }
    if (code !== 200) {
      return { ok: false, data: all, pages: pages,
        error: 'HTTP ' + code + ': ' + resp.getContentText().substring(0, 200) };
    }

    var chunk;
    try { chunk = JSON.parse(resp.getContentText()); }
    catch (e) { return { ok: false, data: all, pages: pages, error: 'JSON parse: ' + e.message }; }

    if (!chunk || chunk.length === 0) break;

    for (var i = 0; i < chunk.length; i++) all.push(chunk[i]);
    console.log('  Страница ' + pages + ': +' + chunk.length + ' строк (всего ' + all.length + ')');

    // Следующий rrdid = rrd_id последней строки
    var last = chunk[chunk.length - 1];
    var lastId = Number(last.rrd_id || 0);
    if (!lastId || lastId === rrdid) break; // нет продвижения — выходим
    rrdid = lastId;

    if (chunk.length < WB_FINANCE_API_LIMIT_) break; // последняя страница

    Utilities.sleep(WB_FINANCE_API_PAGE_PAUSE_);
  }

  return { ok: true, data: all, pages: pages, error: '' };
}

/**
 * Internal: импорт финансов через WB API. Без UI-алертов.
 * @return {Object} result (поля IMPORT_LOG_FINANCE + флаги)
 */
function importWbFinanceFromApiInternal_(dateFrom, dateTo) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var stamp = Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyyMMdd_HHmmss');

  var result = {
    load_id: FINANCE_LOADID_API_PREFIX_ + stamp,
    loaded_at: Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyy-MM-dd HH:mm:ss'),
    source_type: FINANCE_SOURCE_API_,
    period_from: dateFrom, period_to: dateTo,
    file_id: '', file_name: 'WB_API', task_id: '',
    rows_imported: 0, sales_qty: 0, gross_revenue: 0,
    wb_for_pay: 0, wb_logistics: 0, wb_storage: 0, wb_deductions: 0,
    wb_promotion: 0, wb_transit_delivery: 0, wb_compensations: 0, wb_after_expenses: 0,
    status: 'ERROR', error_message: '', skipped_dupes: 0
  };

  if (!dateFrom || !dateTo) { result.error_message = 'Не указаны dateFrom/dateTo'; return result; }

  var rawSheet = getRawFinanceSheet_(ss);
  if (!rawSheet) { result.error_message = 'Лист RAW_WB_FINANCE не найден'; return result; }

  var tk = getFinanceToken_();
  if (!tk) {
    result.error_message = 'Нет токена WB. Задайте Script Property: ' + WB_FINANCE_TOKEN_KEYS_.join(' или ');
    return result;
  }
  console.log('  API токен: ' + tk.key);

  var logSheet = ensureImportLogFinanceSheet_(ss);

  try {
    // 1. Тянем данные
    console.log('  API: запрос отчёта реализации ' + dateFrom + ' — ' + dateTo);
    var fetched = fetchFinanceApiData_(tk.token, dateFrom, dateTo);
    if (!fetched.ok) {
      result.error_message = fetched.error;
      writeFinanceLogEntry_(logSheet, result);
      return result;
    }
    var apiData = fetched.data;
    console.log('  API: получено ' + apiData.length + ' строк за ' + fetched.pages + ' страниц');

    if (apiData.length === 0) {
      result.status = 'OK';
      result.error_message = 'Пустой отчёт за период';
      writeFinanceLogEntry_(logSheet, result);
      return result;
    }

    // 2. Нормализация
    var rawLastCol = ensureRawFinanceCols_(rawSheet);
    var hMap = buildFinanceRawHeaderMap_(rawSheet, rawLastCol);
    var skuIndex = buildSkuIndex_(ss);

    var rows = normalizeFinanceApiRows_(
      apiData, hMap, rawLastCol, result.load_id, result.loaded_at,
      dateFrom, dateTo, result.task_id, skuIndex
    );

    // 3. Удаляем СВОИ прошлые API-строки за период (идемпотентность загрузчика)
    var cleared = clearFinanceOwnPeriod_(rawSheet, hMap, dateFrom, dateTo, FINANCE_LOADID_API_PREFIX_);
    if (cleared > 0) console.log('  Очищено своих API-строк за период: ' + cleared);

    // 4. Дедуп по row_hash против ВСЕХ существующих строк (вкл. ручной импорт)
    var existing = buildExistingFinanceHashSet_(rawSheet, hMap);
    var batchSeen = {};
    var toWrite = [];
    for (var i = 0; i < rows.length; i++) {
      var h = rows[i].__hash;
      if (existing[h] || batchSeen[h]) { result.skipped_dupes++; continue; }
      batchSeen[h] = true;
      delete rows[i].__hash; // не пишем служебное поле в лист
      toWrite.push(rows[i]);
    }
    console.log('  К записи: ' + toWrite.length + ', пропущено дублей: ' + result.skipped_dupes);

    // 5. Запись
    appendFinanceRows_(rawSheet, toWrite, rawLastCol);

    // 6. Суммы (по всем строкам периода в RAW — для корректной сверки)
    var periodRows = readFinanceRowsForPeriod_(rawSheet, hMap, dateFrom, dateTo);
    var sums = aggregateFinanceSums_(periodRows, hMap);

    result.rows_imported = toWrite.length;
    result.sales_qty = sums.sales_qty;
    result.gross_revenue = sums.gross_revenue;
    result.wb_for_pay = sums.wb_for_pay;
    result.wb_logistics = sums.wb_logistics;
    result.wb_storage = sums.wb_storage;
    result.wb_deductions = sums.wb_deductions;
    result.wb_promotion = sums.wb_promotion;
    result.wb_transit_delivery = sums.wb_transit_delivery;
    result.wb_compensations = sums.wb_compensations;
    result.wb_after_expenses = sums.wb_after_expenses;
    result.status = 'OK';

    writeFinanceLogEntry_(logSheet, result);
    return result;

  } catch (e) {
    result.error_message = e.message;
    console.log('❌ API: ' + e.message + '\n' + (e.stack || ''));
    writeFinanceLogEntry_(logSheet, result);
    return result;
  }
}

