/**
 * Создаёт лист IMPORT_LOG_FINANCE (если нет) с нужными колонками.
 */
function createImportLogFinanceSheet() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var name = IMPORT_LOG_FINANCE_SHEET_NAME_;
  var sheet = ss.getSheetByName(name);

  if (sheet) {
    var eh = sheet.getRange(1, 1, 1, Math.max(1, sheet.getLastColumn())).getValues()[0];
    if (String(eh[0] || '').trim() === IMPORT_LOG_FINANCE_HEADERS_[0]) {
      SpreadsheetApp.getUi().alert('✅ ' + name, 'Лист уже существует.',
        SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    }
  } else {
    sheet = ss.insertSheet(name);
  }

  var h = IMPORT_LOG_FINANCE_HEADERS_;
  if (sheet.getMaxColumns() < h.length) {
    sheet.insertColumnsAfter(sheet.getMaxColumns(), h.length - sheet.getMaxColumns());
  }
  sheet.getRange(1, 1, 1, h.length).setValues([h]);
  sheet.getRange(1, 1, 1, h.length)
    .setFontWeight('bold').setBackground('#1F2937').setFontColor('#FFFFFF')
    .setFontSize(10).setFontFamily('Arial');

  var w = [150, 150, 90, 100, 100, 200, 240, 120, 90, 80,
           110, 110, 110, 100, 110, 100, 130, 120, 120, 70, 300];
  for (var i = 0; i < w.length; i++) sheet.setColumnWidth(i + 1, w[i]);
  sheet.setFrozenRows(1);
  SpreadsheetApp.flush();

  SpreadsheetApp.getUi().alert('✅ ' + name + ' создан',
    'Лог готов (' + h.length + ' колонок).',
    SpreadsheetApp.getUi().ButtonSet.OK);
}

/** Возвращает лист лога, создаёт при отсутствии (без UI). */
function ensureImportLogFinanceSheet_(ss) {
  var sheet = ss.getSheetByName(IMPORT_LOG_FINANCE_SHEET_NAME_);
  if (sheet) {
    var eh = sheet.getRange(1, 1, 1, Math.max(1, sheet.getLastColumn())).getValues()[0];
    if (String(eh[0] || '').trim() === IMPORT_LOG_FINANCE_HEADERS_[0]) return sheet;
  }
  if (!sheet) sheet = ss.insertSheet(IMPORT_LOG_FINANCE_SHEET_NAME_);
  var h = IMPORT_LOG_FINANCE_HEADERS_;
  if (sheet.getMaxColumns() < h.length) {
    sheet.insertColumnsAfter(sheet.getMaxColumns(), h.length - sheet.getMaxColumns());
  }
  sheet.getRange(1, 1, 1, h.length).setValues([h]);
  sheet.getRange(1, 1, 1, h.length)
    .setFontWeight('bold').setBackground('#1F2937').setFontColor('#FFFFFF');
  sheet.setFrozenRows(1);
  SpreadsheetApp.flush();
  return sheet;
}

