/**
 * 💰 Обновить финансы WB
 *   1. API rolling 14 дней (основной)
 *   2. Drive Folder Loader (резервный — подхватывает новые XLSX)
 *   3. Пересборка CLEAN_WB_DAILY (buildCleanWbDailyWithFinance)
 *   4. Сверка по ключевым суммам
 */
function updateWbFinanceData() {
  var t0 = Date.now();
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();

  console.log('═══ updateWbFinanceData() СТАРТ ═══');

  var range = financeRolling14Range_();
  var dateFrom = range.from, dateTo = range.to;

  // ── 1. API rolling 14 days ──
  console.log('  Шаг 1: API rolling 14 дней (' + dateFrom + ' — ' + dateTo + ')');
  var apiResult = importWbFinanceFromApiInternal_(dateFrom, dateTo);
  var apiOk = (apiResult.status === 'OK');
  console.log('  API: ' + apiResult.status + ' (новых ' + apiResult.rows_imported +
    ', дублей ' + apiResult.skipped_dupes + ')');

  // ── 2. Drive Folder Loader (всегда — подхватывает прочие периоды/файлы) ──
  console.log('  Шаг 2: Drive Folder Loader');
  var driveResult = importDriveFinanceInternal_();
  console.log('  Drive: ' + driveResult.status + ' (новых файлов ' + driveResult.newFiles +
    ', новых строк ' + driveResult.totalNewRows + ')');

  // ── 3. Пересборка CLEAN_WB_DAILY ──
  var cleanOk = false, cleanErr = '';
  try {
    if (typeof buildCleanWbDailyWithFinance === 'function') {
      console.log('  Шаг 3: пересборка CLEAN_WB_DAILY');
      buildCleanWbDailyWithFinance();
      cleanOk = true;
    } else {
      cleanErr = 'buildCleanWbDailyWithFinance() не найдена';
    }
  } catch (e) {
    cleanErr = e.message;
    console.log('  ⚠️ CLEAN: ' + e.message);
  }

  // ── 4. Сверка за период ──
  var rawSheet = getRawFinanceSheet_(ss);
  var sums = null;
  if (rawSheet && rawSheet.getLastRow() >= 2) {
    var hMap = buildFinanceRawHeaderMap_(rawSheet, rawSheet.getLastColumn());
    var periodRows = readFinanceRowsForPeriod_(rawSheet, hMap, dateFrom, dateTo);
    sums = aggregateFinanceSums_(periodRows, hMap);
  }

  // ── Итоговый алерт ──
  var elapsed = sec_(t0);
  var msg = '💰 Обновление финансов WB\n\n';

  msg += '1️⃣ API (' + dateFrom + ' — ' + dateTo + '): ';
  if (apiOk) {
    msg += '✅\n   Новых строк: ' + apiResult.rows_imported +
      ', дублей: ' + apiResult.skipped_dupes + '\n';
    if (apiResult.error_message) msg += '   (' + apiResult.error_message + ')\n';
  } else {
    msg += '❌\n   ' + apiResult.error_message + '\n';
  }

  msg += '\n2️⃣ Drive Folder Loader: ';
  if (driveResult.status === 'OK' || driveResult.status === 'PARTIAL') {
    if (driveResult.newFiles > 0) {
      msg += '✅ Новых файлов: ' + driveResult.newFiles + ', строк: ' + driveResult.totalNewRows + '\n';
    } else {
      msg += '✅ Новых файлов нет (пропущено: ' + driveResult.skippedFiles + ')\n';
    }
  } else {
    msg += '⚠️ ' + (driveResult.error || driveResult.status) + '\n';
  }

  msg += '\n3️⃣ CLEAN_WB_DAILY: ' + (cleanOk ? '✅ пересобран' : '⚠️ ' + cleanErr) + '\n';

  if (sums) {
    msg += '\n── Суммы за период ' + dateFrom + '—' + dateTo + ' ──\n' +
      'К перечислению: ' + sums.wb_for_pay + ' ₽\n' +
      'Логистика: ' + sums.wb_logistics + ' ₽\n' +
      'Хранение: ' + sums.wb_storage + ' ₽\n' +
      'Удержания: ' + sums.wb_deductions + ' ₽\n' +
      'После расходов WB: ' + sums.wb_after_expenses + ' ₽\n';
  }

  msg += '\nВремя: ' + elapsed + ' сек';

  ui.alert('💰 Обновление финансов WB', msg, ui.ButtonSet.OK);
  console.log('═══ updateWbFinanceData() ЗАВЕРШЕНО: ' + elapsed + ' сек ═══');
}


