/** Строит rawHeaderMap {colNameLower → idx}. */
function buildFinanceRawHeaderMap_(rawSheet, rawLastCol) {
  var headers = rawSheet.getRange(1, 1, 1, rawLastCol).getValues()[0];
  var map = {};
  for (var i = 0; i < headers.length; i++) {
    var k = String(headers[i] || '').trim().toLowerCase();
    if (k) map[k] = i;
  }
  return map;
}

/** MD5-хэш строки → hex. */
function financeMd5_(s) {
  var bytes = Utilities.computeDigest(Utilities.DigestAlgorithm.MD5, String(s), Utilities.Charset.UTF_8);
  var hex = '';
  for (var i = 0; i < bytes.length; i++) {
    var b = (bytes[i] + 256) % 256;
    hex += (b < 16 ? '0' : '') + b.toString(16);
  }
  return hex;
}

/**
 * row_hash по устойчивым идентификаторам операции из массива-строки RAW.
 * Использует rawHeaderMap для доступа к колонкам.
 */
function computeFinanceRowHash_(rowArr, hMap) {
  function g(name) {
    var idx = hMap[name];
    return idx === undefined ? '' : String(rowArr[idx] === undefined || rowArr[idx] === null ? '' : rowArr[idx]).trim();
  }
  var parts = [
    g('rrd_id'),
    g('srid'),
    g('rid'),
    g('shk_id'),
    g('sticker_id'),
    normalizeNmIdFinance_(g('wb_nm_id')),
    normalizeDateKey_(g('sale_dt')),
    normalizeDateKey_(g('rr_dt')),
    g('supplier_oper_name'),
    g('doc_type_name'),
    g('quantity')
  ];
  return financeMd5_(parts.join('|'));
}

/** Множество row_hash всех существующих строк RAW_WB_FINANCE. */
function buildExistingFinanceHashSet_(rawSheet, hMap) {
  var set = {};
  var lr = rawSheet.getLastRow();
  if (lr < 2) return set;
  var data = rawSheet.getRange(2, 1, lr - 1, rawSheet.getLastColumn()).getValues();
  var rhCol = hMap['row_hash'];
  for (var i = 0; i < data.length; i++) {
    var h = rhCol !== undefined ? String(data[i][rhCol] || '').trim() : '';
    if (!h) h = computeFinanceRowHash_(data[i], hMap);
    if (h) set[h] = true;
  }
  return set;
}

/** min/max нормализованной даты по строкам (по sale_dt, иначе rr_dt). */
function financeRowsDateRange_(rows, hMap) {
  var saleCol = hMap['sale_dt'], rrCol = hMap['rr_dt'];
  var min = null, max = null;
  for (var i = 0; i < rows.length; i++) {
    var dk = '';
    if (saleCol !== undefined) dk = normalizeDateKey_(rows[i][saleCol]);
    if (!dk && rrCol !== undefined) dk = normalizeDateKey_(rows[i][rrCol]);
    if (!dk) continue;
    if (!min || dk < min) min = dk;
    if (!max || dk > max) max = dk;
  }
  return { from: min, to: max };
}

/** Дозаписывает строки в конец RAW_WB_FINANCE (без очистки чужих данных). */
function appendFinanceRows_(rawSheet, rows, rawLastCol) {
  if (!rows.length) return 0;
  var ir = rawSheet.getLastRow() + 1; if (ir < 2) ir = 2;
  if (rawSheet.getMaxColumns() < rawLastCol) {
    rawSheet.insertColumnsAfter(rawSheet.getMaxColumns(), rawLastCol - rawSheet.getMaxColumns());
  }
  if (rawSheet.getMaxRows() < ir + rows.length - 1) {
    rawSheet.insertRowsAfter(rawSheet.getMaxRows(), ir + rows.length - rawSheet.getMaxRows());
  }
  var range = rawSheet.getRange(ir, 1, rows.length, rawLastCol);
  try { range.clearDataValidations(); } catch (e) { /* ok */ }
  range.setValues(rows);
  SpreadsheetApp.flush();
  return rows.length;
}

/**
 * Удаляет ТОЛЬКО строки этого загрузчика (по префиксу load_id)
 * за период [dateFrom, dateTo]. Не трогает строки ручного импорта
 * (префикс "DRIVE_XLSX_FINANCE_") и иные источники.
 */
function clearFinanceOwnPeriod_(rawSheet, hMap, dateFrom, dateTo, loadIdPrefix) {
  var lr = rawSheet.getLastRow();
  if (lr < 2) return 0;
  var loadCol = hMap['load_id'];
  var saleCol = hMap['sale_dt'];
  var rrCol = hMap['rr_dt'];
  if (loadCol === undefined) return 0;

  var cc = rawSheet.getLastColumn();
  var all = rawSheet.getRange(2, 1, lr - 1, cc).getValues();
  var keep = [], del = 0;

  for (var i = 0; i < all.length; i++) {
    var lid = String(all[i][loadCol] || '');
    var dk = '';
    if (saleCol !== undefined) dk = normalizeDateKey_(all[i][saleCol]);
    if (!dk && rrCol !== undefined) dk = normalizeDateKey_(all[i][rrCol]);

    var isOwn = lid.indexOf(loadIdPrefix) === 0;
    var inPeriod = dk && dk >= dateFrom && dk <= dateTo;

    if (isOwn && inPeriod) { del++; } else { keep.push(all[i]); }
  }

  if (del === 0) return 0;
  rawSheet.getRange(2, 1, lr - 1, cc).clearContent();
  if (keep.length > 0) rawSheet.getRange(2, 1, keep.length, cc).setValues(keep);
  SpreadsheetApp.flush();
  return del;
}


