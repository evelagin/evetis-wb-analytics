  var msg = '💰 Импорт финансов из папки\n\n' +
    'Папка: ' + out.folderName + '\nФайлов: ' + out.fileCount + '\n\n' +
    '✅ Новых файлов: ' + out.newFiles + '\n⏭️ Пропущено: ' + out.skippedFiles +
    '\n❌ Ошибок: ' + out.errorFiles + '\n';
  if (out.newFiles > 0) {
    msg += '\nНовых строк: ' + out.totalNewRows + '\nПропущено дублей строк: ' + out.totalDupes + '\n';
  }
  for (var i = 0; i < out.results.length; i++) {
    var r = out.results[i];
    msg += '\n' + (r.ok ? '✅' : '❌') + ' ' + r.name +
      (r.ok ? ' (' + (r.period || '') + ') → ' + r.newRows + ' строк' + (r.dupes ? ', дублей ' + r.dupes : '')
            : '\n   ' + r.error);
  }
  msg += '\n\nВремя: ' + sec_(t0) + ' сек';
  ui.alert('💰 Импорт финансов', msg, ui.ButtonSet.OK);
  return out;
}


// ═══════════════════════════════════════
// СВЕРКА
// ═══════════════════════════════════════

/**
 * Сверка ключевых сумм за период:
 *   - внутренняя согласованность after_expenses;
 *   - storage_fee из RAW_WB_FINANCE vs RAW_WB_STORAGE (если доступно);
 *   - распределение строк по источникам (API/DRIVE/ручной импорт).
 *
 * @param {string} dateFrom
 * @param {string} dateTo
 */
function verifyFinanceReconciliation(dateFrom, dateTo) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();

  if (!dateFrom || !dateTo) {
    var rg = financeRolling14Range_();
    dateFrom = dateFrom || rg.from;
    dateTo = dateTo || rg.to;
  }

  var rawSheet = getRawFinanceSheet_(ss);
  if (!rawSheet || rawSheet.getLastRow() < 2) {
    ui.alert('⚠️', 'RAW_WB_FINANCE пуст.', ui.ButtonSet.OK);
    return null;
  }

  var rawLastCol = rawSheet.getLastColumn();
  var hMap = buildFinanceRawHeaderMap_(rawSheet, rawLastCol);
  var periodRows = readFinanceRowsForPeriod_(rawSheet, hMap, dateFrom, dateTo);
  var sums = aggregateFinanceSums_(periodRows, hMap);

  // Внутренняя сверка after_expenses
  var recomputed = roundTwo_(
    sums.wb_for_pay - sums.wb_logistics - sums.wb_storage - sums.wb_deductions -
    sums.wb_promotion + sums.wb_transit_delivery + sums.wb_compensations
  );
  var internalDelta = roundTwo_(recomputed - sums.wb_after_expenses);
  var internalOk = Math.abs(internalDelta) <= FINANCE_RECON_THRESHOLD_;

  // Сверка хранения с RAW_WB_STORAGE (если функция доступна)
  var storageDeltaMsg = '';
  try {
    if (typeof getFinanceStorageFee_ === 'function') {
      // getFinanceStorageFee_ берёт storage_fee из RAW_WB_FINANCE — это «эталон» из финансов
      var finStorage = getFinanceStorageFee_(ss, dateFrom, dateTo);
      storageDeltaMsg = '\n— Хранение (финансы) за период: ' + roundTwo_(finStorage) + ' ₽';
    }
  } catch (e) { /* опционально */ }

  // Распределение по источникам
  var loadCol = hMap['load_id'];
  var srcCounts = { API: 0, DRIVE_loader: 0, manual: 0, other: 0 };
  for (var i = 0; i < periodRows.length; i++) {
    var lid = loadCol !== undefined ? String(periodRows[i][loadCol] || '') : '';
    if (lid.indexOf(FINANCE_LOADID_API_PREFIX_) === 0) srcCounts.API++;
    else if (lid.indexOf(FINANCE_LOADID_DRIVE_PREFIX_) === 0) srcCounts.DRIVE_loader++;
    else if (lid.indexOf('DRIVE_XLSX_FINANCE_') === 0) srcCounts.manual++;
    else srcCounts.other++;
  }

  var msg = '📊 Сверка финансов WB\n\n' +
    'Период: ' + dateFrom + ' — ' + dateTo + '\n' +
    'Строк в периоде: ' + periodRows.length + '\n\n' +
    '── КЛЮЧЕВЫЕ СУММЫ ──\n' +
    'Продажи (шт): ' + sums.sales_qty + '\n' +
    'Выручка (реализация): ' + sums.gross_revenue + ' ₽\n' +
    'К перечислению: ' + sums.wb_for_pay + ' ₽\n' +
    'Логистика: ' + sums.wb_logistics + ' ₽\n' +
    'Хранение: ' + sums.wb_storage + ' ₽\n' +
    'Удержания: ' + sums.wb_deductions + ' ₽\n' +
    'Продвижение/реклама: ' + sums.wb_promotion + ' ₽\n' +
    'Возмещение издержек: ' + sums.wb_transit_delivery + ' ₽\n' +
    'Компенсации: ' + sums.wb_compensations + ' ₽\n' +
    'После расходов WB: ' + sums.wb_after_expenses + ' ₽' + storageDeltaMsg + '\n\n' +
    '── ВНУТРЕННЯЯ СВЕРКА ──\n' +
    'Пересчёт after_expenses: ' + recomputed + ' ₽\n' +
    'Δ: ' + internalDelta + ' ₽ ' + (internalOk ? '✅' : '⚠️') + '\n\n' +
    '── ИСТОЧНИКИ СТРОК ──\n' +
    'API: ' + srcCounts.API + ', Drive-загрузчик: ' + srcCounts.DRIVE_loader +
    ', Ручной импорт: ' + srcCounts.manual +
    (srcCounts.other ? ', Прочее: ' + srcCounts.other : '');

  ui.alert('📊 Сверка финансов', msg, ui.ButtonSet.OK);
  return { sums: sums, internalDelta: internalDelta, internalOk: internalOk, srcCounts: srcCounts };
}


