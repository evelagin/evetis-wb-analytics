/**
 * Считает ключевые финансовые суммы по массиву строк RAW.
 * Логика классификации совпадает с verifyRawWbFinanceImport().
 *
 * @param {Array[]} rows — строки шириной RAW
 * @param {Object} hMap — rawHeaderMap
 * @return {Object} суммы
 */
function aggregateFinanceSums_(rows, hMap) {
  var dtCol = hMap['doc_type_name'];
  var opCol = hMap['supplier_oper_name'];
  var qtyCol = hMap['quantity'];
  var retailCol = hMap['retail_amount'];
  var forPayCol = hMap['for_pay'];
  var logCol = hMap['logistics_amount'];
  var storCol = hMap['storage_fee'];
  var deductCol = hMap['deduction'];
  var penaltyCol = hMap['penalty'];
  var addPayCol = hMap['additional_payment'];
  var compCol = hMap['compensation_amount'];

  function num(row, col) { return col === undefined ? 0 : (Number(row[col]) || 0); }
  function str(row, col) { return col === undefined ? '' : String(row[col] || '').trim(); }

  var salesQty = 0, gross = 0, forPay = 0, log = 0, stor = 0;
  var deduct = 0, promo = 0, transit = 0, comp = 0;

  for (var i = 0; i < rows.length; i++) {
    var row = rows[i];
    var dt = str(row, dtCol);
    var op = str(row, opCol);
    var opLow = op.toLowerCase();

    var isSale = (dt === 'Продажа' && op === 'Продажа');
    var isLog = opLow.indexOf('логистика') >= 0;
    var isStor = opLow.indexOf('хранение') >= 0;
    var isDeduct = opLow.indexOf('удержан') >= 0;
    var isPromo = opLow.indexOf('продвижен') >= 0 || opLow.indexOf('реклам') >= 0;
    var isLoyalty = opLow.indexOf('компенсация скидки') >= 0 || opLow.indexOf('лояльност') >= 0;
    var isTransit = opLow.indexOf('возмещение издержек') >= 0;
    var isPvz = opLow.indexOf('возмещение за выдачу') >= 0;

    // Общий «к перечислению» по всем строкам (как сумма ppvz_for_pay)
    forPay += num(row, forPayCol);

    if (isSale) {
      salesQty += Math.abs(num(row, qtyCol));
      gross += Math.abs(num(row, retailCol));
    }
    if (isLog) log += Math.abs(num(row, logCol) || num(row, forPayCol));
    if (isStor) stor += Math.abs(num(row, storCol) || num(row, forPayCol));
    if (isDeduct) deduct += Math.abs(num(row, deductCol) || num(row, forPayCol));
    if (isPromo) promo += Math.abs(num(row, deductCol) || num(row, forPayCol));
    if (isTransit) transit += (num(row, addPayCol) || num(row, forPayCol));
    if (isLoyalty) comp += (num(row, compCol) || num(row, addPayCol) || num(row, forPayCol));
    if (isPvz) comp += (num(row, addPayCol) || num(row, forPayCol));
  }

  var afterExpenses = forPay - log - stor - deduct - promo + transit + comp;

  return {
    sales_qty: salesQty,
    gross_revenue: roundTwo_(gross),
    wb_for_pay: roundTwo_(forPay),
    wb_logistics: roundTwo_(log),
    wb_storage: roundTwo_(stor),
    wb_deductions: roundTwo_(deduct),
    wb_promotion: roundTwo_(promo),
    wb_transit_delivery: roundTwo_(transit),
    wb_compensations: roundTwo_(comp),
    wb_after_expenses: roundTwo_(afterExpenses)
  };
}

/** Читает строки RAW_WB_FINANCE за период [from,to] (по sale_dt/rr_dt). */
function readFinanceRowsForPeriod_(rawSheet, hMap, dateFrom, dateTo) {
  var lr = rawSheet.getLastRow();
  if (lr < 2) return [];
  var data = rawSheet.getRange(2, 1, lr - 1, rawSheet.getLastColumn()).getValues();
  var saleCol = hMap['sale_dt'], rrCol = hMap['rr_dt'];
  var out = [];
  for (var i = 0; i < data.length; i++) {
    var dk = '';
    if (saleCol !== undefined) dk = normalizeDateKey_(data[i][saleCol]);
    if (!dk && rrCol !== undefined) dk = normalizeDateKey_(data[i][rrCol]);
    if (!dk) continue;
    if (dateFrom && dk < dateFrom) continue;
    if (dateTo && dk > dateTo) continue;
    out.push(data[i]);
  }
  return out;
}


