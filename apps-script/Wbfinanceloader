// DRIVE FOLDER LOADER (резервный режим)
// Использует РАБОЧИЙ парсер normalizeWbFinanceRowsToRaw_ без изменений.
// ═══════════════════════════════════════

/**
 * Собирает file_id уже успешно загруженных через Drive файлов из лога.
 */
function getFinanceProcessedFileIds_(logSheet) {
  var res = {};
  var lr = logSheet.getLastRow();
  if (lr < 2) return res;
  var data = logSheet.getRange(2, 1, lr - 1, IMPORT_LOG_FINANCE_HEADERS_.length).getValues();
  // file_id = idx 5, status = idx 19
  for (var r = 0; r < data.length; r++) {
    var fid = String(data[r][5] || '').trim();
    var st = String(data[r][19] || '').trim();
    if (fid) res[fid] = st;
  }
  return res;
}

/**
 * Обрабатывает один XLSX-файл через рабочий парсер.
 * Не показывает UI-алертов. Возвращает {rows, fileName, error}.
 */
function processFinanceFileForLoader_(ss, fileId, rawHeaderMap, rawLastCol, skuIndex, loadId) {
  var out = { rows: [], fileName: '', error: '' };

  var fileName;
  try { fileName = DriveApp.getFileById(fileId).getName(); }
  catch (e) { out.error = 'Файл не найден: ' + e.message; return out; }
  out.fileName = fileName;

  var tempId = convertXlsxToGoogleSheet_(fileId, fileName);
  if (!tempId) { out.error = 'Конвертация xlsx не удалась'; return out; }

  try {
    var tempSS = SpreadsheetApp.openById(tempId);
    var tempSheet = tempSS.getSheets()[0];
    var lastRow = tempSheet.getLastRow();
    var lastCol = tempSheet.getLastColumn();
    if (lastRow < 2 || lastCol < 2) {
      cleanupTempSheet_(tempId);
      out.error = 'Пустой лист: ' + lastRow + '×' + lastCol;
      return out;
    }

    var allValues = tempSheet.getRange(1, 1, lastRow, lastCol).getValues();
    var headerRowIdx = detectHeaderRow_(allValues);

    var fileMeta = {
      sourceReportPart: 'DRIVE_LOADER',
      fileId: fileId,
      fileName: fileName,
      loadId: loadId  // префикс FIN_DRIVE_ задаётся снаружи
    };

    // ВЫЗОВ рабочего парсера БЕЗ ИЗМЕНЕНИЙ
    var norm = normalizeWbFinanceRowsToRaw_(
      allValues, headerRowIdx, rawHeaderMap, rawLastCol, skuIndex, fileMeta
    );

    cleanupTempSheet_(tempId);
    out.rows = norm.rows;
    return out;

  } catch (e) {
    cleanupTempSheet_(tempId);
    out.error = e.message;
    return out;
  }
}

/**
 * Internal: импорт новых XLSX из папки. Без UI.
 * @return {Object} статистика
 */
function importDriveFinanceInternal_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var out = { status: 'ERROR', newFiles: 0, skippedFiles: 0, errorFiles: 0,
    totalNewRows: 0, totalDupes: 0, results: [], folderName: '', fileCount: 0, error: '' };

  if (!FINANCE_REPORTS_FOLDER_ID_ || FINANCE_REPORTS_FOLDER_ID_ === 'ВСТАВИТЬ_ID_ПАПКИ_С_ФИН_ОТЧЕТАМИ') {
    out.error = 'Не задан FINANCE_REPORTS_FOLDER_ID_'; return out;
  }

  var rawSheet = getRawFinanceSheet_(ss);
  if (!rawSheet) { out.error = 'Лист RAW_WB_FINANCE не найден'; return out; }
  var logSheet = ensureImportLogFinanceSheet_(ss);

  var folder;
  try { folder = DriveApp.getFolderById(FINANCE_REPORTS_FOLDER_ID_); }
  catch (e) { out.error = 'Папка не найдена: ' + e.message; return out; }
  out.folderName = folder.getName();

  // Собираем XLSX-файлы
  var xlsxFiles = [];
  var it1 = folder.getFilesByType('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
  while (it1.hasNext()) { var f = it1.next(); xlsxFiles.push({ id: f.getId(), name: f.getName() }); }
  var it2 = folder.getFilesByType('application/vnd.ms-excel');
  while (it2.hasNext()) {
    var f2 = it2.next(), dup = false;
    for (var d = 0; d < xlsxFiles.length; d++) { if (xlsxFiles[d].id === f2.getId()) { dup = true; break; } }
    if (!dup) xlsxFiles.push({ id: f2.getId(), name: f2.getName() });
  }
  out.fileCount = xlsxFiles.length;
  if (xlsxFiles.length === 0) { out.status = 'OK'; out.error = 'Папка пуста'; return out; }

  var processedIds = getFinanceProcessedFileIds_(logSheet);
  var rawLastCol = ensureRawFinanceCols_(rawSheet);
  var rawHeaderMap = buildFinanceRawHeaderMap_(rawSheet, rawLastCol);
  var skuIndex = buildSkuIndex_(ss);

  for (var fi = 0; fi < xlsxFiles.length; fi++) {
    var xf = xlsxFiles[fi];
    if (processedIds[xf.id] === 'OK') { out.skippedFiles++; continue; }

    var stamp = Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyyMMdd_HHmmss');
    var loadId = FINANCE_LOADID_DRIVE_PREFIX_ + stamp + '_' + fi;

    var fres = processFinanceFileForLoader_(ss, xf.id, rawHeaderMap, rawLastCol, skuIndex, loadId);

    var logRec = {
      load_id: loadId,
      loaded_at: Utilities.formatDate(new Date(), 'Europe/Moscow', 'yyyy-MM-dd HH:mm:ss'),
      source_type: FINANCE_SOURCE_DRIVE_,
      period_from: '', period_to: '',
      file_id: xf.id, file_name: xf.name, task_id: '',
      rows_imported: 0, sales_qty: 0, gross_revenue: 0,
      wb_for_pay: 0, wb_logistics: 0, wb_storage: 0, wb_deductions: 0,
      wb_promotion: 0, wb_transit_delivery: 0, wb_compensations: 0, wb_after_expenses: 0,
      status: 'ERROR', error_message: ''
    };

    if (fres.error) {
      logRec.error_message = fres.error;
      writeFinanceLogEntry_(logSheet, logRec);
      out.errorFiles++;
      out.results.push({ ok: false, name: xf.name, error: fres.error });
      continue;
    }

    var rows = fres.rows;
    if (!rows.length) {
      logRec.status = 'OK';
      logRec.error_message = 'Нет строк после нормализации';
      writeFinanceLogEntry_(logSheet, logRec);
      out.results.push({ ok: true, name: xf.name, newRows: 0, dupes: 0 });
      continue;
    }

    // Период из реальных дат файла → правим метаданные периода в своих строках
    var range = financeRowsDateRange_(rows, rawHeaderMap);
    logRec.period_from = range.from || '';
    logRec.period_to = range.to || '';
    fixFinanceRowsPeriodMeta_(rows, rawHeaderMap, range.from, range.to);

    // row_hash для каждой строки + дедуп
    var existing = buildExistingFinanceHashSet_(rawSheet, rawHeaderMap);
    var batchSeen = {}, toWrite = [], dupes = 0;
    var rhCol = rawHeaderMap['row_hash'];
    for (var ri = 0; ri < rows.length; ri++) {
      var h = computeFinanceRowHash_(rows[ri], rawHeaderMap);
      if (rhCol !== undefined) rows[ri][rhCol] = h;
      if (existing[h] || batchSeen[h]) { dupes++; continue; }
      batchSeen[h] = true;
      toWrite.push(rows[ri]);
    }

    appendFinanceRows_(rawSheet, toWrite, rawLastCol);

    // Суммы по строкам этого файла
    var sums = aggregateFinanceSums_(rows, rawHeaderMap);
    logRec.rows_imported = toWrite.length;
    logRec.sales_qty = sums.sales_qty;
    logRec.gross_revenue = sums.gross_revenue;
    logRec.wb_for_pay = sums.wb_for_pay;
    logRec.wb_logistics = sums.wb_logistics;
    logRec.wb_storage = sums.wb_storage;
    logRec.wb_deductions = sums.wb_deductions;
    logRec.wb_promotion = sums.wb_promotion;
    logRec.wb_transit_delivery = sums.wb_transit_delivery;
    logRec.wb_compensations = sums.wb_compensations;
    logRec.wb_after_expenses = sums.wb_after_expenses;
    logRec.status = 'OK';
    writeFinanceLogEntry_(logSheet, logRec);

    out.newFiles++;
    out.totalNewRows += toWrite.length;
    out.totalDupes += dupes;
    out.results.push({ ok: true, name: xf.name, newRows: toWrite.length, dupes: dupes,
      period: (range.from || '?') + '—' + (range.to || '?') });
  }

  out.status = out.errorFiles > 0 ? 'PARTIAL' : 'OK';
  return out;
}

/**
 * Перезаписывает метаданные периода (request_/report_period_from/to)
 * в строках, произведённых рабочим парсером (он ставит туда IMPORT_PERIOD_).
 * Меняем ТОЛЬКО свои строки-массивы в памяти — парсер не трогаем.
 */
function fixFinanceRowsPeriodMeta_(rows, hMap, from, to) {
  var cols = ['request_date_from', 'report_period_from'];
  var colsTo = ['request_date_to', 'report_period_to'];
  for (var i = 0; i < rows.length; i++) {
    for (var a = 0; a < cols.length; a++) {
      var ci = hMap[cols[a]]; if (ci !== undefined && from) rows[i][ci] = from;
    }
    for (var b = 0; b < colsTo.length; b++) {
      var cj = hMap[colsTo[b]]; if (cj !== undefined && to) rows[i][cj] = to;
    }
    // period_month по sale_dt/rr_dt
    if (hMap['period_month'] !== undefined) {
      var dk = '';
      if (hMap['sale_dt'] !== undefined) dk = normalizeDateKey_(rows[i][hMap['sale_dt']]);
      if (!dk && hMap['rr_dt'] !== undefined) dk = normalizeDateKey_(rows[i][hMap['rr_dt']]);
      if (dk) rows[i][hMap['period_month']] = dk.substring(0, 7);
    }
  }
}

